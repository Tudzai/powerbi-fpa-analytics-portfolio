          },
          {
            "name": "Active Users",
            "displayFolder": "Lifecycle",
            "expression": "SUM ( MonthlyKPIs[ActiveUsers] )",
            "formatString": "#,0",
            "lineageTag": "cb259514-e298-4df3-9a69-2153a92bd322"
          },
          {
            "name": "Returning Users",
            "displayFolder": "Lifecycle",
