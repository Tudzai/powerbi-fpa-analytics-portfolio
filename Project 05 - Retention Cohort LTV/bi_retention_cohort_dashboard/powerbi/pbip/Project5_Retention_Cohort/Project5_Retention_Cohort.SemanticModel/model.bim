            "lineageTag": "cbf3fe5a-90a8-4692-abb6-b25e9c34e51c"
          },
          {
            "name": "LTV To Date",
            "displayFolder": "Revenue",
            "expression": "AVERAGE ( MonthlyKPIs[LTVToDate] )",
            "formatString": "$#,0",
            "lineageTag": "d8bf2e7f-8523-465a-952a-4bda197b0828"
          },
          {
            "name": "Cohort Retention %",
            "displayFolder": "Cohort",
            "expression": "DIVIDE ( SUM ( CohortRetention[RetainedCustomers] ), SUM ( CohortRetention[CohortSize] ) )",
            "formatString": "0.0%",
            "lineageTag": "c126a281-0bef-4fff-b500-309bd47a2c48"
          },
          {
            "name": "Cohort Repeat Purchase %",
            "displayFolder": "Cohort",
            "expression": "DIVIDE ( SUM ( CohortRetention[RepeatCustomers] ), SUM ( CohortRetention[CohortSize] ) )",
            "formatString": "0.0%",
            "lineageTag": "fa7a59ff-bb89-4a3e-8468-0c9b0ada75fe"
          },
          {
            "name": "Cumulative LTV",
            "displayFolder": "Cohort",
            "expression": "DIVIDE ( SUM ( CohortRetention[CumulativeRevenue] ), SUM ( CohortRetention[CohortSize] ) )",
            "formatString": "$#,0",
            "lineageTag": "920de33d-1668-4fa0-8a36-c73e032cfb19"
          },
          {
            "name": "Latest Active Users",
            "displayFolder": "Latest",
            "expression": "VAR m = [Latest Month] RETURN CALCULATE ( [Active Users], DimMonth[MonthStart] = m )",
            "formatString": "#,0",
            "lineageTag": "74bacaee-0c0f-46eb-b8f9-014eeb0c3014"
          },
          {
            "name": "Latest Returning Users",
            "displayFolder": "Latest",
