            "formatString": "#,0",
            "lineageTag": "3dcaf711-e369-4736-94a4-a92613822ecb"
          },
          {
            "name": "Latest Repeat Purchase Rate",
            "displayFolder": "Latest",
            "expression": "VAR m = [Latest Month] RETURN CALCULATE ( [Repeat Purchase Rate], DimMonth[MonthStart] = m )",
            "formatString": "0.0%",
            "lineageTag": "7efc1121-ed2c-4fbe-92dd-460e015c542f"
          },
          {
            "name": "Latest Churn Signals",
            "displayFolder": "Latest",
            "expression": "VAR m = [Latest Month] RETURN CALCULATE ( [Churn Signal Customers], DimMonth[MonthStart] = m )",
            "formatString": "#,0",
            "lineageTag": "2e320775-268d-4b86-80d4-d3790f99d253"
          },
          {
            "name": "Latest Net Revenue",
            "displayFolder": "Latest",
