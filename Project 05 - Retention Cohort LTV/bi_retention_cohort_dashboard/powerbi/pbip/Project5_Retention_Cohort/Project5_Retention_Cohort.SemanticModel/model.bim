            "lineageTag": "4cbb4dd5-e727-49a7-aa77-03cd9e94b99d"
          },
          {
            "name": "New Customers",
            "displayFolder": "Lifecycle",
            "expression": "SUM ( MonthlyKPIs[NewCustomers] )",
            "formatString": "#,0",
            "lineageTag": "6f803bc6-1026-417b-b36f-76933d9bd213"
          },
          {
            "name": "Active Customers",
            "displayFolder": "Lifecycle",
            "expression": "SUM ( MonthlyKPIs[ActiveCustomers] )",
            "formatString": "#,0",
            "lineageTag": "e209a3d9-c101-4fe7-a11a-71a8d1b918b8"
          },
          {
            "name": "Returning Customers",
            "displayFolder": "Lifecycle",
            "expression": "SUM ( MonthlyKPIs[ReturningCustomers] )",
            "formatString": "#,0",
            "lineageTag": "7e631b39-0d84-4838-98c6-b54a269100cc"
          },
          {
            "name": "Repeat Purchasers",
            "displayFolder": "Lifecycle",
            "expression": "SUM ( MonthlyKPIs[RepeatPurchasers] )",
            "formatString": "#,0",
            "lineageTag": "be6fa729-749f-4181-ba4a-e2a0f900f8af"
          },
          {
            "name": "Repeat Purchase Rate",
            "displayFolder": "Lifecycle",
            "expression": "DIVIDE ( [Repeat Purchasers], [Active Customers] )",
            "formatString": "0.0%",
            "lineageTag": "2d84e19c-a35f-4e02-86b2-391da0e960f7"
          },
          {
            "name": "Churn Signal Customers",
            "displayFolder": "Risk",
            "expression": "SUM ( MonthlyKPIs[ChurnSignalCustomers] )",
            "formatString": "#,0",
            "lineageTag": "fcedda92-66bc-4df2-92ec-1a76fe6d6596"
          },
          {
            "name": "Churn Risk Revenue",
            "displayFolder": "Risk",
            "expression": "SUM ( MonthlyKPIs[ChurnRiskRevenue] )",
            "formatString": "$#,0,.0K",
            "lineageTag": "931ce445-ca8c-4881-aa63-0742a95e0801"
          },
          {
            "name": "Net Revenue",
            "displayFolder": "Revenue",
            "expression": "SUM ( MonthlyKPIs[NetRevenue] )",
