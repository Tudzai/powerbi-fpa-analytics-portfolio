  "maximum": "#F05D5E",
  "foreground": "#E7EDF3",
  "foregroundNeutralSecondary": "#A3B3C5",
  "backgroundLight": "#111B24",
  "backgroundNeutral": "#192633",
  "tableAccent": "#2DD4BF",
  "tokens": {
    "color": {
      "canvas": "#071018",
      "canvasAlt": "#0B151F",
      "surface": "#111B24",
