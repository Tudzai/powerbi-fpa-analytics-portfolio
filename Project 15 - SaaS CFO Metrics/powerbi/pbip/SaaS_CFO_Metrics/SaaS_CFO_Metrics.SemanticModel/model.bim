        ]
      },
      {
        "name": "KPI_Measures",
        "lineageTag": "e1df893e-a73e-4155-b8be-8771c3ecfb50",
        "columns": [
          {
            "name": "MeasureName",
            "dataType": "string",
            "sourceColumn": "MeasureName",
            "isHidden": true
          }
        ],
        "partitions": [
          {
            "name": "p_KPI_Measures",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": "let Source = #table(type table [MeasureName = text], {{\"KPI\"}}) in Source"
            }
          }
        ],
        "measures": [
          {
            "name": "Beginning MRR",
            "expression": "SUM ( FactSubscriptionMonthly[BeginningMRR] )",
            "formatString": "$#,0,,.0M",
            "lineageTag": "9e2145c1-9a3c-4f35-a276-0f18874d6487"
          },
          {
            "name": "Ending MRR",
            "expression": "SUM ( FactSubscriptionMonthly[EndingMRR] )",
            "formatString": "$#,0,,.0M",
            "lineageTag": "f0fef635-484d-4146-9189-235daaf02dde"
          },
          {
            "name": "ARR",
            "expression": "[Ending MRR] * 12",
            "formatString": "$#,0,,.0M",
            "lineageTag": "785a0457-6776-4526-8e20-91d6e95b34da"
          },
          {
            "name": "New ARR",
            "expression": "SUM ( FactSubscriptionMonthly[NewMRR] ) * 12",
            "formatString": "$#,0,,.0M",
            "lineageTag": "d2fc41b5-d0a5-4c6b-a7bd-7371c8262559"
          },
          {
            "name": "Expansion ARR",
            "expression": "SUM ( FactSubscriptionMonthly[ExpansionMRR] ) * 12",
            "formatString": "$#,0,,.0M",
            "lineageTag": "55d0d224-e19d-4552-8fbb-e1bf9a7800c8"
          },
          {
            "name": "Contraction ARR",
            "expression": "ABS ( SUM ( FactSubscriptionMonthly[ContractionMRR] ) ) * 12",
            "formatString": "$#,0,,.0M",
            "lineageTag": "626ad466-ef44-4fe7-9c59-bf7a671161bc"
          },
          {
            "name": "Churn ARR",
            "expression": "ABS ( SUM ( FactSubscriptionMonthly[ChurnMRR] ) ) * 12",
            "formatString": "$#,0,,.0M",
            "lineageTag": "2473296d-9926-4875-b939-69a481bd6a5b"
          },
          {
            "name": "Net New ARR",
            "expression": "[New ARR] + [Expansion ARR] - [Contraction ARR] - [Churn ARR]",
            "formatString": "$#,0,,.0M",
            "lineageTag": "a76c5a66-9839-4f94-9794-7d9807857608"
          },
          {
            "name": "ARR Movement",
            "expression": "SUM ( FactMRRMovement[ARRMovement] )",
            "formatString": "$#,0,,.0M",
            "lineageTag": "b2644e3e-b159-458f-bee5-f1ef04e8be4f"
          },
          {
            "name": "Revenue",
            "expression": "SUM ( FactSubscriptionMonthly[RecognizedRevenue] )",
            "formatString": "$#,0,,.0M",
            "lineageTag": "ec6ddc8f-704b-43ef-9902-0f054edb81ef"
          },
          {
            "name": "Gross Margin",
            "expression": "SUM ( FactSubscriptionMonthly[GrossMargin] )",
            "formatString": "$#,0,,.0M",
            "lineageTag": "a0d58969-6d9f-4b13-aa7d-0192cdf2271b"
          },
          {
            "name": "Gross Margin %",
            "expression": "DIVIDE ( [Gross Margin], [Revenue] )",
            "formatString": "0.0%",
            "lineageTag": "a6f70f75-3018-4896-b163-f2d7096efdde"
          },
          {
            "name": "Starting Customers",
            "expression": "SUM ( FactSubscriptionMonthly[StartingLogo] )",
            "formatString": "#,0",
            "lineageTag": "5a2b73a0-903e-4a71-a6fc-a3e7a63b8bb0"
          },
          {
            "name": "Active Customers",
            "expression": "SUM ( FactSubscriptionMonthly[ActiveLogo] )",
            "formatString": "#,0",
            "lineageTag": "09077c4f-8923-4ad6-b6be-8cfb444c53e1"
          },
          {
            "name": "New Customers",
            "expression": "SUM ( FactSubscriptionMonthly[NewLogo] )",
            "formatString": "#,0",
            "lineageTag": "a08a1297-2e01-4c07-ab40-c74de8c647ed"
          },
          {
            "name": "Churned Customers",
            "expression": "SUM ( FactSubscriptionMonthly[ChurnedLogo] )",
            "formatString": "#,0",
            "lineageTag": "7306e4b9-ad7e-41a2-a625-f4b6bcb60978"
          },
          {
            "name": "NRR",
            "expression": "DIVIDE ( [Ending MRR] - SUM ( FactSubscriptionMonthly[NewMRR] ), [Beginning MRR] )",
            "formatString": "0.0%",
            "lineageTag": "826bea0d-758d-494e-a4af-29b71c5c14c9"
          },
          {
            "name": "GRR",
            "expression": "DIVIDE ( [Beginning MRR] - [Contraction ARR] / 12 - [Churn ARR] / 12, [Beginning MRR] )",
            "formatString": "0.0%",
            "lineageTag": "f56a816f-32a5-45c9-a021-ce7e22118427"
          },
          {
            "name": "Revenue Churn Rate",
            "expression": "DIVIDE ( [Churn ARR], [Beginning MRR] * 12 )",
            "formatString": "0.0%",
            "lineageTag": "201cf65d-ed08-43c5-9add-5c43180bc4e9"
          },
          {
            "name": "Logo Churn Rate",
            "expression": "DIVIDE ( [Churned Customers], [Starting Customers] )",
            "formatString": "0.0%",
            "lineageTag": "19d4efc5-6e75-4152-bf1b-bf68f6b47d8b"
          },
          {
            "name": "S&M Spend",
            "expression": "SUM ( FactAcquisitionMonthly[SalesMarketingSpend] )",
            "formatString": "$#,0,,.0M",
            "lineageTag": "cb059cee-24a5-4132-9812-816d17b235bf"
          },
          {
            "name": "New ARR Booked",
            "expression": "SUM ( FactAcquisitionMonthly[NewARRBooked] )",
            "formatString": "$#,0,,.0M",
            "lineageTag": "5c5e4844-2198-4181-a9d1-2a1f22eb8603"
          },
          {
            "name": "CAC",
            "expression": "DIVIDE ( [S&M Spend], SUM ( FactAcquisitionMonthly[NewCustomers] ) )",
            "formatString": "$#,0",
            "lineageTag": "89d4c570-8b8c-44bd-b266-7572f5ccd0d5"
          },
          {
            "name": "ARPA",
            "expression": "DIVIDE ( [Ending MRR], [Active Customers] )",
            "formatString": "$#,0",
            "lineageTag": "f03a7cab-d38c-4db6-8c1f-c488df3294bc"
          },
          {
            "name": "LTV",
            "expression": "DIVIDE ( [ARPA] * 12 * [Gross Margin %], [Revenue Churn Rate] )",
            "formatString": "$#,0",
            "lineageTag": "a15ed4c8-c0b8-473d-8a65-4231138c0333"
          },
          {
            "name": "LTV CAC Ratio",
            "expression": "DIVIDE ( [LTV], [CAC] )",
            "formatString": "0.0x",
            "lineageTag": "a78fdf20-f38f-43d7-b0d2-288b09b7047a"
          },
          {
            "name": "CAC Payback Months",
            "expression": "DIVIDE ( [CAC], DIVIDE ( [Gross Margin], [Active Customers] ) )",
            "formatString": "0.0",
            "lineageTag": "c34df212-3b24-432a-ad84-db3da1540cbb"
          },
          {
            "name": "Magic Number",
            "expression": "DIVIDE ( [Net New ARR], [S&M Spend] )",
            "formatString": "0.0x",
            "lineageTag": "0731f6ee-d380-4d6d-a79c-1286719cbc36"
          },
          {
            "name": "EBITDA",
            "expression": "SUM ( FactFinanceMonthly[EBITDA] )",
            "formatString": "$#,0,,.0M",
            "lineageTag": "8660933b-53dc-4d5f-bdce-3cae6c443f2f"
          },
          {
            "name": "EBITDA Margin",
            "expression": "DIVIDE ( [EBITDA], SUM ( FactFinanceMonthly[Revenue] ) )",
            "formatString": "0.0%",
            "lineageTag": "1cc34abb-276b-4b55-9a7b-cc0e035a59db"
          },
          {
            "name": "ARR Growth %",
            "expression": "AVERAGE ( FactFinanceMonthly[ARRGrowthPct] )",
            "formatString": "0.0%",
            "lineageTag": "85cc2fe4-8a5f-4e62-ac5d-0b28b1c114a2"
          },
          {
            "name": "Rule of 40",
            "expression": "[ARR Growth %] + [EBITDA Margin]",
            "formatString": "0.0%",
            "lineageTag": "d744f1dd-385f-4242-b612-5057830ae4e6"
          },
          {
            "name": "Net Burn",
            "expression": "SUM ( FactFinanceMonthly[NetBurn] )",
            "formatString": "$#,0,,.0M",
            "lineageTag": "06c277a1-9bbd-49d3-a6c6-028cefd5d4f6"
          },
          {
            "name": "Cash Balance",
            "expression": "SUM ( FactFinanceMonthly[CashBalance] )",
            "formatString": "$#,0,,.0M",
            "lineageTag": "4d4c7c66-ebc7-48af-9ecb-7115f58b28bf"
          },
          {
            "name": "Burn Multiple",
            "expression": "DIVIDE ( [Net Burn], DIVIDE ( [Net New ARR], 12 ) )",
            "formatString": "0.0x",
            "lineageTag": "9881c4f6-fd98-41d7-a7bf-507d2e3736c3"
          },
          {
            "name": "Forecast ARR",
            "expression": "SUM ( FactFinanceMonthly[ForecastARR] )",
            "formatString": "$#,0,,.0M",
            "lineageTag": "96cca008-d1c4-45b5-b40d-5e4673cbf47b"
          },
          {
            "name": "Plan ARR",
            "expression": "SUM ( FactFinanceMonthly[PlanARR] )",
            "formatString": "$#,0,,.0M",
            "lineageTag": "7ff66f7e-182e-417a-8217-0405422955fb"
          },
          {
            "name": "Forecast Accuracy",
            "expression": "1 - DIVIDE ( ABS ( [ARR] - [Forecast ARR] ), [ARR] )",
            "formatString": "0.0%",
            "lineageTag": "e333644b-77c6-4420-9c3e-52876db45a86"
          },
          {
            "name": "Cohort NRR",
            "expression": "DIVIDE ( SUM ( FactCohortRetention[RetainedMRR] ), SUM ( FactCohortRetention[CohortStartMRR] ) )",
            "formatString": "0.0%",
            "lineageTag": "7da3bf07-2ae6-4048-adea-197aaa19b19c"
          },
          {
            "name": "Cohort GRR",
            "expression": "DIVIDE ( SUM ( FactCohortRetention[RetainedMRR] ) - SUM ( FactCohortRetention[ExpansionMRR] ), SUM ( FactCohortRetention[CohortStartMRR] ) )",
            "formatString": "0.0%",
            "lineageTag": "867ea29b-69c6-477d-88e4-0cb31a167d6a"
          },
          {
            "name": "Cohort Active Logos",
            "expression": "SUM ( FactCohortRetention[ActiveLogos] )",
            "formatString": "#,0",
            "lineageTag": "343862c1-26b2-4f77-87f1-133e6c7b37b6"
          },
          {
            "name": "Cohort LTV",
            "expression": "DIVIDE ( SUM ( FactCohortRetention[RetainedMRR] ) * 12, SUM ( FactCohortRetention[StartLogos] ) )",
            "formatString": "$#,0",
            "lineageTag": "3dd7d252-cd2b-4dd9-872c-d6e2cf1cd46a"
          },
          {
            "name": "Scenario ARR",
            "expression": "SUM ( FactForecast[ARRValue] )",
            "formatString": "$#,0,,.0M",
            "lineageTag": "7802c568-f7d0-4382-a973-e89367c2f94c"
          },
          {
            "name": "Account Health Score",
            "expression": "AVERAGE ( FactAccountHealth[HealthScore] )",
            "formatString": "0.0",
            "lineageTag": "1dda7b24-61d0-4d1b-b080-4064faf5a45a"
          },
          {
            "name": "Latest ARR",
            "expression": "VAR LatestMonth =\n    MAXX (\n        CALCULATETABLE (\n            VALUES ( DimDate[MonthStart] ),\n            ALLSELECTED ( DimDate ),\n            REMOVEFILTERS ( DimDate[IsLatestCompleteMonth] )\n        ),\n        DimDate[MonthStart]\n    )\nRETURN\n    CALCULATE ( [ARR], FILTER ( ALL ( DimDate ), DimDate[MonthStart] = LatestMonth ) )",
            "formatString": "$#,0,,.0M",
            "lineageTag": "130f8813-ee30-47a8-9ba5-6c4717f3fff3"
          },
          {
            "name": "Latest Net New ARR",
            "expression": "VAR LatestMonth =\n    MAXX (\n        CALCULATETABLE (\n            VALUES ( DimDate[MonthStart] ),\n            ALLSELECTED ( DimDate ),\n            REMOVEFILTERS ( DimDate[IsLatestCompleteMonth] )\n        ),\n        DimDate[MonthStart]\n    )\nRETURN\n    CALCULATE ( [Net New ARR], FILTER ( ALL ( DimDate ), DimDate[MonthStart] = LatestMonth ) )",
            "formatString": "$#,0,,.0M",
            "lineageTag": "d339d21c-d6e9-4c83-a990-35a3538f5a88"
          },
          {
            "name": "Latest NRR",
            "expression": "VAR LatestMonth =\n    MAXX (\n        CALCULATETABLE (\n            VALUES ( DimDate[MonthStart] ),\n            ALLSELECTED ( DimDate ),\n            REMOVEFILTERS ( DimDate[IsLatestCompleteMonth] )\n        ),\n        DimDate[MonthStart]\n    )\nRETURN\n    CALCULATE ( [NRR], FILTER ( ALL ( DimDate ), DimDate[MonthStart] = LatestMonth ) )",
            "formatString": "0.0%",
            "lineageTag": "93a65f2b-0ff7-4fcf-960c-ae6ee59f555f"
          },
          {
            "name": "Latest GRR",
            "expression": "VAR LatestMonth =\n    MAXX (\n        CALCULATETABLE (\n            VALUES ( DimDate[MonthStart] ),\n            ALLSELECTED ( DimDate ),\n            REMOVEFILTERS ( DimDate[IsLatestCompleteMonth] )\n        ),\n        DimDate[MonthStart]\n    )\nRETURN\n    CALCULATE ( [GRR], FILTER ( ALL ( DimDate ), DimDate[MonthStart] = LatestMonth ) )",
            "formatString": "0.0%",
            "lineageTag": "52822606-459e-4191-a2e3-814f30a30ca3"
          },
          {
            "name": "Latest Expansion ARR",
            "expression": "VAR LatestMonth =\n    MAXX (\n        CALCULATETABLE (\n            VALUES ( DimDate[MonthStart] ),\n            ALLSELECTED ( DimDate ),\n            REMOVEFILTERS ( DimDate[IsLatestCompleteMonth] )\n        ),\n        DimDate[MonthStart]\n    )\nRETURN\n    CALCULATE ( [Expansion ARR], FILTER ( ALL ( DimDate ), DimDate[MonthStart] = LatestMonth ) )",
            "formatString": "$#,0,,.0M",
            "lineageTag": "16141bde-d6d1-4a9f-96c3-e211b61c2e95"
          },
          {
            "name": "Latest Churn ARR",
            "expression": "VAR LatestMonth =\n    MAXX (\n        CALCULATETABLE (\n            VALUES ( DimDate[MonthStart] ),\n            ALLSELECTED ( DimDate ),\n            REMOVEFILTERS ( DimDate[IsLatestCompleteMonth] )\n        ),\n        DimDate[MonthStart]\n    )\nRETURN\n    CALCULATE ( [Churn ARR], FILTER ( ALL ( DimDate ), DimDate[MonthStart] = LatestMonth ) )",
            "formatString": "$#,0,,.0M",
            "lineageTag": "43f7cb68-b804-4b45-a083-9504e946ed70"
          },
          {
            "name": "Latest Logo Churn Rate",
            "expression": "VAR LatestMonth =\n    MAXX (\n        CALCULATETABLE (\n            VALUES ( DimDate[MonthStart] ),\n            ALLSELECTED ( DimDate ),\n            REMOVEFILTERS ( DimDate[IsLatestCompleteMonth] )\n        ),\n        DimDate[MonthStart]\n    )\nRETURN\n    CALCULATE ( [Logo Churn Rate], FILTER ( ALL ( DimDate ), DimDate[MonthStart] = LatestMonth ) )",
            "formatString": "0.0%",
            "lineageTag": "9f023d18-3b9d-4554-b399-a4bd9213bdb1"
          },
          {
            "name": "Latest CAC Payback",
            "expression": "VAR LatestMonth =\n    MAXX (\n        CALCULATETABLE (\n            VALUES ( DimDate[MonthStart] ),\n            ALLSELECTED ( DimDate ),\n            REMOVEFILTERS ( DimDate[IsLatestCompleteMonth] )\n        ),\n        DimDate[MonthStart]\n    )\nRETURN\n    CALCULATE ( [CAC Payback Months], FILTER ( ALL ( DimDate ), DimDate[MonthStart] = LatestMonth ) )",
            "formatString": "0.0",
            "lineageTag": "1fa9b2a1-faa8-4508-bd25-bf4229212cd1"
          },
          {
            "name": "Latest LTV CAC Ratio",
            "expression": "VAR LatestMonth =\n    MAXX (\n        CALCULATETABLE (\n            VALUES ( DimDate[MonthStart] ),\n            ALLSELECTED ( DimDate ),\n            REMOVEFILTERS ( DimDate[IsLatestCompleteMonth] )\n        ),\n        DimDate[MonthStart]\n    )\nRETURN\n    CALCULATE ( [LTV CAC Ratio], FILTER ( ALL ( DimDate ), DimDate[MonthStart] = LatestMonth ) )",
            "formatString": "0.0x",
            "lineageTag": "19c59505-0e27-4ff1-9537-c2b6a2225d77"
          },
          {
            "name": "Latest Rule of 40",
            "expression": "VAR LatestMonth =\n    MAXX (\n        CALCULATETABLE (\n            VALUES ( DimDate[MonthStart] ),\n            ALLSELECTED ( DimDate ),\n            REMOVEFILTERS ( DimDate[IsLatestCompleteMonth] )\n        ),\n        DimDate[MonthStart]\n    )\nRETURN\n    CALCULATE ( [Rule of 40], FILTER ( ALL ( DimDate ), DimDate[MonthStart] = LatestMonth ) )",
            "formatString": "0.0%",
            "lineageTag": "43be4c4a-75d4-4d66-ae4f-79e76c2c4190"
          },
          {
            "name": "Latest Burn Multiple",
            "expression": "VAR LatestMonth =\n    MAXX (\n        CALCULATETABLE (\n            VALUES ( DimDate[MonthStart] ),\n            ALLSELECTED ( DimDate ),\n            REMOVEFILTERS ( DimDate[IsLatestCompleteMonth] )\n        ),\n        DimDate[MonthStart]\n    )\nRETURN\n    CALCULATE ( [Burn Multiple], FILTER ( ALL ( DimDate ), DimDate[MonthStart] = LatestMonth ) )",
            "formatString": "0.0x",
            "lineageTag": "786f67e7-ebd3-49b0-a095-38b7873ba5dc"
          },
          {
            "name": "Latest Forecast Accuracy",
            "expression": "VAR LatestMonth =\n    MAXX (\n        CALCULATETABLE (\n            VALUES ( DimDate[MonthStart] ),\n            ALLSELECTED ( DimDate ),\n            REMOVEFILTERS ( DimDate[IsLatestCompleteMonth] )\n        ),\n        DimDate[MonthStart]\n    )\nRETURN\n    CALCULATE ( [Forecast Accuracy], FILTER ( ALL ( DimDate ), DimDate[MonthStart] = LatestMonth ) )",
            "formatString": "0.0%",
            "lineageTag": "5751271c-d6c2-408b-a59e-b10f33107982"
          },
          {
            "name": "ARR YoY %",
            "expression": "DIVIDE ( [Latest ARR] - CALCULATE ( [ARR], DATEADD ( DimDate[MonthStart], -12, MONTH ) ), CALCULATE ( [ARR], DATEADD ( DimDate[MonthStart], -12, MONTH ) ) )",
            "formatString": "0.0%",
            "lineageTag": "42d30913-845b-4790-b07f-686ff30704a9"
          },
          {
            "name": "NRR YoY pp",
            "expression": "VAR LatestMonth =\n    MAXX (\n        CALCULATETABLE (\n            VALUES ( DimDate[MonthStart] ),\n            ALLSELECTED ( DimDate ),\n            REMOVEFILTERS ( DimDate[IsLatestCompleteMonth] )\n        ),\n        DimDate[MonthStart]\n    )\nVAR PriorMonth = EDATE ( LatestMonth, -12 )\nVAR CurrentValue = CALCULATE ( [NRR], FILTER ( ALL ( DimDate ), DimDate[MonthStart] = LatestMonth ) )\nVAR PriorValue = CALCULATE ( [NRR], FILTER ( ALL ( DimDate ), DimDate[MonthStart] = PriorMonth ) )\nRETURN\n    CurrentValue - PriorValue",
            "formatString": "0.0%",
            "lineageTag": "351a7971-9244-4450-b3d9-8d72989b2029"
          },
          {
            "name": "Forecast Accuracy YoY pp",
            "expression": "VAR LatestMonth =\n    MAXX (\n        CALCULATETABLE (\n            VALUES ( DimDate[MonthStart] ),\n            ALLSELECTED ( DimDate ),\n            REMOVEFILTERS ( DimDate[IsLatestCompleteMonth] )\n        ),\n        DimDate[MonthStart]\n    )\nVAR PriorMonth = EDATE ( LatestMonth, -12 )\nVAR CurrentValue = CALCULATE ( [Forecast Accuracy], FILTER ( ALL ( DimDate ), DimDate[MonthStart] = LatestMonth ) )\nVAR PriorValue = CALCULATE ( [Forecast Accuracy], FILTER ( ALL ( DimDate ), DimDate[MonthStart] = PriorMonth ) )\nRETURN\n    CurrentValue - PriorValue",
