          {
            "name": "Efficiency Decision Chips SVG",
            "expression": "VAR Chip1Text = \"Payback: \" & FORMAT ( [Latest CAC Payback], \"0.0\" )\nVAR Chip2Text = \"Burn: \" & FORMAT ( [Latest Burn Multiple], \"0.0x\" )\nVAR Chip3Text = \"Forecast: \" & FORMAT ( [Latest Forecast Accuracy], \"0.0%\" )\nVAR SVG =\n    \"<svg xmlns='http://www.w3.org/2000/svg' width='490' height='38' viewBox='0 0 490 38'>\"\n        & \"<rect x='0' y='0' width='490' height='38' rx='8' fill='none'/>\"\n        & \"<rect x='0.5' y='2.5' width='142' height='33' rx='7' fill='%23FFF3D6' stroke='%23FFFFFF' stroke-width='0.9'/>\"\n        & \"<rect x='13' y='13' width='11' height='11' rx='3' fill='%23F59E0B'/>\"\n        & \"<text x='36' y='23.5' font-family='Segoe UI Semibold' font-size='12.5' fill='%23261C3C'>\" & Chip1Text & \"</text>\"\n        & \"<rect x='156.5' y='2.5' width='150' height='33' rx='7' fill='%23FCE7E7' stroke='%23FFFFFF' stroke-width='0.9'/>\"\n        & \"<rect x='169' y='13' width='11' height='11' rx='3' fill='%23DC2626'/>\"\n        & \"<text x='192' y='23.5' font-family='Segoe UI Semibold' font-size='12.5' fill='%23261C3C'>\" & Chip2Text & \"</text>\"\n        & \"<rect x='320.5' y='2.5' width='168' height='33' rx='7' fill='%23E7F0FF' stroke='%23FFFFFF' stroke-width='0.9'/>\"\n        & \"<rect x='333' y='13' width='11' height='11' rx='3' fill='%232563EB'/>\"\n        & \"<text x='356' y='23.5' font-family='Segoe UI Semibold' font-size='12.5' fill='%23261C3C'>\" & Chip3Text & \"</text>\"\n        & \"</svg>\"\nRETURN\n    \"data:image/svg+xml;utf8,\" & SVG",
