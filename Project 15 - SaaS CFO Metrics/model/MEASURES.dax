Latest Forecast Accuracy = VAR LatestMonth =
    MAXX (
        CALCULATETABLE (
            VALUES ( DimDate[MonthStart] ),
            ALLSELECTED ( DimDate ),
            REMOVEFILTERS ( DimDate[IsLatestCompleteMonth] )
        ),
