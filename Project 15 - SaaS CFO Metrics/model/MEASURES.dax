Latest Rule of 40 = VAR LatestMonth =
    MAXX (
        CALCULATETABLE (
            VALUES ( DimDate[MonthStart] ),
            ALLSELECTED ( DimDate ),
            REMOVEFILTERS ( DimDate[IsLatestCompleteMonth] )
        ),
