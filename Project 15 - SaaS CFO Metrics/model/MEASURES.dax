Latest Logo Churn Rate = VAR LatestMonth =
    MAXX (
        CALCULATETABLE (
            VALUES ( DimDate[MonthStart] ),
            ALLSELECTED ( DimDate ),
            REMOVEFILTERS ( DimDate[IsLatestCompleteMonth] )
        ),
        DimDate[MonthStart]
    )
RETURN
