              "        & \"<text x='16' y='82' font-family='Segoe UI' font-size='27' font-weight='750' fill='%232A9D8F'>\" & ValueText & \"</text>\"",
              "        & \"<rect x='128' y='36' width='112' height='60' rx='9' fill='%23F7FBFC' stroke='%23E5EFF2' stroke-width='1'/>\"",
