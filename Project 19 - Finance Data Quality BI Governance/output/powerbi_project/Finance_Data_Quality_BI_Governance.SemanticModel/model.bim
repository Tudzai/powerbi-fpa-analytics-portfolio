      {
        "name": "KPI Measures",
        "columns": [
          {
            "name": "MeasureKey",
            "dataType": "string",
            "isHidden": true,
            "lineageTag": "bc80b561-7bd1-4b11-b3e3-724c52286f07",
            "sourceColumn": "MeasureKey"
          }
        ],
        "lineageTag": "b0998165-5005-4b5d-ba8d-a44f8dfbb160",
        "measures": [
          {
            "name": "Dataset Count",
            "displayFolder": "Overview",
            "expression": "DISTINCTCOUNT ( DimDataset[DatasetKey] )",
            "formatString": "#,0",
            "lineageTag": "aa4b5aeb-7d57-4d8f-9ce3-935f6718ddcc"
          },
          {
            "name": "Critical Dataset Count",
            "displayFolder": "Overview",
            "expression": "CALCULATE ( [Dataset Count], DimDataset[Criticality] = \"Tier 1\" )",
            "formatString": "#,0",
            "lineageTag": "59149879-2a3b-40df-9362-244ce96281cd"
          },
          {
            "name": "Certified Dataset Count",
            "displayFolder": "Overview",
            "expression": "CALCULATE ( [Dataset Count], DimDataset[Certified] = \"Y\" )",
            "formatString": "#,0",
            "lineageTag": "c154f50c-46ab-48e7-a952-09bcaae07f6b"
          },
          {
            "name": "Data Quality Score",
            "displayFolder": "Quality",
            "expression": "AVERAGE ( FactDatasetDaily[DataQualityScore] )",
            "formatString": "0.0",
            "lineageTag": "240f7718-a912-461f-a131-638293b4eaea"
          },
          {
            "name": "Completeness %",
            "displayFolder": "Quality",
            "expression": "DIVIDE ( SUM ( FactDatasetDaily[RowsLoaded] ), SUM ( FactDatasetDaily[RowsExpected] ) )",
            "formatString": "0.0%",
            "lineageTag": "584d0ff3-6896-4d16-a132-0997078257c2"
          },
          {
            "name": "Freshness SLA %",
            "displayFolder": "Reliability",
            "expression": "DIVIDE ( SUM ( FactDatasetDaily[FreshnessWithinSLAFlag] ), COUNTROWS ( FactDatasetDaily ) )",
            "formatString": "0.0%",
            "lineageTag": "36615f7c-a4de-4108-b34e-33133bcd8116"
          },
          {
            "name": "Refresh Runs",
            "displayFolder": "Reliability",
            "expression": "COUNTROWS ( FactRefreshRuns )",
            "formatString": "#,0",
            "lineageTag": "1eb388f9-3531-46f7-8ab5-388088a77aa4"
          },
          {
            "name": "Refresh Success %",
            "displayFolder": "Reliability",
            "expression": "DIVIDE ( CALCULATE ( [Refresh Runs], FactRefreshRuns[Status] = \"Success\" ), [Refresh Runs] )",
            "formatString": "0.0%",
            "lineageTag": "cf78b057-3da6-47d5-bd3f-8029b3fc3d15"
          },
          {
            "name": "Failed Refreshes",
            "displayFolder": "Reliability",
            "expression": "CALCULATE ( [Refresh Runs], FactRefreshRuns[Status] = \"Failed\" )",
            "formatString": "#,0",
            "lineageTag": "f17a410f-cecb-4136-af72-0d04ac6b6768"
          },
          {
            "name": "Avg Refresh Duration Min",
            "displayFolder": "Reliability",
            "expression": "AVERAGE ( FactRefreshRuns[DurationMinutes] )",
            "formatString": "0.0",
            "lineageTag": "8f7117f2-1b5d-451c-9aa6-799f210a8a6d"
          },
          {
            "name": "DQ Issue Count",
            "displayFolder": "Quality",
            "expression": "SUM ( FactDatasetDaily[NullCriticalCount] ) + SUM ( FactDatasetDaily[DuplicateKeyCount] ) + SUM ( FactDatasetDaily[SchemaDriftCount] )",
            "formatString": "#,0",
            "lineageTag": "7f5300d6-bb35-4830-bdef-2c128e5c0891"
          },
          {
            "name": "Open Incidents",
            "displayFolder": "Reliability",
            "expression": [
              "VAR AsOfMonth = MAXX ( ALLSELECTED ( DimDate ), DimDate[MonthIndex] )",
              "RETURN",
              "    CALCULATE (",
              "        COUNTROWS ( FactIncidents ),",
              "        REMOVEFILTERS ( DimDate ),",
              "        KEEPFILTERS (",
              "            FILTER (",
              "                FactIncidents,",
              "                FactIncidents[OpenMonthIndex] <= AsOfMonth",
              "                    && ( FactIncidents[CloseMonthIndex] = 0 || FactIncidents[CloseMonthIndex] > AsOfMonth )",
              "            )",
              "        )",
              "    )"
            ],
            "formatString": "#,0",
            "lineageTag": "713a6a88-5497-425e-87d4-efb21b8e039a"
          },
          {
            "name": "Avg MTTR Hours",
            "displayFolder": "Reliability",
            "expression": "AVERAGE ( FactIncidents[MTTRHours] )",
            "formatString": "0.0",
            "lineageTag": "ca9f009f-1c08-4077-8486-798a5ad4c913"
          },
          {
            "name": "Reconciliation Variance",
            "displayFolder": "Reconciliation",
            "expression": "SUM ( FactReconciliation[VarianceAmount] )",
            "formatString": "$#,0",
            "lineageTag": "a3287247-d166-4cc3-9a2b-1e9e1517f5e5"
          },
          {
            "name": "Abs Reconciliation Variance",
            "displayFolder": "Reconciliation",
            "expression": "SUMX ( FactReconciliation, ABS ( FactReconciliation[VarianceAmount] ) )",
            "formatString": "$#,0",
            "lineageTag": "81e3cc56-d924-4e09-9685-ba4d51e9d5a2"
          },
          {
            "name": "Reconciliation Pass %",
            "displayFolder": "Reconciliation",
            "expression": "DIVIDE ( CALCULATE ( COUNTROWS ( FactReconciliation ), FactReconciliation[ReconciliationStatus] = \"Pass\" ), COUNTROWS ( FactReconciliation ) )",
            "formatString": "0.0%",
            "lineageTag": "162adce8-fd58-4512-a917-c8c52abb2726"
          },
          {
            "name": "Report Views",
            "displayFolder": "Adoption",
            "expression": "SUM ( FactUsage[Views] )",
            "formatString": "#,0",
            "lineageTag": "4301ebd5-379e-40c1-9ae0-cc5ff8bf827a"
          },
          {
            "name": "Active Viewer Days",
            "displayFolder": "Adoption",
            "expression": "SUM ( FactUsage[UniqueViewers] )",
            "formatString": "#,0",
            "lineageTag": "21a5e5f2-bd81-4f98-ac77-5dd4cc77ffe2"
          },
          {
            "name": "Export Events",
            "displayFolder": "Adoption",
            "expression": "SUM ( FactUsage[ExportEvents] )",
            "formatString": "#,0",
            "lineageTag": "7ea5e34d-2d36-4b67-9713-df639dafb5ab"
          },
          {
            "name": "Avg Report Load Seconds",
            "displayFolder": "Adoption",
            "expression": "AVERAGE ( FactUsage[AvgLoadSeconds] )",
            "formatString": "0.0",
            "lineageTag": "85cd40b0-fb9a-4cbc-9f6d-bb59ce317b5a"
          },
          {
            "name": "Failed Visual Count",
            "displayFolder": "Adoption",
            "expression": "SUM ( FactUsage[FailedVisualCount] )",
            "formatString": "#,0",
            "lineageTag": "97bc0d16-9780-46a9-bba4-8f66eafd03ab"
          },
          {
            "name": "Access Risk Events",
            "displayFolder": "Controls",
            "expression": "SUM ( FactAccessReview[RLSExceptions] ) + SUM ( FactAccessReview[OrphanedUsers] ) + SUM ( FactAccessReview[UnauthorizedSharingEvents] )",
            "formatString": "#,0",
            "lineageTag": "d967c10b-d341-43da-bcd0-c1efa302bc35"
          },
          {
            "name": "RLS Exceptions",
            "displayFolder": "Controls",
            "expression": "SUM ( FactAccessReview[RLSExceptions] )",
            "formatString": "#,0",
            "lineageTag": "71cd2ce3-0815-4c12-9792-be34f63228f1"
          },
          {
            "name": "Pending Access Reviews",
            "displayFolder": "Controls",
            "expression": "SUM ( FactAccessReview[PendingAccessReviews] )",
            "formatString": "#,0",
            "lineageTag": "29f90cec-e09d-4b09-8d83-00a3a151926f"
          },
          {
            "name": "Deployment Control Score",
            "displayFolder": "Controls",
            "expression": "AVERAGE ( FactAccessReview[DeploymentControlScore] )",
            "formatString": "0.0",
            "lineageTag": "14262402-f9ee-4eef-90e0-33a7b9c252a0"
          },
          {
            "name": "Current Lens Label",
            "displayFolder": "Executive Lens",
            "expression": [
              "VAR MonthLens = SELECTEDVALUE ( DimDate[MonthYear], \"All Months\" )",
              "VAR DomainLens = SELECTEDVALUE ( DimDataset[Domain], \"All Domains\" )",
              "VAR CriticalityLens = SELECTEDVALUE ( DimDataset[Criticality], \"All Tiers\" )",
              "RETURN \"Lens: \" & MonthLens & \" | \" & DomainLens & \" | \" & CriticalityLens"
            ],
            "lineageTag": "35618693-4397-434c-94cb-2d74479c3c01"
          },
          {
            "name": "Usage Lens Label",
            "displayFolder": "Executive Lens",
            "expression": [
              "VAR WorkspaceLens = SELECTEDVALUE ( DimReport[Workspace], \"All Workspaces\" )",
              "VAR SensitivityLens = SELECTEDVALUE ( DimReport[SensitivityLabel], \"All Sensitivity\" )",
              "RETURN \"Lens: \" & WorkspaceLens & \" | \" & SensitivityLens"
            ],
            "lineageTag": "9c897340-215a-4932-acb6-7d6d5ced80bf"
          },
          {
            "name": "Action Lens Label",
            "displayFolder": "Executive Lens",
            "expression": [
              "VAR MonthLens = SELECTEDVALUE ( DimDate[MonthYear], \"All Months\" )",
              "VAR DepartmentLens = SELECTEDVALUE ( DimDepartment[Department], \"All Departments\" )",
              "RETURN \"Lens: \" & MonthLens & \" | \" & DepartmentLens"
            ],
            "lineageTag": "46b825f7-2b89-44fb-bfc5-5798d48a631b"
          },
          {
            "name": "Governance Decision Chip",
            "displayFolder": "Executive Lens",
            "expression": [
              "VAR Dq = [Data Quality Score]",
              "VAR Fresh = [Freshness SLA %]",
              "VAR OpenIncidents = [Open Incidents]",
              "RETURN IF ( Dq >= 92 && Fresh >= 0.95 && OpenIncidents <= 30, \"PASS: trust posture on track\", IF ( OpenIncidents > 45, \"ESCALATE: incident load above guardrail\", \"WATCH: owner review required\" ) )"
            ],
            "lineageTag": "4153b43f-9cd6-4368-9ac0-f2e2767bf3b9"
          },
          {
            "name": "Reliability Decision Chip",
            "displayFolder": "Executive Lens",
            "expression": [
              "VAR Failed = [Failed Refreshes]",
              "VAR Complete = [Completeness %]",
              "VAR RecPass = [Reconciliation Pass %]",
              "RETURN IF ( Failed <= 25 && Complete >= 0.99 && RecPass >= 0.90, \"PASS: close-ready reliability\", IF ( Failed > 40 || Complete < 0.985, \"ESCALATE: reliability SLA at risk\", \"WATCH: validate exception queue\" ) )"
            ],
            "lineageTag": "08b8b2c9-41d9-4243-9ce0-bb11ce7a2505"
          },
          {
            "name": "Adoption Decision Chip",
            "displayFolder": "Executive Lens",
            "expression": [
              "VAR LoadSec = [Avg Report Load Seconds]",
              "VAR AccessRisk = [Access Risk Events]",
              "VAR ControlScore = [Deployment Control Score]",
              "RETURN IF ( LoadSec <= 3.0 && AccessRisk <= 800 && ControlScore >= 92, \"PASS: governed adoption healthy\", IF ( AccessRisk > 950, \"ESCALATE: access risk concentration\", \"WATCH: control follow-up needed\" ) )"
            ],
            "lineageTag": "51b26efd-c1c9-4ef6-80e8-de68ecbdce26"
          },
          {
            "name": "Risk Action Decision Chip",
            "displayFolder": "Executive Lens",
            "expression": [
              "VAR OpenIncidents = [Open Incidents]",
              "VAR AccessRisk = [Access Risk Events]",
              "VAR Pending = [Pending Access Reviews]",
              "RETURN IF ( OpenIncidents <= 30 && AccessRisk <= 800 && Pending <= 900, \"PASS: action load inside guardrail\", IF ( OpenIncidents > 45 || Pending > 1100, \"ESCALATE: prioritize owner actions\", \"WATCH: triage aging queues\" ) )"
            ],
            "lineageTag": "897fc21d-f479-47ff-a79a-cf5b9649aa2c"
          },
          {
            "name": "Data Quality Score Sparkline SVG",
            "dataCategory": "ImageUrl",
            "displayFolder": "Sparkline SVG",
            "expression": [
              "VAR LatestIndex = MAXX ( ALLSELECTED ( DimDate ), DimDate[MonthIndex] )",
              "VAR MonthTable =",
              "    ADDCOLUMNS (",
              "        FILTER (",
              "            ALL ( DimDate ),",
              "            DimDate[MonthIndex] <= LatestIndex",
              "                && DimDate[MonthIndex] > LatestIndex - 12",
              "        ),",
              "        \"__Value\", CALCULATE ( [Data Quality Score] )",
              "    )",
              "VAR CleanTable = FILTER ( MonthTable, NOT ISBLANK ( [__Value] ) )",
              "VAR RowCount = COUNTROWS ( CleanTable )",
              "VAR MinValue = MINX ( CleanTable, [__Value] )",
              "VAR MaxValue = MAXX ( CleanTable, [__Value] )",
              "VAR FirstValue = MINX ( TOPN ( 1, CleanTable, DimDate[MonthIndex], ASC ), [__Value] )",
              "VAR LastValue = MINX ( TOPN ( 1, CleanTable, DimDate[MonthIndex], DESC ), [__Value] )",
              "VAR StartYValue = 38 - DIVIDE ( FirstValue - MinValue, MaxValue - MinValue, 0.5 ) * 30",
              "VAR EndYValue = 38 - DIVIDE ( LastValue - MinValue, MaxValue - MinValue, 0.5 ) * 30",
              "VAR TrendColor = IF ( LastValue >= FirstValue, \"%231B4D89\", \"%23C94A4A\" )",
              "VAR Points =",
              "    CONCATENATEX (",
              "        CleanTable,",
              "        VAR RankValue = RANKX ( CleanTable, DimDate[MonthIndex],, ASC, DENSE ) - 1",
              "        VAR XValue = 8 + DIVIDE ( RankValue, MAX ( 1, RowCount - 1 ), 0 ) * 184",
              "        VAR YValue = 38 - DIVIDE ( [__Value] - MinValue, MaxValue - MinValue, 0.5 ) * 30",
              "        RETURN FORMAT ( XValue, \"0.0\" ) & \",\" & FORMAT ( YValue, \"0.0\" ),",
              "        \" \",",
              "        DimDate[MonthIndex],",
              "        ASC",
              "    )",
              "RETURN",
              "    IF (",
              "        RowCount < 2,",
              "        BLANK (),",
              "        \"data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='44' viewBox='0 0 200 44'><rect x='0' y='0' width='200' height='44' rx='7' fill='%23F4FAFB'/><line x1='8' y1='25' x2='192' y2='25' stroke='%23D3E0E3' stroke-width='1' stroke-dasharray='4 5'/><polyline points='\"",
              "            & Points",
              "            & \"' fill='none' stroke='\"",
              "            & TrendColor",
              "            & \"' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'/><circle cx='8' cy='\"",
              "            & FORMAT ( StartYValue, \"0.0\" )",
              "            & \"' r='3' fill='%23FFFFFF' stroke='%237D9197' stroke-width='1.4'/><circle cx='192' cy='\"",
              "            & FORMAT ( EndYValue, \"0.0\" )",
              "            & \"' r='4' fill='\"",
              "            & TrendColor",
              "            & \"' stroke='%23FFFFFF' stroke-width='1.4'/></svg>\"",
              "    )"
            ],
            "lineageTag": "16360e05-ccf1-48e2-bb65-97fe2be400c3"
          },
