              "    )",
              "VAR SelectedAxisMonths =",
              "    SELECTCOLUMNS (",
              "        SelectedMonths,",
              "        \"AxisMonthIndex\", DimDate[MonthIndex]",
              "    )",
              "VAR TrailingAxisMonths =",
              "    SELECTCOLUMNS (",
              "        GENERATESERIES ( LatestIndex - 11, LatestIndex, 1 ),",
              "        \"AxisMonthIndex\", [Value]",
              "    )",
              "VAR AxisMonths =",
              "    DISTINCT (",
