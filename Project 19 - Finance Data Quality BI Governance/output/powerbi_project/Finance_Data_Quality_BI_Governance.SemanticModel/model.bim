              "        & \"<rect x='124' y='108' width='112' height='42' rx='8' fill='%23F4FAFB' stroke='%23DDE8EB' stroke-width='1'/>\"",
              "        & \"<text x='25' y='125' font-family='Segoe UI' font-size='11.8' font-weight='800' fill='%2317324A'>PY</text>\"",
