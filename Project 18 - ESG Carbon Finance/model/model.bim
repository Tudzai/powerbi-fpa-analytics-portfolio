                "    PromotedHeaders = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),",
                "    ChangedType = Table.TransformColumnTypes(PromotedHeaders, {{\"initiative_id\", type text}, {\"initiative\", type text}, {\"scope\", type text}, {\"business_unit\", type text}, {\"implementation_status\", type text}, {\"start_year\", Int64.Type}, {\"capex_usd\", type number}, {\"annual_reduction_tco2e\", type number}, {\"annual_opex_savings_usd\", type number}, {\"avoided_carbon_cost_usd_at_90\", type number}, {\"net_annual_benefit_usd_at_90\", type number}, {\"payback_years_at_90\", type number}, {\"roi_at_90\", type number}, {\"macc_usd_per_tco2e\", type number}}, \"en-US\")",
