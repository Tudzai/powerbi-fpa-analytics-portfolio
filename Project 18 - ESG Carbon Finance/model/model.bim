      {
        "name": "KPI_Measures",
        "lineageTag": "576ae6a0-37fd-48ef-9132-3936ab1a63e3",
        "columns": [
          {
            "name": "MeasureName",
            "dataType": "string",
            "sourceColumn": "MeasureName",
            "isHidden": true
          }
        ],
        "partitions": [
          {
            "name": "p_KPI_Measures",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": "let Source = #table(type table [MeasureName = text], {{\"KPI\"}}) in Source"
            }
          }
        ],
        "measures": [
          {
            "name": "Total Emissions tCO2e",
            "expression": "SUM ( fact_emissions[emissions_tco2e] )",
            "formatString": "#,0.0",
            "lineageTag": "f84176c5-f795-4f2b-86ad-6d7a3efed932"
          },
          {
            "name": "Scope 1 Emissions tCO2e",
            "expression": "CALCULATE ( [Total Emissions tCO2e], fact_emissions[scope] = \"Scope 1\" )",
            "formatString": "#,0.0",
            "lineageTag": "50d088eb-fa6d-4b6a-981d-87b18de0c5d5"
          },
          {
            "name": "Scope 2 Emissions tCO2e",
            "expression": "CALCULATE ( [Total Emissions tCO2e], fact_emissions[scope] = \"Scope 2\" )",
            "formatString": "#,0.0",
            "lineageTag": "1c97655e-244e-455f-bc48-a98dbe3c190a"
          },
          {
            "name": "Scope 3 Emissions tCO2e",
            "expression": "CALCULATE ( [Total Emissions tCO2e], fact_emissions[scope] = \"Scope 3\" )",
            "formatString": "#,0.0",
            "lineageTag": "70accc8c-eefc-4d2b-9d23-b352324689de"
          },
          {
            "name": "Total Spend USD",
            "expression": "SUM ( fact_emissions[spend_usd] )",
            "formatString": "$#,0",
            "lineageTag": "e09292f3-85fd-4ffd-9bda-cc4bc6b629ce"
          },
          {
            "name": "Revenue USD",
            "expression": "SUM ( fact_emissions[revenue_usd] )",
            "formatString": "$#,0",
            "lineageTag": "5508ca8b-6067-451c-a29c-d7e1e9ad7385"
          },
          {
            "name": "Emissions Intensity tCO2e per $M Revenue",
            "expression": "DIVIDE ( [Total Emissions tCO2e], [Revenue USD] ) * 1000000",
            "formatString": "#,0.0",
            "lineageTag": "c8544dbb-0fae-4df5-96e8-f17d81604538"
          },
          {
            "name": "Selected Carbon Price USD/t",
            "expression": "SELECTEDVALUE ( dim_carbon_scenario[carbon_price_usd_per_t], 50 )",
            "formatString": "$#,0",
            "lineageTag": "a59470cf-57e4-416d-acfa-0ca75cbc1f55"
          },
          {
            "name": "Carbon Cost USD",
            "expression": "[Total Emissions tCO2e] * [Selected Carbon Price USD/t]",
            "formatString": "$#,0",
            "lineageTag": "8a497053-7fda-498f-9ca9-5f05fa6ed0d0"
          },
          {
            "name": "Scenario Carbon Cost USD",
            "expression": "SUM ( fact_carbon_exposure[carbon_cost_usd] )",
            "formatString": "$#,0",
            "lineageTag": "8fdc400b-3a06-4cae-8e04-84d89ec760cc"
          },
          {
            "name": "Supplier Emissions tCO2e",
            "expression": "SUM ( fact_supplier_month[emissions_tco2e] )",
            "formatString": "#,0.0",
            "lineageTag": "b6c27f59-65ab-427d-bf42-2e7259d23968"
          },
          {
            "name": "Supplier Spend USD",
            "expression": "SUM ( fact_supplier_month[spend_usd] )",
            "formatString": "$#,0",
            "lineageTag": "6fb4f629-0498-4844-8f78-4b893175c0c3"
          },
          {
            "name": "Supplier Intensity tCO2e per $M Spend",
            "expression": "DIVIDE ( [Supplier Emissions tCO2e], [Supplier Spend USD] ) * 1000000",
            "formatString": "#,0.0",
            "lineageTag": "0181ec70-f43b-4269-9163-7fce2b80c16d"
          },
          {
            "name": "Average Data Quality Score",
            "expression": "AVERAGE ( fact_supplier_month[data_quality_score] )",
            "formatString": "0.0%",
            "lineageTag": "6d707451-e5eb-41d3-9f8f-59075ebf5b02"
          },
          {
            "name": "Abatement Annual Reduction tCO2e",
            "expression": "SUM ( fact_abatement_initiatives[annual_reduction_tco2e] )",
            "formatString": "#,0",
            "lineageTag": "7f942077-f3b3-4a53-92ee-5681276d516f"
          },
          {
            "name": "Abatement Capex USD",
            "expression": "SUM ( fact_abatement_initiatives[capex_usd] )",
            "formatString": "$#,0",
            "lineageTag": "5d55996e-6dbd-42b7-9cc3-706c3aff09b3"
          },
          {
            "name": "Avoided Carbon Cost USD at Selected Price",
            "expression": "[Abatement Annual Reduction tCO2e] * [Selected Carbon Price USD/t]",
            "formatString": "$#,0",
            "lineageTag": "b8f6fb31-0623-41ce-a37f-8af664832a40"
          },
          {
            "name": "Abatement Annual Benefit USD",
            "expression": "SUM ( fact_abatement_initiatives[annual_opex_savings_usd] ) + [Avoided Carbon Cost USD at Selected Price]",
            "formatString": "$#,0",
            "lineageTag": "8cb7cc79-995e-4c87-9b73-73a18cc93759"
          },
          {
            "name": "Abatement ROI",
            "expression": "DIVIDE ( [Abatement Annual Benefit USD], [Abatement Capex USD] )",
            "formatString": "0.0%",
            "lineageTag": "5cbae872-e07e-475a-961e-918470260e9e"
          },
          {
            "name": "Payback Years",
            "expression": "DIVIDE ( [Abatement Capex USD], [Abatement Annual Benefit USD] )",
            "formatString": "0.0",
            "lineageTag": "9913d5b5-5c1e-4843-a2d7-768361a04971"
          },
          {
            "name": "MACC USD per tCO2e",
            "expression": "DIVIDE ( DIVIDE ( [Abatement Capex USD], 7 ) - SUM ( fact_abatement_initiatives[annual_opex_savings_usd] ), [Abatement Annual Reduction tCO2e] )",
            "formatString": "$#,0.0",
            "lineageTag": "a57f2987-04c3-4900-8c7b-0a76e959b1ee"
          },
          {
            "name": "Latest Month Emissions tCO2e",
            "expression": "VAR LatestMonth = MAX ( dim_date[date_key] ) RETURN CALCULATE ( [Total Emissions tCO2e], dim_date[date_key] = LatestMonth )",
            "formatString": "#,0.0",
            "lineageTag": "b519e254-b9a9-4b76-8701-de48b3e2cdd7"
          },
          {
            "name": "YoY Emissions Change %",
            "expression": "VAR CurrentEmissions = [Total Emissions tCO2e] VAR PriorEmissions = CALCULATE ( [Total Emissions tCO2e], DATEADD ( dim_date[month_start], -1, YEAR ) ) RETURN DIVIDE ( CurrentEmissions - PriorEmissions, PriorEmissions )",
            "formatString": "0.0%",
            "lineageTag": "255134b3-2424-4294-a2af-83f9a7a5f49b"
          }
        ]
      }
    ],
