{
  "name": "FP&A Orange Executive",
  "dataColors": [
    "#F97316",
    "#2A9D8F",
    "#2563EB",
    "#E9C46A",
    "#8B5CF6",
    "#111827",
    "#D62828",
    "#64748B"
  ],
  "background": "#F8FAFC",
  "foreground": "#111827",
  "tableAccent": "#F97316",
  "good": "#2A9D8F",
  "neutral": "#64748B",
  "bad": "#D62828",
  "maximum": "#F97316",
  "center": "#E5E7EB",
  "minimum": "#2563EB",
  "visualStyles": {
    "*": {
      "*": {
        "title": [
          {
            "fontColor": {
              "solid": {
                "color": "#111827"
              }
            },
            "fontSize": 11,
            "fontFamily": "Segoe UI Semibold",
            "alignment": "left"
          }
        ],
        "background": [
          {
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#E5E7EB"
              }
            },
            "radius": 6
          }
        ],
        "visualHeader": [
          {
            "show": false
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": {
              "solid": {
                "color": "#111827"
              }
            },
            "fontSize": 22,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "categoryLabels": [
          {
            "color": {
              "solid": {
                "color": "#64748B"
              }
            },
            "fontSize": 9
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "header": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#334155"
              }
            },
            "textSize": 9
          }
        ]
      }
    }
  },
  "textClasses": {
    "callout": {
      "fontSize": 28,
      "fontFace": "Segoe UI Semibold",
      "color": "#111827"
    },
    "title": {
      "fontSize": 13,
      "fontFace": "Segoe UI Semibold",
      "color": "#111827"
    },
    "header": {
      "fontSize": 11,
      "fontFace": "Segoe UI Semibold",
      "color": "#334155"
    },
    "label": {
      "fontSize": 9,
      "fontFace": "Segoe UI",
      "color": "#64748B"
    }
  }
}
