          {
            "name": "Intercompany Elimination KPI Card SVG",
            "expression": "VAR d = [Selected Latest Complete Date]\nVAR LatestIdx =\n    CALCULATE ( MAX ( DimDate[month_index] ), REMOVEFILTERS ( DimDate ), DimDate[date] = d )\nVAR CurrentValue =\n    CALCULATE ( [Intercompany Elimination], REMOVEFILTERS ( DimDate ), DimDate[date] = d )\nVAR PriorDate = EDATE ( d, -12 )\nVAR PriorValue =\n    CALCULATE ( [Intercompany Elimination], REMOVEFILTERS ( DimDate ), DimDate[date] = PriorDate )\nVAR BudgetValue = BLANK ()\nVAR ChangePct = DIVIDE ( CurrentValue - PriorValue, ABS ( PriorValue ) )\nVAR DeltaPoints = ( CurrentValue - PriorValue ) * 100\nVAR StatusBasis =\n    IF (\n        NOT ISBLANK ( BudgetValue ),\n        DIVIDE ( CurrentValue - BudgetValue, ABS ( BudgetValue ) ),\n        ChangePct\n    )\nVAR StatusColor =\n    IF ( StatusBasis <= -0.02, \"%236F8552\", IF ( StatusBasis <= 0.02, \"%23A8894B\", \"%23B85A72\" ) )\nVAR StatusText =\n    IF ( StatusBasis <= -0.02, \"ON TRACK\", IF ( StatusBasis <= 0.02, \"WATCH\", \"ACTION\" ) )\nVAR TrendColor =\n    IF ( CurrentValue <= PriorValue, \"%236F8552\", \"%23B85A72\" )\nVAR MonthTable =\n    ADDCOLUMNS (\n        FILTER (\n            ALL ( DimDate ),\n            DimDate[date] <= d\n                && DimDate[month_index] >= LatestIdx - 11\n        ),\n        \"__Value\", CALCULATE ( [Intercompany Elimination] )\n    )\nVAR CleanTable = FILTER ( MonthTable, NOT ISBLANK ( [__Value] ) )\nVAR RowCount = COUNTROWS ( CleanTable )\nVAR MinValue = MINX ( CleanTable, [__Value] )\nVAR MaxValue = MAXX ( CleanTable, [__Value] )\nVAR FirstValue = MINX ( TOPN ( 1, CleanTable, DimDate[date], ASC ), [__Value] )\nVAR LastValue = MAXX ( TOPN ( 1, CleanTable, DimDate[date], DESC ), [__Value] )\nVAR FirstY =\n    IF (\n        MaxValue = MinValue,\n        52,\n        74 - DIVIDE ( FirstValue - MinValue, MaxValue - MinValue, 0.5 ) * 38\n    )\nVAR LastY =\n    IF (\n        MaxValue = MinValue,\n        52,\n        74 - DIVIDE ( LastValue - MinValue, MaxValue - MinValue, 0.5 ) * 38\n    )\nVAR LinePoints =\n    CONCATENATEX (\n        CleanTable,\n        VAR RankValue = RANKX ( CleanTable, DimDate[date], , ASC, DENSE ) - 1\n        VAR XValue = 164 + DIVIDE ( RankValue, MAX ( 1, RowCount - 1 ), 0 ) * 100\n        VAR YRatio =\n            IF (\n                MaxValue = MinValue,\n                0.5,\n                DIVIDE ( [__Value] - MinValue, MaxValue - MinValue, 0.5 )\n            )\n        VAR YValue = 74 - YRatio * 38\n        RETURN FORMAT ( XValue, \"0.0\", \"en-US\" ) & \",\" & FORMAT ( YValue, \"0.0\", \"en-US\" ),\n        \" \",\n        DimDate[date],\n        ASC\n    )\nVAR ValueText = SUBSTITUTE ( SUBSTITUTE ( FORMAT ( DIVIDE ( CurrentValue, 1000000 ), \"$0.0M;($0.0M);$0.0M\" ), \"%\", \"%25\" ), \"&\", \"and\" )\nVAR PyText = SUBSTITUTE ( SUBSTITUTE ( FORMAT ( DIVIDE ( PriorValue, 1000000 ), \"$0.0M;($0.0M);$0.0M\" ), \"%\", \"%25\" ), \"&\", \"and\" )\nVAR DeltaText = SUBSTITUTE ( SUBSTITUTE ( FORMAT ( ChangePct, \"+0.0%;-0.0%;0.0%\" ), \"%\", \"%25\" ), \"&\", \"and\" )\nVAR Sparkline =\n    IF (\n        RowCount >= 2,\n        \"<polyline points='\" & LinePoints & \"' fill='none' stroke='\" & TrendColor & \"' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'/>\"\n            & \"<circle cx='164' cy='\" & FORMAT ( FirstY, \"0.0\", \"en-US\" ) & \"' r='3.2' fill='%23FFFFFF' stroke='%23526173' stroke-width='1.2'/>\"\n            & \"<circle cx='264' cy='\" & FORMAT ( LastY, \"0.0\", \"en-US\" ) & \"' r='4.2' fill='\" & TrendColor & \"'/>\",\n        \"<line x1='164' y1='56' x2='264' y2='56' stroke='%23E6ECF2' stroke-width='3' stroke-linecap='round'/>\"\n    )\nVAR SVG =\n    \"<svg xmlns='http://www.w3.org/2000/svg' width='292' height='104' viewBox='0 0 292 104'>\"\n    & \"<rect x='1' y='1' width='290' height='102' rx='7' fill='%23FFFFFF' stroke='%23D5DEE8'/>\"\n    & \"<rect x='1' y='1' width='290' height='4' rx='2' fill='%232B6F75'/>\"\n    & \"<text x='16' y='24' font-family='Segoe UI Semibold' font-size='10.5' fill='%23526173'>IC Elimination</text>\"\n    & \"<text x='16' y='54' font-family='Segoe UI Semibold' font-size='25' fill='%230F172A'>\" & ValueText & \"</text>\"\n    & \"<rect x='160' y='34' width='108' height='44' rx='8' fill='%23F8FAFC'/>\"\n    & \"<line x1='166' y1='56' x2='264' y2='56' stroke='%23E6ECF2' stroke-width='1' stroke-dasharray='3 5'/>\"\n    & Sparkline\n    & \"<rect x='16' y='72' width='76' height='18' rx='9' fill='%23F8FAFC' stroke='%23D5DEE8'/>\"\n    & \"<text x='26' y='85' font-family='Segoe UI' font-size='8.2' fill='%23526173'>PY \" & PyText & \"</text>\"\n    & \"<rect x='98' y='72' width='56' height='18' rx='9' fill='\" & StatusColor & \"' fill-opacity='0.14'/>\"\n    & \"<text x='108' y='85' font-family='Segoe UI Semibold' font-size='8.2' fill='\" & StatusColor & \"'>\" & DeltaText & \"</text>\"\n    & \"<text x='190' y='91' font-family='Segoe UI Semibold' font-size='8' fill='\" & StatusColor & \"'>\" & StatusText & \"</text>\"\n    & \"</svg>\"\nRETURN\n    \"data:image/svg+xml;utf8,\" & SVG",
            "formatString": "",
            "description": "SVG KPI card for intercompany elimination impact with lower-is-better status and sparkline.",
            "dataCategory": "ImageUrl"
          },
          {
            "name": "Close Exceptions KPI Card SVG",
            "expression": "VAR d = [Selected Latest Complete Date]\nVAR LatestIdx =\n    CALCULATE ( MAX ( DimDate[month_index] ), REMOVEFILTERS ( DimDate ), DimDate[date] = d )\nVAR CurrentValue =\n    CALCULATE ( [Open Exception Value], REMOVEFILTERS ( DimDate ), DimDate[date] = d )\nVAR PriorDate = EDATE ( d, -12 )\nVAR PriorValue =\n    CALCULATE ( [Open Exception Value], REMOVEFILTERS ( DimDate ), DimDate[date] = PriorDate )\nVAR BudgetValue = BLANK ()\nVAR ChangePct = DIVIDE ( CurrentValue - PriorValue, ABS ( PriorValue ) )\nVAR DeltaPoints = ( CurrentValue - PriorValue ) * 100\nVAR StatusBasis =\n    IF (\n        NOT ISBLANK ( BudgetValue ),\n        DIVIDE ( CurrentValue - BudgetValue, ABS ( BudgetValue ) ),\n        ChangePct\n    )\nVAR StatusColor =\n    IF ( StatusBasis <= -0.02, \"%236F8552\", IF ( StatusBasis <= 0.02, \"%23A8894B\", \"%23B85A72\" ) )\nVAR StatusText =\n    IF ( StatusBasis <= -0.02, \"ON TRACK\", IF ( StatusBasis <= 0.02, \"WATCH\", \"ACTION\" ) )\nVAR TrendColor =\n    IF ( CurrentValue <= PriorValue, \"%236F8552\", \"%23B85A72\" )\nVAR MonthTable =\n    ADDCOLUMNS (\n        FILTER (\n            ALL ( DimDate ),\n            DimDate[date] <= d\n                && DimDate[month_index] >= LatestIdx - 11\n        ),\n        \"__Value\", CALCULATE ( [Open Exception Value] )\n    )\nVAR CleanTable = FILTER ( MonthTable, NOT ISBLANK ( [__Value] ) )\nVAR RowCount = COUNTROWS ( CleanTable )\nVAR MinValue = MINX ( CleanTable, [__Value] )\nVAR MaxValue = MAXX ( CleanTable, [__Value] )\nVAR FirstValue = MINX ( TOPN ( 1, CleanTable, DimDate[date], ASC ), [__Value] )\nVAR LastValue = MAXX ( TOPN ( 1, CleanTable, DimDate[date], DESC ), [__Value] )\nVAR FirstY =\n    IF (\n        MaxValue = MinValue,\n        52,\n        74 - DIVIDE ( FirstValue - MinValue, MaxValue - MinValue, 0.5 ) * 38\n    )\nVAR LastY =\n    IF (\n        MaxValue = MinValue,\n        52,\n        74 - DIVIDE ( LastValue - MinValue, MaxValue - MinValue, 0.5 ) * 38\n    )\nVAR LinePoints =\n    CONCATENATEX (\n        CleanTable,\n        VAR RankValue = RANKX ( CleanTable, DimDate[date], , ASC, DENSE ) - 1\n        VAR XValue = 164 + DIVIDE ( RankValue, MAX ( 1, RowCount - 1 ), 0 ) * 100\n        VAR YRatio =\n            IF (\n                MaxValue = MinValue,\n                0.5,\n                DIVIDE ( [__Value] - MinValue, MaxValue - MinValue, 0.5 )\n            )\n        VAR YValue = 74 - YRatio * 38\n        RETURN FORMAT ( XValue, \"0.0\", \"en-US\" ) & \",\" & FORMAT ( YValue, \"0.0\", \"en-US\" ),\n        \" \",\n        DimDate[date],\n        ASC\n    )\nVAR ValueText = SUBSTITUTE ( SUBSTITUTE ( FORMAT ( DIVIDE ( CurrentValue, 1000000 ), \"$0.0M;($0.0M);$0.0M\" ), \"%\", \"%25\" ), \"&\", \"and\" )\nVAR PyText = SUBSTITUTE ( SUBSTITUTE ( FORMAT ( DIVIDE ( PriorValue, 1000000 ), \"$0.0M;($0.0M);$0.0M\" ), \"%\", \"%25\" ), \"&\", \"and\" )\nVAR DeltaText = SUBSTITUTE ( SUBSTITUTE ( FORMAT ( ChangePct, \"+0.0%;-0.0%;0.0%\" ), \"%\", \"%25\" ), \"&\", \"and\" )\nVAR Sparkline =\n    IF (\n        RowCount >= 2,\n        \"<polyline points='\" & LinePoints & \"' fill='none' stroke='\" & TrendColor & \"' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'/>\"\n            & \"<circle cx='164' cy='\" & FORMAT ( FirstY, \"0.0\", \"en-US\" ) & \"' r='3.2' fill='%23FFFFFF' stroke='%23526173' stroke-width='1.2'/>\"\n            & \"<circle cx='264' cy='\" & FORMAT ( LastY, \"0.0\", \"en-US\" ) & \"' r='4.2' fill='\" & TrendColor & \"'/>\",\n        \"<line x1='164' y1='56' x2='264' y2='56' stroke='%23E6ECF2' stroke-width='3' stroke-linecap='round'/>\"\n    )\nVAR SVG =\n    \"<svg xmlns='http://www.w3.org/2000/svg' width='292' height='104' viewBox='0 0 292 104'>\"\n    & \"<rect x='1' y='1' width='290' height='102' rx='7' fill='%23FFFFFF' stroke='%23D5DEE8'/>\"\n    & \"<rect x='1' y='1' width='290' height='4' rx='2' fill='%23B85A72'/>\"\n    & \"<text x='16' y='24' font-family='Segoe UI Semibold' font-size='10.5' fill='%23526173'>Close Risk</text>\"\n    & \"<text x='16' y='54' font-family='Segoe UI Semibold' font-size='25' fill='%230F172A'>\" & ValueText & \"</text>\"\n    & \"<rect x='160' y='34' width='108' height='44' rx='8' fill='%23F8FAFC'/>\"\n    & \"<line x1='166' y1='56' x2='264' y2='56' stroke='%23E6ECF2' stroke-width='1' stroke-dasharray='3 5'/>\"\n    & Sparkline\n    & \"<rect x='16' y='72' width='76' height='18' rx='9' fill='%23F8FAFC' stroke='%23D5DEE8'/>\"\n    & \"<text x='26' y='85' font-family='Segoe UI' font-size='8.2' fill='%23526173'>PY \" & PyText & \"</text>\"\n    & \"<rect x='98' y='72' width='56' height='18' rx='9' fill='\" & StatusColor & \"' fill-opacity='0.14'/>\"\n    & \"<text x='108' y='85' font-family='Segoe UI Semibold' font-size='8.2' fill='\" & StatusColor & \"'>\" & DeltaText & \"</text>\"\n    & \"<text x='190' y='91' font-family='Segoe UI Semibold' font-size='8' fill='\" & StatusColor & \"'>\" & StatusText & \"</text>\"\n    & \"</svg>\"\nRETURN\n    \"data:image/svg+xml;utf8,\" & SVG",
            "formatString": "",
            "description": "SVG KPI card for open exception exposure with lower-is-better status and sparkline.",
            "dataCategory": "ImageUrl"
          },
          {
            "name": "Forecast Accuracy KPI Card SVG",
            "expression": "VAR d = [Selected Latest Complete Date]\nVAR LatestIdx =\n    CALCULATE ( MAX ( DimDate[month_index] ), REMOVEFILTERS ( DimDate ), DimDate[date] = d )\nVAR CurrentValue =\n    CALCULATE ( [Forecast Accuracy %], REMOVEFILTERS ( DimDate ), DimDate[date] = d )\nVAR PriorDate = EDATE ( d, -12 )\nVAR PriorValue =\n    CALCULATE ( [Forecast Accuracy %], REMOVEFILTERS ( DimDate ), DimDate[date] = PriorDate )\nVAR BudgetValue = BLANK ()\nVAR ChangePct = DIVIDE ( CurrentValue - PriorValue, ABS ( PriorValue ) )\nVAR DeltaPoints = ( CurrentValue - PriorValue ) * 100\nVAR StatusBasis =\n    IF (\n        NOT ISBLANK ( BudgetValue ),\n        DIVIDE ( CurrentValue - BudgetValue, ABS ( BudgetValue ) ),\n        ChangePct\n    )\nVAR StatusColor =\n    IF ( StatusBasis >= 0.02, \"%236F8552\", IF ( StatusBasis >= -0.02, \"%23A8894B\", \"%23B85A72\" ) )\nVAR StatusText =\n    IF ( StatusBasis >= 0.02, \"ON TRACK\", IF ( StatusBasis >= -0.02, \"WATCH\", \"ACTION\" ) )\nVAR TrendColor =\n    IF ( CurrentValue >= PriorValue, \"%236F8552\", \"%23B85A72\" )\nVAR MonthTable =\n    ADDCOLUMNS (\n        FILTER (\n            ALL ( DimDate ),\n            DimDate[date] <= d\n                && DimDate[month_index] >= LatestIdx - 11\n        ),\n        \"__Value\", CALCULATE ( [Forecast Accuracy %] )\n    )\nVAR CleanTable = FILTER ( MonthTable, NOT ISBLANK ( [__Value] ) )\nVAR RowCount = COUNTROWS ( CleanTable )\nVAR MinValue = MINX ( CleanTable, [__Value] )\nVAR MaxValue = MAXX ( CleanTable, [__Value] )\nVAR FirstValue = MINX ( TOPN ( 1, CleanTable, DimDate[date], ASC ), [__Value] )\nVAR LastValue = MAXX ( TOPN ( 1, CleanTable, DimDate[date], DESC ), [__Value] )\nVAR FirstY =\n    IF (\n        MaxValue = MinValue,\n        52,\n        74 - DIVIDE ( FirstValue - MinValue, MaxValue - MinValue, 0.5 ) * 38\n    )\nVAR LastY =\n    IF (\n        MaxValue = MinValue,\n        52,\n        74 - DIVIDE ( LastValue - MinValue, MaxValue - MinValue, 0.5 ) * 38\n    )\nVAR LinePoints =\n    CONCATENATEX (\n        CleanTable,\n        VAR RankValue = RANKX ( CleanTable, DimDate[date], , ASC, DENSE ) - 1\n        VAR XValue = 164 + DIVIDE ( RankValue, MAX ( 1, RowCount - 1 ), 0 ) * 100\n        VAR YRatio =\n            IF (\n                MaxValue = MinValue,\n                0.5,\n                DIVIDE ( [__Value] - MinValue, MaxValue - MinValue, 0.5 )\n            )\n        VAR YValue = 74 - YRatio * 38\n        RETURN FORMAT ( XValue, \"0.0\", \"en-US\" ) & \",\" & FORMAT ( YValue, \"0.0\", \"en-US\" ),\n        \" \",\n        DimDate[date],\n        ASC\n    )\nVAR ValueText = SUBSTITUTE ( SUBSTITUTE ( FORMAT ( CurrentValue, \"0.0%\" ), \"%\", \"%25\" ), \"&\", \"and\" )\nVAR PyText = SUBSTITUTE ( SUBSTITUTE ( FORMAT ( PriorValue, \"0.0%\" ), \"%\", \"%25\" ), \"&\", \"and\" )\nVAR DeltaText = SUBSTITUTE ( SUBSTITUTE ( FORMAT ( DeltaPoints, \"+0.0pt;-0.0pt;0.0pt\" ), \"%\", \"%25\" ), \"&\", \"and\" )\nVAR Sparkline =\n    IF (\n        RowCount >= 2,\n        \"<polyline points='\" & LinePoints & \"' fill='none' stroke='\" & TrendColor & \"' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'/>\"\n            & \"<circle cx='164' cy='\" & FORMAT ( FirstY, \"0.0\", \"en-US\" ) & \"' r='3.2' fill='%23FFFFFF' stroke='%23526173' stroke-width='1.2'/>\"\n            & \"<circle cx='264' cy='\" & FORMAT ( LastY, \"0.0\", \"en-US\" ) & \"' r='4.2' fill='\" & TrendColor & \"'/>\",\n        \"<line x1='164' y1='56' x2='264' y2='56' stroke='%23E6ECF2' stroke-width='3' stroke-linecap='round'/>\"\n    )\nVAR SVG =\n    \"<svg xmlns='http://www.w3.org/2000/svg' width='292' height='104' viewBox='0 0 292 104'>\"\n    & \"<rect x='1' y='1' width='290' height='102' rx='7' fill='%23FFFFFF' stroke='%23D5DEE8'/>\"\n    & \"<rect x='1' y='1' width='290' height='4' rx='2' fill='%23A8894B'/>\"\n    & \"<text x='16' y='24' font-family='Segoe UI Semibold' font-size='10.5' fill='%23526173'>Forecast Accuracy</text>\"\n    & \"<text x='16' y='54' font-family='Segoe UI Semibold' font-size='25' fill='%230F172A'>\" & ValueText & \"</text>\"\n    & \"<rect x='160' y='34' width='108' height='44' rx='8' fill='%23F8FAFC'/>\"\n    & \"<line x1='166' y1='56' x2='264' y2='56' stroke='%23E6ECF2' stroke-width='1' stroke-dasharray='3 5'/>\"\n    & Sparkline\n    & \"<rect x='16' y='72' width='76' height='18' rx='9' fill='%23F8FAFC' stroke='%23D5DEE8'/>\"\n    & \"<text x='26' y='85' font-family='Segoe UI' font-size='8.2' fill='%23526173'>PY \" & PyText & \"</text>\"\n    & \"<rect x='98' y='72' width='56' height='18' rx='9' fill='\" & StatusColor & \"' fill-opacity='0.14'/>\"\n    & \"<text x='108' y='85' font-family='Segoe UI Semibold' font-size='8.2' fill='\" & StatusColor & \"'>\" & DeltaText & \"</text>\"\n    & \"<text x='190' y='91' font-family='Segoe UI Semibold' font-size='8' fill='\" & StatusColor & \"'>\" & StatusText & \"</text>\"\n    & \"</svg>\"\nRETURN\n    \"data:image/svg+xml;utf8,\" & SVG",
            "formatString": "",
            "description": "SVG KPI card for forecast accuracy with prior-year point delta and sparkline.",
            "dataCategory": "ImageUrl"
          },
          {
            "name": "Lens Summary SVG",
            "expression": "VAR PeriodText = [Selected Latest Complete Period Label]\nVAR RegionText =\n    IF ( ISFILTERED ( DimEntity[region] ), LEFT ( CONCATENATEX ( VALUES ( DimEntity[region] ), DimEntity[region], \", \" ), 20 ), \"All regions\" )\nVAR BUText =\n    IF ( ISFILTERED ( DimBusinessUnit[business_unit] ), LEFT ( CONCATENATEX ( VALUES ( DimBusinessUnit[business_unit] ), DimBusinessUnit[business_unit], \", \" ), 24 ), \"All BUs\" )\nVAR ScenarioText =\n    IF ( ISFILTERED ( DimScenario[scenario] ), LEFT ( CONCATENATEX ( VALUES ( DimScenario[scenario] ), DimScenario[scenario], \", \" ), 18 ), \"Actual lens\" )\nVAR RevVar = [Latest Revenue Var %]\nVAR EbitdaVar = [Latest EBITDA Var %]\nVAR RiskValue = [Latest Open Exception Value]\nVAR RevText = SUBSTITUTE ( FORMAT ( RevVar, \"+0.0%;-0.0%;0.0%\" ), \"%\", \"%25\" )\nVAR StatusColor = IF ( EbitdaVar >= 0.02, \"%232B6F75\", IF ( EbitdaVar >= -0.02, \"%23A8894B\", \"%23B85A72\" ) )\nVAR SVG =\n    \"<svg xmlns='http://www.w3.org/2000/svg' width='536' height='42' viewBox='0 0 536 42'>\"\n    & \"<rect x='0.5' y='0.5' width='535' height='41' rx='7' fill='%23FFFFFF' stroke='%23D5DEE8'/>\"\n    & \"<circle cx='18' cy='21' r='5' fill='\" & StatusColor & \"'/>\"\n    & \"<text x='32' y='17' font-family='Segoe UI Semibold' font-size='9.5' fill='%230F172A'>Current Lens</text>\"\n    & \"<text x='32' y='31' font-family='Segoe UI' font-size='8.3' fill='%23526173'>\" & PeriodText & \" | \" & ScenarioText & \"</text>\"\n    & \"<rect x='174' y='9' width='102' height='24' rx='12' fill='%23F8FAFC' stroke='%23D5DEE8'/>\"\n    & \"<text x='186' y='25' font-family='Segoe UI Semibold' font-size='8.4' fill='%232F5F9E'>\" & RegionText & \"</text>\"\n    & \"<rect x='286' y='9' width='118' height='24' rx='12' fill='%23F8FAFC' stroke='%23D5DEE8'/>\"\n    & \"<text x='298' y='25' font-family='Segoe UI Semibold' font-size='8.4' fill='%232B6F75'>\" & BUText & \"</text>\"\n    & \"<rect x='414' y='9' width='108' height='24' rx='12' fill='%23F8FAFC' stroke='%23D5DEE8'/>\"\n    & \"<text x='426' y='25' font-family='Segoe UI Semibold' font-size='8.2' fill='%23A8894B'>Rev \" & RevText & \" | Risk $\" & FORMAT ( DIVIDE ( RiskValue, 1000000 ), \"0.0M\" ) & \"</text>\"\n    & \"</svg>\"\nRETURN\n    \"data:image/svg+xml;utf8,\" & SVG",
            "formatString": "",
            "description": "Top-bar Current Lens SVG for selected period, region, BU, revenue variance, and close-risk exposure.",
            "dataCategory": "ImageUrl"
          },
          {
            "name": "Regional FP&A Decision Chips SVG",
            "expression": "VAR Blue = \"%232F5F9E\"\nVAR Teal = \"%232B6F75\"\nVAR Gold = \"%23A8894B\"\nVAR Rose = \"%23B85A72\"\nVAR RevColor = IF ( [Latest Revenue Var %] >= 0, Teal, Rose )\nVAR EbitdaColor = IF ( [Latest EBITDA Var %] >= 0, Teal, Rose )\nVAR RiskColor = IF ( [Latest Open Exception Count] = 0, Teal, IF ( [Latest Open Exception Value] < 5000000, Gold, Rose ) )\nVAR ICColor = IF ( ABS ( DIVIDE ( [Latest Intercompany Elimination], [Latest Gross Revenue] ) ) < 0.08, Teal, Gold )\nVAR SVG =\n    \"<svg xmlns='http://www.w3.org/2000/svg' width='536' height='68' viewBox='0 0 536 68'>\"\n    & \"<rect x='0.5' y='0.5' width='535' height='67' rx='7' fill='%23FFFFFF' stroke='%23D5DEE8'/>\"\n    & \"<text x='14' y='17' font-family='Segoe UI Semibold' font-size='10' fill='%230F172A'>Decision Signals</text>\"\n    & \"<rect x='14' y='28' width='164' height='28' rx='14' fill='%23F8FAFC' stroke='%23D5DEE8'/>\"\n    & \"<circle cx='30' cy='42' r='4' fill='\" & RevColor & \"'/>\"\n    & \"<text x='42' y='39' font-family='Segoe UI' font-size='7.6' fill='%23526173'>Revenue vs budget</text>\"\n    & \"<text x='42' y='51' font-family='Segoe UI Semibold' font-size='8.4' fill='%230F172A'>\" & SUBSTITUTE ( FORMAT ( [Latest Revenue Var %], \"+0.0%;-0.0%;0.0%\" ), \"%\", \"%25\" ) & \"</text>\"\n    & \"<rect x='192' y='28' width='164' height='28' rx='14' fill='%23F8FAFC' stroke='%23D5DEE8'/>\"\n    & \"<circle cx='208' cy='42' r='4' fill='\" & EbitdaColor & \"'/>\"\n    & \"<text x='220' y='39' font-family='Segoe UI' font-size='7.6' fill='%23526173'>EBITDA vs budget</text>\"\n    & \"<text x='220' y='51' font-family='Segoe UI Semibold' font-size='8.4' fill='%230F172A'>\" & SUBSTITUTE ( FORMAT ( [Latest EBITDA Var %], \"+0.0%;-0.0%;0.0%\" ), \"%\", \"%25\" ) & \"</text>\"\n    & \"<rect x='370' y='28' width='164' height='28' rx='14' fill='%23F8FAFC' stroke='%23D5DEE8'/>\"\n    & \"<circle cx='386' cy='42' r='4' fill='\" & RiskColor & \"'/>\"\n    & \"<text x='398' y='39' font-family='Segoe UI' font-size='7.6' fill='%23526173'>Open close risk</text>\"\n    & \"<text x='398' y='51' font-family='Segoe UI Semibold' font-size='8.4' fill='%230F172A'>\" & SUBSTITUTE ( FORMAT ( [Latest Open Exception Count], \"#,0\" ) & \" items | $\" & FORMAT ( DIVIDE ( [Latest Open Exception Value], 1000000 ), \"0.0M\" ), \"%\", \"%25\" ) & \"</text>\"\n    & \"</svg>\"\nRETURN\n    \"data:image/svg+xml;utf8,\" & SVG",
            "formatString": "",
            "description": "Executive decision-chip SVG for regional FP&A revenue, EBITDA, and close-risk status.",
            "dataCategory": "ImageUrl"
          },
          {
            "name": "Controls Decision Chips SVG",
            "expression": "VAR Blue = \"%232F5F9E\"\nVAR Teal = \"%232B6F75\"\nVAR Gold = \"%23A8894B\"\nVAR Rose = \"%23B85A72\"\nVAR RevColor = IF ( [Latest Revenue Var %] >= 0, Teal, Rose )\nVAR EbitdaColor = IF ( [Latest EBITDA Var %] >= 0, Teal, Rose )\nVAR RiskColor = IF ( [Latest Open Exception Count] = 0, Teal, IF ( [Latest Open Exception Value] < 5000000, Gold, Rose ) )\nVAR ICColor = IF ( ABS ( DIVIDE ( [Latest Intercompany Elimination], [Latest Gross Revenue] ) ) < 0.08, Teal, Gold )\nVAR SVG =\n    \"<svg xmlns='http://www.w3.org/2000/svg' width='536' height='68' viewBox='0 0 536 68'>\"\n    & \"<rect x='0.5' y='0.5' width='535' height='67' rx='7' fill='%23FFFFFF' stroke='%23D5DEE8'/>\"\n    & \"<text x='14' y='17' font-family='Segoe UI Semibold' font-size='10' fill='%230F172A'>Control Signals</text>\"\n    & \"<rect x='14' y='28' width='164' height='28' rx='14' fill='%23F8FAFC' stroke='%23D5DEE8'/>\"\n    & \"<circle cx='30' cy='42' r='4' fill='\" & ICColor & \"'/>\"\n    & \"<text x='42' y='39' font-family='Segoe UI' font-size='7.6' fill='%23526173'>Intercompany</text>\"\n    & \"<text x='42' y='51' font-family='Segoe UI Semibold' font-size='8.4' fill='%230F172A'>\" & SUBSTITUTE ( \"$\" & FORMAT ( DIVIDE ( ABS ( [Latest Intercompany Elimination] ), 1000000 ), \"0.0M\" ), \"%\", \"%25\" ) & \"</text>\"\n    & \"<rect x='192' y='28' width='164' height='28' rx='14' fill='%23F8FAFC' stroke='%23D5DEE8'/>\"\n    & \"<circle cx='208' cy='42' r='4' fill='\" & RiskColor & \"'/>\"\n    & \"<text x='220' y='39' font-family='Segoe UI' font-size='7.6' fill='%23526173'>Close risk</text>\"\n    & \"<text x='220' y='51' font-family='Segoe UI Semibold' font-size='8.4' fill='%230F172A'>\" & SUBSTITUTE ( FORMAT ( [Latest Open Exception Count], \"#,0\" ) & \" open\", \"%\", \"%25\" ) & \"</text>\"\n    & \"<rect x='370' y='28' width='164' height='28' rx='14' fill='%23F8FAFC' stroke='%23D5DEE8'/>\"\n    & \"<circle cx='386' cy='42' r='4' fill='\" & EbitdaColor & \"'/>\"\n    & \"<text x='398' y='39' font-family='Segoe UI' font-size='7.6' fill='%23526173'>Forecast quality</text>\"\n    & \"<text x='398' y='51' font-family='Segoe UI Semibold' font-size='8.4' fill='%230F172A'>\" & SUBSTITUTE ( FORMAT ( [Latest Forecast Accuracy %], \"0.0%\" ), \"%\", \"%25\" ) & \"</text>\"\n    & \"</svg>\"\nRETURN\n    \"data:image/svg+xml;utf8,\" & SVG",
            "formatString": "",
            "description": "Control decision-chip SVG for intercompany, close risk, and forecast quality.",
            "dataCategory": "ImageUrl"
          }
        ]
      }
    ],
