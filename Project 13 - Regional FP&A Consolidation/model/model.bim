            "sourceColumn": "rate_type",
            "summarizeBy": "none"
          },
          {
            "name": "rate_to_usd",
            "dataType": "double",
            "sourceColumn": "rate_to_usd",
            "summarizeBy": "none"
          }
        ],
        "partitions": [
          {
            "name": "FactFXRate-Import",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Csv.Document(File.Contents(\"C:/Users/Win/OneDrive/Codex/Portfolio/BI/Project 13 - Regional FP&A Consolidation/data/prepared/fact_fx_rate.csv\"), [Delimiter=\",\", Encoding=65001, QuoteStyle=QuoteStyle.Csv]),",
                "    PromotedHeaders = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),",
                "    TypedColumns = Table.TransformColumnTypes(PromotedHeaders, {",
                "        {\"date_id\", type text},\n        {\"currency\", type text},\n        {\"to_currency\", type text},\n        {\"rate_type\", type text},\n        {\"rate_to_usd\", type number}",
                "    }, \"en-US\")",
                "in",
                "    TypedColumns"
              ]
            }
          }
        ]
      },
      {
        "name": "KPI Measures",
        "columns": [
          {
            "name": "Measure Group",
            "dataType": "string",
            "sourceColumn": "Measure Group",
            "isHidden": true,
            "summarizeBy": "none"
          }
        ],
        "partitions": [
          {
            "name": "KPI Measures-Import",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = #table(type table [Measure Group = text], {{\"Regional FP&A Consolidation\"}})",
                "in",
                "    Source"
              ]
            }
          }
        ],
        "measures": [
          {
            "name": "Total Revenue",
            "expression": "SUM ( FactFinancialSummary[external_revenue_usd] )",
            "formatString": "$#,0,,.0M",
            "description": "Consolidated external revenue after excluding intercompany revenue."
          },
          {
            "name": "Gross Revenue",
            "expression": "SUM ( FactFinancialSummary[gross_revenue_usd] )",
            "formatString": "$#,0,,.0M",
            "description": "External plus intercompany revenue before elimination."
          },
          {
            "name": "Intercompany Revenue",
            "expression": "SUM ( FactFinancialSummary[intercompany_revenue_usd] )",
            "formatString": "$#,0,,.0M",
            "description": "Intercompany revenue requiring elimination."
          },
          {
            "name": "Intercompany Elimination",
            "expression": "SUM ( FactFinancialSummary[intercompany_elimination_usd] )",
            "formatString": "$#,0,,.0M",
            "description": "Net intercompany elimination impact."
          },
          {
            "name": "Gross Profit",
            "expression": "SUM ( FactFinancialSummary[gross_profit_usd] )",
            "formatString": "$#,0,,.0M",
            "description": "Revenue minus cost of services."
          },
          {
            "name": "Gross Margin %",
            "expression": "DIVIDE ( [Gross Profit], [Total Revenue] )",
            "formatString": "0.0%",
            "description": "Gross profit divided by consolidated external revenue."
          },
          {
            "name": "OPEX",
            "expression": "SUM ( FactFinancialSummary[opex_usd] )",
            "formatString": "$#,0,,.0M",
            "description": "Personnel, facilities, sales and marketing, and G&A."
          },
          {
            "name": "EBITDA",
            "expression": "SUM ( FactFinancialSummary[ebitda_usd] )",
            "formatString": "$#,0,,.0M",
            "description": "Gross profit plus OPEX after intercompany elimination."
          },
          {
            "name": "EBITDA Margin %",
            "expression": "DIVIDE ( [EBITDA], [Total Revenue] )",
            "formatString": "0.0%",
            "description": "EBITDA divided by consolidated external revenue."
          },
          {
            "name": "Operating Income",
            "expression": "SUM ( FactFinancialSummary[operating_income_usd] )",
            "formatString": "$#,0,,.0M",
            "description": "EBITDA less depreciation."
          },
          {
            "name": "Net Income",
            "expression": "SUM ( FactFinancialSummary[net_income_usd] )",
            "formatString": "$#,0,,.0M",
            "description": "Operating income less interest and tax."
          },
          {
            "name": "Cash Position",
            "expression": "SUM ( FactFinancialSummary[cash_position_usd] )",
            "formatString": "$#,0,,.0M",
            "description": "Period-end cash position by entity and BU allocation."
          },
          {
            "name": "Operating Cash Flow",
            "expression": "SUM ( FactFinancialSummary[operating_cash_flow_usd] )",
            "formatString": "$#,0,,.0M",
            "description": "Operating cash flow proxy tied to EBITDA conversion."
          },
          {
            "name": "Working Capital",
            "expression": "SUM ( FactFinancialSummary[working_capital_usd] )",
            "formatString": "$#,0,,.0M",
            "description": "Working capital proxy for close review."
          },
          {
            "name": "Actual Revenue",
            "expression": "CALCULATE ( [Total Revenue], DimScenario[scenario] = \"Actual\" )",
            "formatString": "$#,0,,.0M",
            "description": "Actual consolidated revenue."
          },
          {
            "name": "Budget Revenue",
            "expression": "CALCULATE ( [Total Revenue], DimScenario[scenario] = \"Budget\" )",
            "formatString": "$#,0,,.0M",
            "description": "Budget consolidated revenue."
          },
          {
            "name": "Revenue Var vs Budget",
            "expression": "[Actual Revenue] - [Budget Revenue]",
            "formatString": "$#,0,,.0M",
            "description": "Actual revenue less budget revenue."
          },
          {
            "name": "Revenue Var %",
            "expression": "DIVIDE ( [Revenue Var vs Budget], [Budget Revenue] )",
            "formatString": "0.0%",
            "description": "Revenue variance divided by budget revenue."
          },
          {
            "name": "Actual EBITDA",
            "expression": "CALCULATE ( [EBITDA], DimScenario[scenario] = \"Actual\" )",
            "formatString": "$#,0,,.0M",
            "description": "Actual EBITDA."
          },
          {
            "name": "Budget EBITDA",
            "expression": "CALCULATE ( [EBITDA], DimScenario[scenario] = \"Budget\" )",
            "formatString": "$#,0,,.0M",
            "description": "Budget EBITDA."
          },
          {
            "name": "EBITDA Var vs Budget",
            "expression": "[Actual EBITDA] - [Budget EBITDA]",
            "formatString": "$#,0,,.0M",
            "description": "Actual EBITDA less budget EBITDA."
          },
          {
            "name": "EBITDA Var %",
            "expression": "DIVIDE ( [EBITDA Var vs Budget], [Budget EBITDA] )",
            "formatString": "0.0%",
            "description": "EBITDA variance divided by budget EBITDA."
          },
          {
            "name": "Forecast EBITDA",
            "expression": "CALCULATE ( [EBITDA], DimScenario[scenario] = \"Forecast\" )",
            "formatString": "$#,0,,.0M",
            "description": "Forecast EBITDA."
          },
          {
            "name": "Forecast Accuracy %",
            "expression": "1 - ABS ( DIVIDE ( [Actual EBITDA] - [Forecast EBITDA], [Actual EBITDA] ) )",
            "formatString": "0.0%",
            "description": "Directional forecast accuracy for EBITDA."
          },
          {
            "name": "Open Exception Count",
            "expression": "CALCULATE ( COUNTROWS ( FactCloseExceptions ), FactCloseExceptions[status] <> \"Closed\" )",
            "formatString": "#,0",
            "description": "Open or in-progress close exceptions."
          },
          {
            "name": "Open Exception Value",
            "expression": "CALCULATE ( SUM ( FactCloseExceptions[amount_usd] ), FactCloseExceptions[status] <> \"Closed\" )",
            "formatString": "$#,0,,.0M",
            "description": "Value attached to unresolved close exceptions."
          },
          {
            "name": "Selected Latest Complete Date",
            "expression": "VAR GlobalLatestComplete =\n    CALCULATE (\n        MAX ( DimDate[date] ),\n        REMOVEFILTERS ( DimDate ),\n        DimDate[is_latest_complete] = TRUE ()\n    )\nVAR SelectedLatest =\n    MAXX (\n        FILTER ( ALLSELECTED ( DimDate ), DimDate[date] <= GlobalLatestComplete ),\n        DimDate[date]\n    )\nRETURN\n    COALESCE ( SelectedLatest, GlobalLatestComplete )",
            "formatString": "mmm yyyy",
            "description": "Latest complete date within the selected date context, capped to the global closed period."
          },
          {
            "name": "Selected Latest Complete Period Label",
            "expression": "FORMAT ( [Selected Latest Complete Date], \"MMM yyyy\" )",
            "formatString": "",
            "description": "Display label for the selected latest complete month."
          },
          {
            "name": "Latest Actual Revenue",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [Actual Revenue], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0,,.0M",
            "description": "Actual revenue at selected latest complete period."
          },
          {
            "name": "Latest Budget Revenue",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [Budget Revenue], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0,,.0M",
            "description": "Budget revenue at selected latest complete period."
          },
          {
            "name": "Latest Revenue Var vs Budget",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [Revenue Var vs Budget], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0,,.0M",
            "description": "Revenue variance at selected latest complete period."
          },
          {
            "name": "Latest Revenue Var %",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [Revenue Var %], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "0.0%",
            "description": "Revenue variance percent at selected latest complete period."
          },
          {
            "name": "Latest Actual EBITDA",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [Actual EBITDA], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0,,.0M",
            "description": "Actual EBITDA at selected latest complete period."
          },
          {
            "name": "Latest Budget EBITDA",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [Budget EBITDA], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0,,.0M",
            "description": "Budget EBITDA at selected latest complete period."
          },
          {
            "name": "Latest EBITDA Var vs Budget",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [EBITDA Var vs Budget], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0,,.0M",
            "description": "EBITDA variance at selected latest complete period."
          },
          {
            "name": "Latest EBITDA Var %",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [EBITDA Var %], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "0.0%",
            "description": "EBITDA variance percent at selected latest complete period."
          },
          {
            "name": "Latest Gross Revenue",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [Gross Revenue], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0,,.0M",
            "description": "Gross revenue at selected latest complete period."
          },
          {
            "name": "Latest Gross Profit",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [Gross Profit], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0,,.0M",
            "description": "Gross profit at selected latest complete period."
          },
          {
            "name": "Latest Gross Margin %",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [Gross Margin %], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "0.0%",
            "description": "Gross margin at selected latest complete period."
          },
          {
            "name": "Latest OPEX",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [OPEX], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0,,.0M",
            "description": "OPEX at selected latest complete period."
          },
          {
            "name": "Latest Net Income",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [Net Income], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0,,.0M",
            "description": "Net income at selected latest complete period."
          },
          {
            "name": "Latest EBITDA Margin %",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [EBITDA Margin %], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "0.0%",
            "description": "EBITDA margin at selected latest complete period."
          },
          {
            "name": "Latest Cash Position",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [Cash Position], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0,,.0M",
            "description": "Cash position at selected latest complete period."
          },
          {
            "name": "Latest Operating Cash Flow",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [Operating Cash Flow], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0,,.0M",
            "description": "Operating cash flow at selected latest complete period."
          },
          {
            "name": "Latest Forecast Accuracy %",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [Forecast Accuracy %], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "0.0%",
            "description": "Forecast accuracy at selected latest complete period."
          },
          {
            "name": "Latest Intercompany Revenue",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [Intercompany Revenue], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0,,.0M",
            "description": "Intercompany revenue at selected latest complete period."
          },
          {
            "name": "Latest Intercompany Elimination",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [Intercompany Elimination], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0,,.0M",
            "description": "Intercompany elimination impact at selected latest complete period."
          },
          {
            "name": "Latest Open Exception Count",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [Open Exception Count], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "#,0",
            "description": "Open close-exception count at selected latest complete period."
          },
          {
            "name": "Latest Open Exception Value",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [Open Exception Value], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0,,.0M",
            "description": "Open close-exception exposure at selected latest complete period."
          },
          {
            "name": "Revenue PY",
            "expression": "VAR d = EDATE ( [Selected Latest Complete Date], -12 )\nRETURN\n    CALCULATE ( [Actual Revenue], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0,,.0M",
            "description": "Actual revenue for the same month in the prior year."
          },
          {
            "name": "EBITDA PY",
            "expression": "VAR d = EDATE ( [Selected Latest Complete Date], -12 )\nRETURN\n    CALCULATE ( [Actual EBITDA], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0,,.0M",
            "description": "Actual EBITDA for the same month in the prior year."
          },
          {
            "name": "Gross Margin PY %",
            "expression": "VAR d = EDATE ( [Selected Latest Complete Date], -12 )\nRETURN\n    CALCULATE ( [Gross Margin %], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "0.0%",
            "description": "Gross margin for the same month in the prior year."
          },
          {
            "name": "Cash Position PY",
            "expression": "VAR d = EDATE ( [Selected Latest Complete Date], -12 )\nRETURN\n    CALCULATE ( [Cash Position], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0,,.0M",
            "description": "Cash position for the same month in the prior year."
          },
          {
            "name": "Open Exception Value PY",
            "expression": "VAR d = EDATE ( [Selected Latest Complete Date], -12 )\nRETURN\n    CALCULATE ( [Open Exception Value], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0,,.0M",
            "description": "Open exception value for the same month in the prior year."
          },
          {
            "name": "Revenue KPI Card SVG",
            "expression": "VAR d = [Selected Latest Complete Date]\nVAR LatestIdx =\n    CALCULATE ( MAX ( DimDate[month_index] ), REMOVEFILTERS ( DimDate ), DimDate[date] = d )\nVAR CurrentValue =\n    CALCULATE ( [Actual Revenue], REMOVEFILTERS ( DimDate ), DimDate[date] = d )\nVAR PriorDate = EDATE ( d, -12 )\nVAR PriorValue =\n    CALCULATE ( [Actual Revenue], REMOVEFILTERS ( DimDate ), DimDate[date] = PriorDate )\nVAR BudgetValue = CALCULATE ( [Budget Revenue], REMOVEFILTERS ( DimDate ), DimDate[date] = d )\nVAR ChangePct = DIVIDE ( CurrentValue - PriorValue, ABS ( PriorValue ) )\nVAR DeltaPoints = ( CurrentValue - PriorValue ) * 100\nVAR StatusBasis =\n    IF (\n        NOT ISBLANK ( BudgetValue ),\n        DIVIDE ( CurrentValue - BudgetValue, ABS ( BudgetValue ) ),\n        ChangePct\n    )\nVAR StatusColor =\n    IF ( StatusBasis >= 0.02, \"%236F8552\", IF ( StatusBasis >= -0.02, \"%23A8894B\", \"%23B85A72\" ) )\nVAR StatusText =\n    IF ( StatusBasis >= 0.02, \"ON TRACK\", IF ( StatusBasis >= -0.02, \"WATCH\", \"ACTION\" ) )\nVAR TrendColor =\n    IF ( CurrentValue >= PriorValue, \"%236F8552\", \"%23B85A72\" )\nVAR MonthTable =\n    ADDCOLUMNS (\n        FILTER (\n            ALL ( DimDate ),\n            DimDate[date] <= d\n                && DimDate[month_index] >= LatestIdx - 11\n        ),\n        \"__Value\", CALCULATE ( [Actual Revenue] )\n    )\nVAR CleanTable = FILTER ( MonthTable, NOT ISBLANK ( [__Value] ) )\nVAR RowCount = COUNTROWS ( CleanTable )\nVAR MinValue = MINX ( CleanTable, [__Value] )\nVAR MaxValue = MAXX ( CleanTable, [__Value] )\nVAR FirstValue = MINX ( TOPN ( 1, CleanTable, DimDate[date], ASC ), [__Value] )\nVAR LastValue = MAXX ( TOPN ( 1, CleanTable, DimDate[date], DESC ), [__Value] )\nVAR FirstY =\n    IF (\n        MaxValue = MinValue,\n        52,\n        74 - DIVIDE ( FirstValue - MinValue, MaxValue - MinValue, 0.5 ) * 38\n    )\nVAR LastY =\n    IF (\n        MaxValue = MinValue,\n        52,\n        74 - DIVIDE ( LastValue - MinValue, MaxValue - MinValue, 0.5 ) * 38\n    )\nVAR LinePoints =\n    CONCATENATEX (\n        CleanTable,\n        VAR RankValue = RANKX ( CleanTable, DimDate[date], , ASC, DENSE ) - 1\n        VAR XValue = 164 + DIVIDE ( RankValue, MAX ( 1, RowCount - 1 ), 0 ) * 100\n        VAR YRatio =\n            IF (\n                MaxValue = MinValue,\n                0.5,\n                DIVIDE ( [__Value] - MinValue, MaxValue - MinValue, 0.5 )\n            )\n        VAR YValue = 74 - YRatio * 38\n        RETURN FORMAT ( XValue, \"0.0\", \"en-US\" ) & \",\" & FORMAT ( YValue, \"0.0\", \"en-US\" ),\n        \" \",\n        DimDate[date],\n        ASC\n    )\nVAR ValueText = SUBSTITUTE ( SUBSTITUTE ( FORMAT ( DIVIDE ( CurrentValue, 1000000 ), \"$0.0M;($0.0M);$0.0M\" ), \"%\", \"%25\" ), \"&\", \"and\" )\nVAR PyText = SUBSTITUTE ( SUBSTITUTE ( FORMAT ( DIVIDE ( PriorValue, 1000000 ), \"$0.0M;($0.0M);$0.0M\" ), \"%\", \"%25\" ), \"&\", \"and\" )\nVAR DeltaText = SUBSTITUTE ( SUBSTITUTE ( FORMAT ( ChangePct, \"+0.0%;-0.0%;0.0%\" ), \"%\", \"%25\" ), \"&\", \"and\" )\nVAR Sparkline =\n    IF (\n        RowCount >= 2,\n        \"<polyline points='\" & LinePoints & \"' fill='none' stroke='\" & TrendColor & \"' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'/>\"\n            & \"<circle cx='164' cy='\" & FORMAT ( FirstY, \"0.0\", \"en-US\" ) & \"' r='3.2' fill='%23FFFFFF' stroke='%23526173' stroke-width='1.2'/>\"\n            & \"<circle cx='264' cy='\" & FORMAT ( LastY, \"0.0\", \"en-US\" ) & \"' r='4.2' fill='\" & TrendColor & \"'/>\",\n        \"<line x1='164' y1='56' x2='264' y2='56' stroke='%23E6ECF2' stroke-width='3' stroke-linecap='round'/>\"\n    )\nVAR SVG =\n    \"<svg xmlns='http://www.w3.org/2000/svg' width='292' height='104' viewBox='0 0 292 104'>\"\n    & \"<rect x='1' y='1' width='290' height='102' rx='7' fill='%23FFFFFF' stroke='%23D5DEE8'/>\"\n    & \"<rect x='1' y='1' width='290' height='4' rx='2' fill='%232F5F9E'/>\"\n    & \"<text x='16' y='24' font-family='Segoe UI Semibold' font-size='10.5' fill='%23526173'>Revenue</text>\"\n    & \"<text x='16' y='54' font-family='Segoe UI Semibold' font-size='25' fill='%230F172A'>\" & ValueText & \"</text>\"\n    & \"<rect x='160' y='34' width='108' height='44' rx='8' fill='%23F8FAFC'/>\"\n    & \"<line x1='166' y1='56' x2='264' y2='56' stroke='%23E6ECF2' stroke-width='1' stroke-dasharray='3 5'/>\"\n    & Sparkline\n    & \"<rect x='16' y='72' width='76' height='18' rx='9' fill='%23F8FAFC' stroke='%23D5DEE8'/>\"\n    & \"<text x='26' y='85' font-family='Segoe UI' font-size='8.2' fill='%23526173'>PY \" & PyText & \"</text>\"\n    & \"<rect x='98' y='72' width='56' height='18' rx='9' fill='\" & StatusColor & \"' fill-opacity='0.14'/>\"\n    & \"<text x='108' y='85' font-family='Segoe UI Semibold' font-size='8.2' fill='\" & StatusColor & \"'>\" & DeltaText & \"</text>\"\n    & \"<text x='190' y='91' font-family='Segoe UI Semibold' font-size='8' fill='\" & StatusColor & \"'>\" & StatusText & \"</text>\"\n    & \"</svg>\"\nRETURN\n    \"data:image/svg+xml;utf8,\" & SVG",
            "formatString": "",
            "description": "SVG KPI card for revenue with latest value, PY delta, status chip, and sparkline.",
            "dataCategory": "ImageUrl"
          },
          {
            "name": "EBITDA KPI Card SVG",
            "expression": "VAR d = [Selected Latest Complete Date]\nVAR LatestIdx =\n    CALCULATE ( MAX ( DimDate[month_index] ), REMOVEFILTERS ( DimDate ), DimDate[date] = d )\nVAR CurrentValue =\n    CALCULATE ( [Actual EBITDA], REMOVEFILTERS ( DimDate ), DimDate[date] = d )\nVAR PriorDate = EDATE ( d, -12 )\nVAR PriorValue =\n    CALCULATE ( [Actual EBITDA], REMOVEFILTERS ( DimDate ), DimDate[date] = PriorDate )\nVAR BudgetValue = CALCULATE ( [Budget EBITDA], REMOVEFILTERS ( DimDate ), DimDate[date] = d )\nVAR ChangePct = DIVIDE ( CurrentValue - PriorValue, ABS ( PriorValue ) )\nVAR DeltaPoints = ( CurrentValue - PriorValue ) * 100\nVAR StatusBasis =\n    IF (\n        NOT ISBLANK ( BudgetValue ),\n        DIVIDE ( CurrentValue - BudgetValue, ABS ( BudgetValue ) ),\n        ChangePct\n    )\nVAR StatusColor =\n    IF ( StatusBasis >= 0.02, \"%236F8552\", IF ( StatusBasis >= -0.02, \"%23A8894B\", \"%23B85A72\" ) )\nVAR StatusText =\n    IF ( StatusBasis >= 0.02, \"ON TRACK\", IF ( StatusBasis >= -0.02, \"WATCH\", \"ACTION\" ) )\nVAR TrendColor =\n    IF ( CurrentValue >= PriorValue, \"%236F8552\", \"%23B85A72\" )\nVAR MonthTable =\n    ADDCOLUMNS (\n        FILTER (\n            ALL ( DimDate ),\n            DimDate[date] <= d\n                && DimDate[month_index] >= LatestIdx - 11\n        ),\n        \"__Value\", CALCULATE ( [Actual EBITDA] )\n    )\nVAR CleanTable = FILTER ( MonthTable, NOT ISBLANK ( [__Value] ) )\nVAR RowCount = COUNTROWS ( CleanTable )\nVAR MinValue = MINX ( CleanTable, [__Value] )\nVAR MaxValue = MAXX ( CleanTable, [__Value] )\nVAR FirstValue = MINX ( TOPN ( 1, CleanTable, DimDate[date], ASC ), [__Value] )\nVAR LastValue = MAXX ( TOPN ( 1, CleanTable, DimDate[date], DESC ), [__Value] )\nVAR FirstY =\n    IF (\n        MaxValue = MinValue,\n        52,\n        74 - DIVIDE ( FirstValue - MinValue, MaxValue - MinValue, 0.5 ) * 38\n    )\nVAR LastY =\n    IF (\n        MaxValue = MinValue,\n        52,\n        74 - DIVIDE ( LastValue - MinValue, MaxValue - MinValue, 0.5 ) * 38\n    )\nVAR LinePoints =\n    CONCATENATEX (\n        CleanTable,\n        VAR RankValue = RANKX ( CleanTable, DimDate[date], , ASC, DENSE ) - 1\n        VAR XValue = 164 + DIVIDE ( RankValue, MAX ( 1, RowCount - 1 ), 0 ) * 100\n        VAR YRatio =\n            IF (\n                MaxValue = MinValue,\n                0.5,\n                DIVIDE ( [__Value] - MinValue, MaxValue - MinValue, 0.5 )\n            )\n        VAR YValue = 74 - YRatio * 38\n        RETURN FORMAT ( XValue, \"0.0\", \"en-US\" ) & \",\" & FORMAT ( YValue, \"0.0\", \"en-US\" ),\n        \" \",\n        DimDate[date],\n        ASC\n    )\nVAR ValueText = SUBSTITUTE ( SUBSTITUTE ( FORMAT ( DIVIDE ( CurrentValue, 1000000 ), \"$0.0M;($0.0M);$0.0M\" ), \"%\", \"%25\" ), \"&\", \"and\" )\nVAR PyText = SUBSTITUTE ( SUBSTITUTE ( FORMAT ( DIVIDE ( PriorValue, 1000000 ), \"$0.0M;($0.0M);$0.0M\" ), \"%\", \"%25\" ), \"&\", \"and\" )\nVAR DeltaText = SUBSTITUTE ( SUBSTITUTE ( FORMAT ( ChangePct, \"+0.0%;-0.0%;0.0%\" ), \"%\", \"%25\" ), \"&\", \"and\" )\nVAR Sparkline =\n    IF (\n        RowCount >= 2,\n        \"<polyline points='\" & LinePoints & \"' fill='none' stroke='\" & TrendColor & \"' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'/>\"\n            & \"<circle cx='164' cy='\" & FORMAT ( FirstY, \"0.0\", \"en-US\" ) & \"' r='3.2' fill='%23FFFFFF' stroke='%23526173' stroke-width='1.2'/>\"\n            & \"<circle cx='264' cy='\" & FORMAT ( LastY, \"0.0\", \"en-US\" ) & \"' r='4.2' fill='\" & TrendColor & \"'/>\",\n        \"<line x1='164' y1='56' x2='264' y2='56' stroke='%23E6ECF2' stroke-width='3' stroke-linecap='round'/>\"\n    )\nVAR SVG =\n    \"<svg xmlns='http://www.w3.org/2000/svg' width='292' height='104' viewBox='0 0 292 104'>\"\n    & \"<rect x='1' y='1' width='290' height='102' rx='7' fill='%23FFFFFF' stroke='%23D5DEE8'/>\"\n    & \"<rect x='1' y='1' width='290' height='4' rx='2' fill='%232B6F75'/>\"\n    & \"<text x='16' y='24' font-family='Segoe UI Semibold' font-size='10.5' fill='%23526173'>EBITDA</text>\"\n    & \"<text x='16' y='54' font-family='Segoe UI Semibold' font-size='25' fill='%230F172A'>\" & ValueText & \"</text>\"\n    & \"<rect x='160' y='34' width='108' height='44' rx='8' fill='%23F8FAFC'/>\"\n    & \"<line x1='166' y1='56' x2='264' y2='56' stroke='%23E6ECF2' stroke-width='1' stroke-dasharray='3 5'/>\"\n    & Sparkline\n    & \"<rect x='16' y='72' width='76' height='18' rx='9' fill='%23F8FAFC' stroke='%23D5DEE8'/>\"\n    & \"<text x='26' y='85' font-family='Segoe UI' font-size='8.2' fill='%23526173'>PY \" & PyText & \"</text>\"\n    & \"<rect x='98' y='72' width='56' height='18' rx='9' fill='\" & StatusColor & \"' fill-opacity='0.14'/>\"\n    & \"<text x='108' y='85' font-family='Segoe UI Semibold' font-size='8.2' fill='\" & StatusColor & \"'>\" & DeltaText & \"</text>\"\n    & \"<text x='190' y='91' font-family='Segoe UI Semibold' font-size='8' fill='\" & StatusColor & \"'>\" & StatusText & \"</text>\"\n    & \"</svg>\"\nRETURN\n    \"data:image/svg+xml;utf8,\" & SVG",
            "formatString": "",
            "description": "SVG KPI card for EBITDA with latest value, PY delta, status chip, and sparkline.",
            "dataCategory": "ImageUrl"
          },
          {
            "name": "Margin KPI Card SVG",
            "expression": "VAR d = [Selected Latest Complete Date]\nVAR LatestIdx =\n    CALCULATE ( MAX ( DimDate[month_index] ), REMOVEFILTERS ( DimDate ), DimDate[date] = d )\nVAR CurrentValue =\n    CALCULATE ( [EBITDA Margin %], REMOVEFILTERS ( DimDate ), DimDate[date] = d )\nVAR PriorDate = EDATE ( d, -12 )\nVAR PriorValue =\n    CALCULATE ( [EBITDA Margin %], REMOVEFILTERS ( DimDate ), DimDate[date] = PriorDate )\nVAR BudgetValue = BLANK ()\nVAR ChangePct = DIVIDE ( CurrentValue - PriorValue, ABS ( PriorValue ) )\nVAR DeltaPoints = ( CurrentValue - PriorValue ) * 100\nVAR StatusBasis =\n    IF (\n        NOT ISBLANK ( BudgetValue ),\n        DIVIDE ( CurrentValue - BudgetValue, ABS ( BudgetValue ) ),\n        ChangePct\n    )\nVAR StatusColor =\n    IF ( StatusBasis >= 0.02, \"%236F8552\", IF ( StatusBasis >= -0.02, \"%23A8894B\", \"%23B85A72\" ) )\nVAR StatusText =\n    IF ( StatusBasis >= 0.02, \"ON TRACK\", IF ( StatusBasis >= -0.02, \"WATCH\", \"ACTION\" ) )\nVAR TrendColor =\n    IF ( CurrentValue >= PriorValue, \"%236F8552\", \"%23B85A72\" )\nVAR MonthTable =\n    ADDCOLUMNS (\n        FILTER (\n            ALL ( DimDate ),\n            DimDate[date] <= d\n                && DimDate[month_index] >= LatestIdx - 11\n        ),\n        \"__Value\", CALCULATE ( [EBITDA Margin %] )\n    )\nVAR CleanTable = FILTER ( MonthTable, NOT ISBLANK ( [__Value] ) )\nVAR RowCount = COUNTROWS ( CleanTable )\nVAR MinValue = MINX ( CleanTable, [__Value] )\nVAR MaxValue = MAXX ( CleanTable, [__Value] )\nVAR FirstValue = MINX ( TOPN ( 1, CleanTable, DimDate[date], ASC ), [__Value] )\nVAR LastValue = MAXX ( TOPN ( 1, CleanTable, DimDate[date], DESC ), [__Value] )\nVAR FirstY =\n    IF (\n        MaxValue = MinValue,\n        52,\n        74 - DIVIDE ( FirstValue - MinValue, MaxValue - MinValue, 0.5 ) * 38\n    )\nVAR LastY =\n    IF (\n        MaxValue = MinValue,\n        52,\n        74 - DIVIDE ( LastValue - MinValue, MaxValue - MinValue, 0.5 ) * 38\n    )\nVAR LinePoints =\n    CONCATENATEX (\n        CleanTable,\n        VAR RankValue = RANKX ( CleanTable, DimDate[date], , ASC, DENSE ) - 1\n        VAR XValue = 164 + DIVIDE ( RankValue, MAX ( 1, RowCount - 1 ), 0 ) * 100\n        VAR YRatio =\n            IF (\n                MaxValue = MinValue,\n                0.5,\n                DIVIDE ( [__Value] - MinValue, MaxValue - MinValue, 0.5 )\n            )\n        VAR YValue = 74 - YRatio * 38\n        RETURN FORMAT ( XValue, \"0.0\", \"en-US\" ) & \",\" & FORMAT ( YValue, \"0.0\", \"en-US\" ),\n        \" \",\n        DimDate[date],\n        ASC\n    )\nVAR ValueText = SUBSTITUTE ( SUBSTITUTE ( FORMAT ( CurrentValue, \"0.0%\" ), \"%\", \"%25\" ), \"&\", \"and\" )\nVAR PyText = SUBSTITUTE ( SUBSTITUTE ( FORMAT ( PriorValue, \"0.0%\" ), \"%\", \"%25\" ), \"&\", \"and\" )\nVAR DeltaText = SUBSTITUTE ( SUBSTITUTE ( FORMAT ( DeltaPoints, \"+0.0pt;-0.0pt;0.0pt\" ), \"%\", \"%25\" ), \"&\", \"and\" )\nVAR Sparkline =\n    IF (\n        RowCount >= 2,\n        \"<polyline points='\" & LinePoints & \"' fill='none' stroke='\" & TrendColor & \"' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'/>\"\n            & \"<circle cx='164' cy='\" & FORMAT ( FirstY, \"0.0\", \"en-US\" ) & \"' r='3.2' fill='%23FFFFFF' stroke='%23526173' stroke-width='1.2'/>\"\n            & \"<circle cx='264' cy='\" & FORMAT ( LastY, \"0.0\", \"en-US\" ) & \"' r='4.2' fill='\" & TrendColor & \"'/>\",\n        \"<line x1='164' y1='56' x2='264' y2='56' stroke='%23E6ECF2' stroke-width='3' stroke-linecap='round'/>\"\n    )\nVAR SVG =\n    \"<svg xmlns='http://www.w3.org/2000/svg' width='292' height='104' viewBox='0 0 292 104'>\"\n    & \"<rect x='1' y='1' width='290' height='102' rx='7' fill='%23FFFFFF' stroke='%23D5DEE8'/>\"\n    & \"<rect x='1' y='1' width='290' height='4' rx='2' fill='%236F8552'/>\"\n    & \"<text x='16' y='24' font-family='Segoe UI Semibold' font-size='10.5' fill='%23526173'>EBITDA Margin</text>\"\n    & \"<text x='16' y='54' font-family='Segoe UI Semibold' font-size='25' fill='%230F172A'>\" & ValueText & \"</text>\"\n    & \"<rect x='160' y='34' width='108' height='44' rx='8' fill='%23F8FAFC'/>\"\n    & \"<line x1='166' y1='56' x2='264' y2='56' stroke='%23E6ECF2' stroke-width='1' stroke-dasharray='3 5'/>\"\n    & Sparkline\n    & \"<rect x='16' y='72' width='76' height='18' rx='9' fill='%23F8FAFC' stroke='%23D5DEE8'/>\"\n    & \"<text x='26' y='85' font-family='Segoe UI' font-size='8.2' fill='%23526173'>PY \" & PyText & \"</text>\"\n    & \"<rect x='98' y='72' width='56' height='18' rx='9' fill='\" & StatusColor & \"' fill-opacity='0.14'/>\"\n    & \"<text x='108' y='85' font-family='Segoe UI Semibold' font-size='8.2' fill='\" & StatusColor & \"'>\" & DeltaText & \"</text>\"\n    & \"<text x='190' y='91' font-family='Segoe UI Semibold' font-size='8' fill='\" & StatusColor & \"'>\" & StatusText & \"</text>\"\n    & \"</svg>\"\nRETURN\n    \"data:image/svg+xml;utf8,\" & SVG",
            "formatString": "",
            "description": "SVG KPI card for EBITDA margin with prior-year point delta and sparkline.",
            "dataCategory": "ImageUrl"
