          {
            "name": "Cash KPI Card SVG",
            "expression": "VAR d = [Selected Latest Complete Date]\nVAR LatestIdx =\n    CALCULATE ( MAX ( DimDate[month_index] ), REMOVEFILTERS ( DimDate ), DimDate[date] = d )\nVAR CurrentValue =\n    COALESCE ( CALCULATE ( [Cash Position], REMOVEFILTERS ( DimDate ), DimDate[date] = d ), 0 )\nVAR PriorDate = EDATE ( d, -12 )\nVAR PriorValue =\n    COALESCE ( CALCULATE ( [Cash Position], REMOVEFILTERS ( DimDate ), DimDate[date] = PriorDate ), 0 )\nVAR BudgetValue = BLANK ()\nVAR ChangePct = DIVIDE ( CurrentValue - PriorValue, ABS ( PriorValue ) )\nVAR DeltaPoints = ( CurrentValue - PriorValue ) * 100\nVAR StatusBasis =\n    IF (\n        NOT ISBLANK ( BudgetValue ),\n        DIVIDE ( CurrentValue - BudgetValue, ABS ( BudgetValue ) ),\n        ChangePct\n    )\nVAR StatusColor =\n    IF ( StatusBasis >= 0.02, \"%236F8552\", IF ( StatusBasis >= -0.02, \"%23A8894B\", \"%23B85A72\" ) )\nVAR StatusText =\n    IF ( StatusBasis >= 0.02, \"ON TRACK\", IF ( StatusBasis >= -0.02, \"WATCH\", \"ACTION\" ) )\nVAR TrendColor =\n    IF ( CurrentValue >= PriorValue, \"%236F8552\", \"%23B85A72\" )\nVAR MonthTable =\n    ADDCOLUMNS (\n        FILTER (\n            ALL ( DimDate ),\n            DimDate[date] <= d\n                && DimDate[month_index] >= LatestIdx - 11\n        ),\n        \"__Value\", CALCULATE ( [Cash Position] )\n    )\nVAR CleanTable = FILTER ( MonthTable, NOT ISBLANK ( [__Value] ) )\nVAR RowCount = COUNTROWS ( CleanTable )\nVAR MinValue = MINX ( CleanTable, [__Value] )\nVAR MaxValue = MAXX ( CleanTable, [__Value] )\nVAR FirstValue = MINX ( TOPN ( 1, CleanTable, DimDate[date], ASC ), [__Value] )\nVAR LastValue = MAXX ( TOPN ( 1, CleanTable, DimDate[date], DESC ), [__Value] )\nVAR FirstY =\n    IF (\n        MaxValue = MinValue,\n        70,\n        96 - DIVIDE ( FirstValue - MinValue, MaxValue - MinValue, 0.5 ) * 52\n    )\nVAR LastY =\n    IF (\n        MaxValue = MinValue,\n        70,\n        96 - DIVIDE ( LastValue - MinValue, MaxValue - MinValue, 0.5 ) * 52\n    )\nVAR LinePoints =\n    CONCATENATEX (\n        CleanTable,\n        VAR RankValue = RANKX ( CleanTable, DimDate[date], , ASC, DENSE ) - 1\n        VAR XValue = 172 + DIVIDE ( RankValue, MAX ( 1, RowCount - 1 ), 0 ) * 102\n        VAR YRatio =\n            IF (\n                MaxValue = MinValue,\n                0.5,\n                DIVIDE ( [__Value] - MinValue, MaxValue - MinValue, 0.5 )\n            )\n        VAR YValue = 96 - YRatio * 52\n        RETURN FORMAT ( XValue, \"0.0\", \"en-US\" ) & \",\" & FORMAT ( YValue, \"0.0\", \"en-US\" ),\n        \" \",\n        DimDate[date],\n        ASC\n    )\nVAR AreaPoints = \"172,106 \" & LinePoints & \" 274,106\"\nVAR ValueText = SUBSTITUTE ( SUBSTITUTE ( FORMAT ( DIVIDE ( CurrentValue, 1000000 ), \"$0.0M;($0.0M);$0.0M\" ), \"%\", \"%25\" ), \"&\", \"and\" )\nVAR PyText = SUBSTITUTE ( SUBSTITUTE ( FORMAT ( DIVIDE ( PriorValue, 1000000 ), \"$0.0M;($0.0M);$0.0M\" ), \"%\", \"%25\" ), \"&\", \"and\" )\nVAR DeltaText = SUBSTITUTE ( SUBSTITUTE ( FORMAT ( ChangePct, \"+0.0%;-0.0%;0.0%\" ), \"%\", \"%25\" ), \"&\", \"and\" )\nVAR Sparkline =\n    IF (\n        RowCount >= 2,\n        \"<g clip-path='url(%23sparkClip)'><polygon points='\" & AreaPoints & \"' fill='\" & TrendColor & \"' fill-opacity='0.26'/>\"\n            & \"<polyline points='\" & LinePoints & \"' fill='none' stroke='\" & TrendColor & \"' stroke-width='4.0' stroke-linecap='round' stroke-linejoin='round'/></g>\"\n            & \"<circle cx='172' cy='\" & FORMAT ( FirstY, \"0.0\", \"en-US\" ) & \"' r='4.4' fill='%231F2630' stroke='%23B9C3CF' stroke-width='1.45'/>\"\n            & \"<circle cx='274' cy='\" & FORMAT ( LastY, \"0.0\", \"en-US\" ) & \"' r='5.6' fill='\" & TrendColor & \"'/>\",\n        \"<line x1='172' y1='70' x2='274' y2='70' stroke='%23313B48' stroke-width='4.0' stroke-linecap='round'/>\"\n    )\nVAR SVG =\n    \"<svg xmlns='http://www.w3.org/2000/svg' width='296' height='135' viewBox='0 0 296 135'>\"\n    & \"<defs><clipPath id='sparkClip'><rect x='170' y='43' width='106' height='64' rx='5'/></clipPath></defs>\"\n    & \"<rect x='1.2' y='1.2' width='293.6' height='132.6' rx='12' fill='%23242B35' stroke='%233A4655' stroke-width='1.05'/>\"\n    & \"<rect x='13' y='13' width='150' height='4.5' rx='2.25' fill='%23A8894B'/>\"\n    & \"<rect x='13' y='31' width='16' height='16' rx='4.2' fill='%23A8894B' fill-opacity='0.22' stroke='%23A8894B' stroke-width='1.15'/>\"\n    & \"<text x='38' y='45' font-family='Segoe UI Semibold' font-size='13.0' fill='%23F7FAFC' letter-spacing='0'>Cash Position</text>\"\n    & \"<text x='13' y='98' font-family='Segoe UI Semibold' font-size='38' fill='%23A8894B' letter-spacing='0'>\" & ValueText & \"</text>\"\n    & \"<rect x='162' y='32' width='120' height='82' rx='9' fill='%231F2630' stroke='%233A4655' stroke-width='1.0'/>\"\n    & \"<rect x='170' y='43' width='106' height='64' rx='5.5' fill='%23A8894B' fill-opacity='0.13'/>\"\n    & \"<line x1='170' y1='73' x2='276' y2='73' stroke='%23313B48' stroke-width='1.4' stroke-dasharray='4 5'/>\"\n    & Sparkline\n    & \"<rect x='13' y='110' width='94' height='20' rx='9' fill='%232C3440' stroke='%233A4655' stroke-width='0.75'/>\"\n    & \"<text x='23' y='124' font-family='Segoe UI Semibold' font-size='10.5' fill='%23B9C3CF'>PY \" & PyText & \"</text>\"\n    & \"<rect x='113' y='110' width='76' height='20' rx='9' fill='\" & StatusColor & \"' fill-opacity='0.16' stroke='\" & StatusColor & \"' stroke-opacity='0.18'/>\"\n    & \"<text x='151' y='124' text-anchor='middle' font-family='Segoe UI Semibold' font-size='10.5' fill='\" & StatusColor & \"'>\" & DeltaText & \"</text>\"\n    & \"<rect x='195' y='110' width='87' height='20' rx='9' fill='\" & StatusColor & \"' fill-opacity='0.11'/>\"\n    & \"<text x='238.5' y='124' text-anchor='middle' font-family='Segoe UI Semibold' font-size='10.2' fill='\" & StatusColor & \"'>\" & StatusText & \"</text>\"\n    & \"</svg>\"\nRETURN\n    \"data:image/svg+xml;utf8,\" & SVG",
