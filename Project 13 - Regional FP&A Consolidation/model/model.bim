          {
            "name": "Forecast Accuracy KPI Card SVG",
            "expression": "VAR d = [Selected Latest Complete Date]\nVAR LatestIdx =\n    CALCULATE ( MAX ( DimDate[month_index] ), REMOVEFILTERS ( DimDate ), DimDate[date] = d )\nVAR CurrentValue =\n    COALESCE ( CALCULATE ( [Forecast Accuracy %], REMOVEFILTERS ( DimDate ), DimDate[date] = d ), 0 )\nVAR PriorDate = EDATE ( d, -12 )\nVAR PriorValue =\n    COALESCE ( CALCULATE ( [Forecast Accuracy %], REMOVEFILTERS ( DimDate ), DimDate[date] = PriorDate ), 0 )\nVAR BudgetValue = BLANK ()\nVAR ChangePct = DIVIDE ( CurrentValue - PriorValue, ABS ( PriorValue ) )\nVAR DeltaPoints = ( CurrentValue - PriorValue ) * 100\nVAR StatusBasis =\n    IF (\n        NOT ISBLANK ( BudgetValue ),\n        DIVIDE ( CurrentValue - BudgetValue, ABS ( BudgetValue ) ),\n        ChangePct\n    )\nVAR StatusColor =\n    IF ( StatusBasis >= 0.02, \"%236F8552\", IF ( StatusBasis >= -0.02, \"%23A8894B\", \"%23B85A72\" ) )\nVAR StatusText =\n    IF ( StatusBasis >= 0.02, \"ON TRACK\", IF ( StatusBasis >= -0.02, \"WATCH\", \"ACTION\" ) )\nVAR TrendColor =\n    IF ( CurrentValue >= PriorValue, \"%236F8552\", \"%23B85A72\" )\nVAR MonthTable =\n    ADDCOLUMNS (\n        FILTER (\n            ALL ( DimDate ),\n            DimDate[date] <= d\n                && DimDate[month_index] >= LatestIdx - 11\n        ),\n        \"__Value\", CALCULATE ( [Forecast Accuracy %] )\n    )\nVAR CleanTable = FILTER ( MonthTable, NOT ISBLANK ( [__Value] ) )\nVAR RowCount = COUNTROWS ( CleanTable )\nVAR MinValue = MINX ( CleanTable, [__Value] )\nVAR MaxValue = MAXX ( CleanTable, [__Value] )\nVAR FirstValue = MINX ( TOPN ( 1, CleanTable, DimDate[date], ASC ), [__Value] )\nVAR LastValue = MAXX ( TOPN ( 1, CleanTable, DimDate[date], DESC ), [__Value] )\nVAR FirstY =\n    IF (\n        MaxValue = MinValue,\n        70,\n        96 - DIVIDE ( FirstValue - MinValue, MaxValue - MinValue, 0.5 ) * 52\n    )\nVAR LastY =\n    IF (\n        MaxValue = MinValue,\n        70,\n        96 - DIVIDE ( LastValue - MinValue, MaxValue - MinValue, 0.5 ) * 52\n    )\nVAR LinePoints =\n    CONCATENATEX (\n        CleanTable,\n        VAR RankValue = RANKX ( CleanTable, DimDate[date], , ASC, DENSE ) - 1\n        VAR XValue = 172 + DIVIDE ( RankValue, MAX ( 1, RowCount - 1 ), 0 ) * 102\n        VAR YRatio =\n            IF (\n                MaxValue = MinValue,\n                0.5,\n                DIVIDE ( [__Value] - MinValue, MaxValue - MinValue, 0.5 )\n            )\n        VAR YValue = 96 - YRatio * 52\n        RETURN FORMAT ( XValue, \"0.0\", \"en-US\" ) & \",\" & FORMAT ( YValue, \"0.0\", \"en-US\" ),\n        \" \",\n        DimDate[date],\n        ASC\n    )\nVAR AreaPoints = \"172,106 \" & LinePoints & \" 274,106\"\nVAR ValueText = SUBSTITUTE ( SUBSTITUTE ( FORMAT ( CurrentValue, \"0.0%\" ), \"%\", \"%25\" ), \"&\", \"and\" )\nVAR PyText = SUBSTITUTE ( SUBSTITUTE ( FORMAT ( PriorValue, \"0.0%\" ), \"%\", \"%25\" ), \"&\", \"and\" )\nVAR DeltaText = SUBSTITUTE ( SUBSTITUTE ( FORMAT ( DeltaPoints, \"+0.0pt;-0.0pt;0.0pt\" ), \"%\", \"%25\" ), \"&\", \"and\" )\nVAR Sparkline =\n    IF (\n        RowCount >= 2,\n        \"<g clip-path='url(%23sparkClip)'><polygon points='\" & AreaPoints & \"' fill='\" & TrendColor & \"' fill-opacity='0.26'/>\"\n            & \"<polyline points='\" & LinePoints & \"' fill='none' stroke='\" & TrendColor & \"' stroke-width='4.0' stroke-linecap='round' stroke-linejoin='round'/></g>\"\n            & \"<circle cx='172' cy='\" & FORMAT ( FirstY, \"0.0\", \"en-US\" ) & \"' r='4.4' fill='%231F2630' stroke='%23B9C3CF' stroke-width='1.45'/>\"\n            & \"<circle cx='274' cy='\" & FORMAT ( LastY, \"0.0\", \"en-US\" ) & \"' r='5.6' fill='\" & TrendColor & \"'/>\",\n        \"<line x1='172' y1='70' x2='274' y2='70' stroke='%23313B48' stroke-width='4.0' stroke-linecap='round'/>\"\n    )\nVAR SVG =\n    \"<svg xmlns='http://www.w3.org/2000/svg' width='296' height='135' viewBox='0 0 296 135'>\"\n    & \"<defs><clipPath id='sparkClip'><rect x='170' y='43' width='106' height='64' rx='5'/></clipPath></defs>\"\n    & \"<rect x='1.2' y='1.2' width='293.6' height='132.6' rx='12' fill='%23242B35' stroke='%233A4655' stroke-width='1.05'/>\"\n    & \"<rect x='13' y='13' width='150' height='4.5' rx='2.25' fill='%23A8894B'/>\"\n    & \"<rect x='13' y='31' width='16' height='16' rx='4.2' fill='%23A8894B' fill-opacity='0.22' stroke='%23A8894B' stroke-width='1.15'/>\"\n    & \"<text x='38' y='45' font-family='Segoe UI Semibold' font-size='13.0' fill='%23F7FAFC' letter-spacing='0'>Forecast Accuracy</text>\"\n    & \"<text x='13' y='98' font-family='Segoe UI Semibold' font-size='38' fill='%23A8894B' letter-spacing='0'>\" & ValueText & \"</text>\"\n    & \"<rect x='162' y='32' width='120' height='82' rx='9' fill='%231F2630' stroke='%233A4655' stroke-width='1.0'/>\"\n    & \"<rect x='170' y='43' width='106' height='64' rx='5.5' fill='%23A8894B' fill-opacity='0.13'/>\"\n    & \"<line x1='170' y1='73' x2='276' y2='73' stroke='%23313B48' stroke-width='1.4' stroke-dasharray='4 5'/>\"\n    & Sparkline\n    & \"<rect x='13' y='110' width='94' height='20' rx='9' fill='%232C3440' stroke='%233A4655' stroke-width='0.75'/>\"\n    & \"<text x='23' y='124' font-family='Segoe UI Semibold' font-size='10.5' fill='%23B9C3CF'>PY \" & PyText & \"</text>\"\n    & \"<rect x='113' y='110' width='76' height='20' rx='9' fill='\" & StatusColor & \"' fill-opacity='0.16' stroke='\" & StatusColor & \"' stroke-opacity='0.18'/>\"\n    & \"<text x='151' y='124' text-anchor='middle' font-family='Segoe UI Semibold' font-size='10.5' fill='\" & StatusColor & \"'>\" & DeltaText & \"</text>\"\n    & \"<rect x='195' y='110' width='87' height='20' rx='9' fill='\" & StatusColor & \"' fill-opacity='0.11'/>\"\n    & \"<text x='238.5' y='124' text-anchor='middle' font-family='Segoe UI Semibold' font-size='10.2' fill='\" & StatusColor & \"'>\" & StatusText & \"</text>\"\n    & \"</svg>\"\nRETURN\n    \"data:image/svg+xml;utf8,\" & SVG",
            "formatString": "",
            "description": "SVG KPI card for forecast accuracy with prior-year point delta and sparkline.",
            "dataCategory": "ImageUrl"
          },
          {
            "name": "Lens Summary SVG",
            "expression": "VAR PeriodText = [Selected Latest Complete Period Label]\nVAR RegionRaw =\n    IF ( ISFILTERED ( DimEntity[region] ), CONCATENATEX ( VALUES ( DimEntity[region] ), DimEntity[region], \", \" ), \"All regions\" )\nVAR BURaw =\n    IF ( ISFILTERED ( DimBusinessUnit[business_unit] ), CONCATENATEX ( VALUES ( DimBusinessUnit[business_unit] ), DimBusinessUnit[business_unit], \", \" ), \"All BUs\" )\nVAR ScenarioRaw =\n    IF ( ISFILTERED ( DimScenario[scenario] ), CONCATENATEX ( VALUES ( DimScenario[scenario] ), DimScenario[scenario], \", \" ), \"Actual lens\" )\nVAR ScenarioText = SUBSTITUTE ( LEFT ( ScenarioRaw, 20 ), \"&\", \"and\" )\nVAR RegionText = SUBSTITUTE ( LEFT ( RegionRaw, 24 ), \"&\", \"and\" )\nVAR BUText = SUBSTITUTE ( LEFT ( BURaw, 28 ), \"&\", \"and\" )\nVAR RevVar = [Latest Revenue Var %]\nVAR EbitdaVar = [Latest EBITDA Var %]\nVAR RiskValue = COALESCE ( [Latest Open Exception Value], 0 )\nVAR RevText = SUBSTITUTE ( FORMAT ( RevVar, \"+0.0%;-0.0%;0.0%\" ), \"%\", \"%25\" )\nVAR StatusColor = IF ( EbitdaVar >= 0.02, \"%232B6F75\", IF ( EbitdaVar >= -0.02, \"%23A8894B\", \"%23B85A72\" ) )\nVAR Line1 = SUBSTITUTE ( LEFT ( PeriodText & \" | \" & ScenarioText, 38 ), \"&\", \"and\" )\nVAR Line2 = SUBSTITUTE ( LEFT ( BUText & \" | \" & RegionText, 48 ), \"&\", \"and\" )\nVAR RiskText = \"$\" & FORMAT ( DIVIDE ( RiskValue, 1000000 ), \"0.0M\" )\nVAR SVG =\n    \"<svg xmlns='http://www.w3.org/2000/svg' width='568' height='78' viewBox='0 0 568 78'>\"\n    & \"<rect x='18' y='14' width='5' height='50' rx='2.5' fill='%232B6F75'/>\"\n    & \"<circle cx='46' cy='27' r='7.4' fill='\" & StatusColor & \"'/>\"\n    & \"<text x='64' y='28' font-family='Segoe UI Semibold' font-size='14.0' fill='%23F7FAFC'>CURRENT LENS</text>\"\n    & \"<text x='64' y='50' font-family='Segoe UI Semibold' font-size='13.1' fill='%23F7FAFC'>\" & Line1 & \"</text>\"\n    & \"<text x='64' y='66' font-family='Segoe UI' font-size='12.2' fill='%23C7D0DB'>\" & Line2 & \"</text>\"\n    & \"<rect x='244' y='10' width='154' height='58' rx='11' fill='%231F2630' stroke='%233A4655' stroke-width='1.05'/>\"\n    & \"<text x='321' y='30' text-anchor='middle' font-family='Segoe UI' font-size='11.2' fill='%23C7D0DB'>Revenue var</text>\"\n    & \"<text x='321' y='57' text-anchor='middle' font-family='Segoe UI Semibold' font-size='22.0' fill='%232F5F9E'>\" & RevText & \"</text>\"\n    & \"<rect x='410' y='10' width='144' height='58' rx='11' fill='%231F2630' stroke='%233A4655' stroke-width='1.05'/>\"\n    & \"<text x='482' y='30' text-anchor='middle' font-family='Segoe UI' font-size='11.2' fill='%23C7D0DB'>Close risk</text>\"\n    & \"<text x='482' y='57' text-anchor='middle' font-family='Segoe UI Semibold' font-size='22.0' fill='%23A8894B'>\" & RiskText & \"</text>\"\n    & \"</svg>\"\nRETURN\n    \"data:image/svg+xml;utf8,\" & SVG",
            "formatString": "",
            "description": "Top-bar Current Lens SVG for selected period, region, BU, revenue variance, and close-risk exposure.",
            "dataCategory": "ImageUrl"
          }
        ]
      }
    ],
    "relationships": [
