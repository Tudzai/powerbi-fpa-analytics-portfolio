          {
            "name": "Gross Revenue KPI Card SVG",
            "expression": "VAR d = [Selected Latest Complete Date]\nVAR LatestIdx =\n    CALCULATE ( MAX ( DimDate[month_index] ), REMOVEFILTERS ( DimDate ), DimDate[date] = d )\nVAR CurrentValue =\n    CALCULATE ( [Gross Revenue], REMOVEFILTERS ( DimDate ), DimDate[date] = d )\nVAR PriorDate = EDATE ( d, -12 )\nVAR PriorValue =\n    CALCULATE ( [Gross Revenue], REMOVEFILTERS ( DimDate ), DimDate[date] = PriorDate )\nVAR BudgetValue = BLANK ()\nVAR ChangePct = DIVIDE ( CurrentValue - PriorValue, ABS ( PriorValue ) )\nVAR DeltaPoints = ( CurrentValue - PriorValue ) * 100\nVAR StatusBasis =\n    IF (\n        NOT ISBLANK ( BudgetValue ),\n        DIVIDE ( CurrentValue - BudgetValue, ABS ( BudgetValue ) ),\n        ChangePct\n    )\nVAR StatusColor =\n    IF ( StatusBasis >= 0.02, \"%236F8552\", IF ( StatusBasis >= -0.02, \"%23A8894B\", \"%23B85A72\" ) )\nVAR StatusText =\n    IF ( StatusBasis >= 0.02, \"ON TRACK\", IF ( StatusBasis >= -0.02, \"WATCH\", \"ACTION\" ) )\nVAR TrendColor =\n    IF ( CurrentValue >= PriorValue, \"%236F8552\", \"%23B85A72\" )\nVAR MonthTable =\n    ADDCOLUMNS (\n        FILTER (\n            ALL ( DimDate ),\n            DimDate[date] <= d\n                && DimDate[month_index] >= LatestIdx - 11\n        ),\n        \"__Value\", CALCULATE ( [Gross Revenue] )\n    )\nVAR CleanTable = FILTER ( MonthTable, NOT ISBLANK ( [__Value] ) )\nVAR RowCount = COUNTROWS ( CleanTable )\nVAR MinValue = MINX ( CleanTable, [__Value] )\nVAR MaxValue = MAXX ( CleanTable, [__Value] )\nVAR FirstValue = MINX ( TOPN ( 1, CleanTable, DimDate[date], ASC ), [__Value] )\nVAR LastValue = MAXX ( TOPN ( 1, CleanTable, DimDate[date], DESC ), [__Value] )\nVAR FirstY =\n    IF (\n        MaxValue = MinValue,\n        52,\n        74 - DIVIDE ( FirstValue - MinValue, MaxValue - MinValue, 0.5 ) * 38\n    )\nVAR LastY =\n    IF (\n        MaxValue = MinValue,\n        52,\n        74 - DIVIDE ( LastValue - MinValue, MaxValue - MinValue, 0.5 ) * 38\n    )\nVAR LinePoints =\n    CONCATENATEX (\n        CleanTable,\n        VAR RankValue = RANKX ( CleanTable, DimDate[date], , ASC, DENSE ) - 1\n        VAR XValue = 164 + DIVIDE ( RankValue, MAX ( 1, RowCount - 1 ), 0 ) * 100\n        VAR YRatio =\n            IF (\n                MaxValue = MinValue,\n                0.5,\n                DIVIDE ( [__Value] - MinValue, MaxValue - MinValue, 0.5 )\n            )\n        VAR YValue = 74 - YRatio * 38\n        RETURN FORMAT ( XValue, \"0.0\", \"en-US\" ) & \",\" & FORMAT ( YValue, \"0.0\", \"en-US\" ),\n        \" \",\n        DimDate[date],\n        ASC\n    )\nVAR ValueText = SUBSTITUTE ( SUBSTITUTE ( FORMAT ( DIVIDE ( CurrentValue, 1000000 ), \"$0.0M;($0.0M);$0.0M\" ), \"%\", \"%25\" ), \"&\", \"and\" )\nVAR PyText = SUBSTITUTE ( SUBSTITUTE ( FORMAT ( DIVIDE ( PriorValue, 1000000 ), \"$0.0M;($0.0M);$0.0M\" ), \"%\", \"%25\" ), \"&\", \"and\" )\nVAR DeltaText = SUBSTITUTE ( SUBSTITUTE ( FORMAT ( ChangePct, \"+0.0%;-0.0%;0.0%\" ), \"%\", \"%25\" ), \"&\", \"and\" )\nVAR Sparkline =\n    IF (\n        RowCount >= 2,\n        \"<polyline points='\" & LinePoints & \"' fill='none' stroke='\" & TrendColor & \"' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'/>\"\n            & \"<circle cx='164' cy='\" & FORMAT ( FirstY, \"0.0\", \"en-US\" ) & \"' r='3.2' fill='%23FFFFFF' stroke='%23526173' stroke-width='1.2'/>\"\n            & \"<circle cx='264' cy='\" & FORMAT ( LastY, \"0.0\", \"en-US\" ) & \"' r='4.2' fill='\" & TrendColor & \"'/>\",\n        \"<line x1='164' y1='56' x2='264' y2='56' stroke='%23E6ECF2' stroke-width='3' stroke-linecap='round'/>\"\n    )\nVAR SVG =\n    \"<svg xmlns='http://www.w3.org/2000/svg' width='292' height='104' viewBox='0 0 292 104'>\"\n    & \"<rect x='1' y='1' width='290' height='102' rx='7' fill='%23FFFFFF' stroke='%23D5DEE8'/>\"\n    & \"<rect x='1' y='1' width='290' height='4' rx='2' fill='%232F5F9E'/>\"\n    & \"<text x='16' y='24' font-family='Segoe UI Semibold' font-size='10.5' fill='%23526173'>Gross Revenue</text>\"\n    & \"<text x='16' y='54' font-family='Segoe UI Semibold' font-size='25' fill='%230F172A'>\" & ValueText & \"</text>\"\n    & \"<rect x='160' y='34' width='108' height='44' rx='8' fill='%23F8FAFC'/>\"\n    & \"<line x1='166' y1='56' x2='264' y2='56' stroke='%23E6ECF2' stroke-width='1' stroke-dasharray='3 5'/>\"\n    & Sparkline\n    & \"<rect x='16' y='72' width='76' height='18' rx='9' fill='%23F8FAFC' stroke='%23D5DEE8'/>\"\n    & \"<text x='26' y='85' font-family='Segoe UI' font-size='8.2' fill='%23526173'>PY \" & PyText & \"</text>\"\n    & \"<rect x='98' y='72' width='56' height='18' rx='9' fill='\" & StatusColor & \"' fill-opacity='0.14'/>\"\n    & \"<text x='108' y='85' font-family='Segoe UI Semibold' font-size='8.2' fill='\" & StatusColor & \"'>\" & DeltaText & \"</text>\"\n    & \"<text x='190' y='91' font-family='Segoe UI Semibold' font-size='8' fill='\" & StatusColor & \"'>\" & StatusText & \"</text>\"\n    & \"</svg>\"\nRETURN\n    \"data:image/svg+xml;utf8,\" & SVG",
