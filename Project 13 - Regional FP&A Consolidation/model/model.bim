            "sourceColumn": "rate_to_usd",
            "summarizeBy": "none"
          }
        ],
        "partitions": [
          {
            "name": "FactFXRate-Import",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Csv.Document(File.Contents(\"<PROJECT_ROOT>/data/prepared/fact_fx_rate.csv\"), [Delimiter=\",\", Encoding=65001, QuoteStyle=QuoteStyle.Csv]),",
                "    PromotedHeaders = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),",
                "    TypedColumns = Table.TransformColumnTypes(PromotedHeaders, {",
                "        {\"date_id\", type text},\n        {\"currency\", type text},\n        {\"to_currency\", type text},\n        {\"rate_type\", type text},\n        {\"rate_to_usd\", type number}",
                "    }, \"en-US\")",
                "in",
                "    TypedColumns"
              ]
            }
          }
        ]
      },
      {
        "name": "KPI Measures",
        "columns": [
          {
            "name": "Measure Group",
            "dataType": "string",
            "sourceColumn": "Measure Group",
            "isHidden": true,
            "summarizeBy": "none"
          }
        ],
        "partitions": [
          {
            "name": "KPI Measures-Import",
            "mode": "import",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = #table(type table [Measure Group = text], {{\"Regional FP&A Consolidation\"}})",
                "in",
                "    Source"
              ]
            }
          }
        ],
        "measures": [
          {
            "name": "Total Revenue",
            "expression": "SUM ( FactFinancialSummary[external_revenue_usd] )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Consolidated external revenue after excluding intercompany revenue."
          },
          {
            "name": "Gross Revenue",
            "expression": "SUM ( FactFinancialSummary[gross_revenue_usd] )",
            "formatString": "$#,0;($#,0);$0",
            "description": "External plus intercompany revenue before elimination."
          },
          {
            "name": "Intercompany Revenue",
            "expression": "SUM ( FactFinancialSummary[intercompany_revenue_usd] )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Intercompany revenue requiring elimination."
          },
          {
            "name": "Intercompany Elimination",
            "expression": "SUM ( FactFinancialSummary[intercompany_elimination_usd] )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Net intercompany elimination impact."
          },
          {
            "name": "Gross Profit",
            "expression": "SUM ( FactFinancialSummary[gross_profit_usd] )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Revenue minus cost of services."
          },
          {
            "name": "Gross Margin %",
            "expression": "DIVIDE ( [Gross Profit], [Total Revenue] )",
            "formatString": "0.0%",
            "description": "Gross profit divided by consolidated external revenue."
          },
          {
            "name": "OPEX",
            "expression": "SUM ( FactFinancialSummary[opex_usd] )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Personnel, facilities, sales and marketing, and G&A."
          },
          {
            "name": "EBITDA",
            "expression": "SUM ( FactFinancialSummary[ebitda_usd] )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Gross profit plus OPEX after intercompany elimination."
          },
          {
            "name": "EBITDA Margin %",
            "expression": "DIVIDE ( [EBITDA], [Total Revenue] )",
            "formatString": "0.0%",
            "description": "EBITDA divided by consolidated external revenue."
          },
          {
            "name": "Operating Income",
            "expression": "SUM ( FactFinancialSummary[operating_income_usd] )",
            "formatString": "$#,0;($#,0);$0",
            "description": "EBITDA less depreciation."
          },
          {
            "name": "Net Income",
            "expression": "SUM ( FactFinancialSummary[net_income_usd] )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Operating income less interest and tax."
          },
          {
            "name": "Cash Position",
            "expression": "SUM ( FactFinancialSummary[cash_position_usd] )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Period-end cash position by entity and BU allocation."
          },
          {
            "name": "Operating Cash Flow",
            "expression": "SUM ( FactFinancialSummary[operating_cash_flow_usd] )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Operating cash flow proxy tied to EBITDA conversion."
          },
          {
            "name": "Working Capital",
            "expression": "SUM ( FactFinancialSummary[working_capital_usd] )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Working capital proxy for close review."
          },
          {
            "name": "Actual Revenue",
            "expression": "CALCULATE ( [Total Revenue], DimScenario[scenario] = \"Actual\" )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Actual consolidated revenue."
          },
          {
            "name": "Budget Revenue",
            "expression": "CALCULATE ( [Total Revenue], DimScenario[scenario] = \"Budget\" )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Budget consolidated revenue."
          },
          {
            "name": "Revenue Var vs Budget",
            "expression": "[Actual Revenue] - [Budget Revenue]",
            "formatString": "$#,0;($#,0);$0",
            "description": "Actual revenue less budget revenue."
          },
          {
            "name": "Revenue Var %",
            "expression": "DIVIDE ( [Revenue Var vs Budget], [Budget Revenue] )",
            "formatString": "0.0%",
            "description": "Revenue variance divided by budget revenue."
          },
          {
            "name": "Actual EBITDA",
            "expression": "CALCULATE ( [EBITDA], DimScenario[scenario] = \"Actual\" )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Actual EBITDA."
          },
          {
            "name": "Budget EBITDA",
            "expression": "CALCULATE ( [EBITDA], DimScenario[scenario] = \"Budget\" )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Budget EBITDA."
          },
          {
            "name": "EBITDA Var vs Budget",
            "expression": "[Actual EBITDA] - [Budget EBITDA]",
            "formatString": "$#,0;($#,0);$0",
            "description": "Actual EBITDA less budget EBITDA."
          },
          {
            "name": "EBITDA Var %",
            "expression": "DIVIDE ( [EBITDA Var vs Budget], [Budget EBITDA] )",
            "formatString": "0.0%",
            "description": "EBITDA variance divided by budget EBITDA."
          },
          {
            "name": "Forecast EBITDA",
            "expression": "CALCULATE ( [EBITDA], DimScenario[scenario] = \"Forecast\" )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Forecast EBITDA."
          },
          {
            "name": "Forecast Accuracy %",
            "expression": "1 - ABS ( DIVIDE ( [Actual EBITDA] - [Forecast EBITDA], [Actual EBITDA] ) )",
            "formatString": "0.0%",
            "description": "Directional forecast accuracy for EBITDA."
          },
          {
            "name": "Open Exception Count",
            "expression": "CALCULATE ( COUNTROWS ( FactCloseExceptions ), FactCloseExceptions[status] <> \"Closed\" )",
            "formatString": "#,0",
            "description": "Open or in-progress close exceptions."
          },
          {
            "name": "Open Exception Value",
            "expression": "CALCULATE ( SUM ( FactCloseExceptions[amount_usd] ), FactCloseExceptions[status] <> \"Closed\" )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Value attached to unresolved close exceptions."
          },
          {
            "name": "Selected Latest Complete Date",
            "expression": "VAR GlobalLatestComplete =\n    CALCULATE (\n        MAX ( DimDate[date] ),\n        REMOVEFILTERS ( DimDate ),\n        DimDate[is_latest_complete] = TRUE ()\n    )\nVAR SelectedLatest =\n    MAXX (\n        FILTER ( ALLSELECTED ( DimDate ), DimDate[date] <= GlobalLatestComplete ),\n        DimDate[date]\n    )\nRETURN\n    COALESCE ( SelectedLatest, GlobalLatestComplete )",
            "formatString": "mmm yyyy",
            "description": "Latest complete date within the selected date context, capped to the global closed period."
          },
          {
            "name": "Selected Latest Complete Period Label",
            "expression": "FORMAT ( [Selected Latest Complete Date], \"MMM yyyy\" )",
            "formatString": "",
            "description": "Display label for the selected latest complete month."
          },
          {
            "name": "Bridge Amount",
            "expression": "SUM ( FactVarianceDriverBridge[amount_usd] )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Variance-driver bridge amount with explicit aggregation for native Power BI visuals."
          },
          {
            "name": "Latest Bridge Amount",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [Bridge Amount], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Variance-driver bridge amount at selected latest complete period."
          },
          {
            "name": "Exception Amount",
            "expression": "SUM ( FactCloseExceptions[amount_usd] )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Close-exception exposure with explicit aggregation for native Power BI visuals."
          },
          {
            "name": "Latest Exception Amount",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [Exception Amount], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Close-exception exposure at selected latest complete period."
          },
          {
            "name": "Financial Amount",
            "expression": "SUM ( FactFinancials[amount_usd] )",
            "formatString": "$#,0;($#,0);$0",
            "description": "P&L statement amount with explicit aggregation for native Power BI visuals."
          },
          {
            "name": "Latest Actual Revenue",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [Actual Revenue], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Actual revenue at selected latest complete period."
          },
          {
            "name": "Latest Budget Revenue",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [Budget Revenue], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Budget revenue at selected latest complete period."
          },
          {
            "name": "Latest Revenue Var vs Budget",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [Revenue Var vs Budget], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Revenue variance at selected latest complete period."
          },
          {
            "name": "Latest Revenue Var %",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [Revenue Var %], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "0.0%",
            "description": "Revenue variance percent at selected latest complete period."
          },
          {
            "name": "Latest Actual EBITDA",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [Actual EBITDA], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Actual EBITDA at selected latest complete period."
          },
          {
            "name": "Latest Budget EBITDA",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [Budget EBITDA], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Budget EBITDA at selected latest complete period."
          },
          {
            "name": "Latest EBITDA Var vs Budget",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [EBITDA Var vs Budget], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0;($#,0);$0",
            "description": "EBITDA variance at selected latest complete period."
          },
          {
            "name": "Latest EBITDA Var %",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [EBITDA Var %], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "0.0%",
            "description": "EBITDA variance percent at selected latest complete period."
          },
          {
            "name": "Latest Gross Revenue",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [Gross Revenue], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Gross revenue at selected latest complete period."
          },
          {
            "name": "Latest Gross Profit",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [Gross Profit], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Gross profit at selected latest complete period."
          },
          {
            "name": "Latest Gross Margin %",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [Gross Margin %], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "0.0%",
            "description": "Gross margin at selected latest complete period."
          },
          {
            "name": "Latest OPEX",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [OPEX], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0;($#,0);$0",
            "description": "OPEX at selected latest complete period."
          },
          {
            "name": "Latest Net Income",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [Net Income], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Net income at selected latest complete period."
          },
          {
            "name": "Latest EBITDA Margin %",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [EBITDA Margin %], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "0.0%",
            "description": "EBITDA margin at selected latest complete period."
          },
          {
            "name": "Latest Cash Position",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [Cash Position], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Cash position at selected latest complete period."
          },
          {
            "name": "Latest Operating Cash Flow",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [Operating Cash Flow], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Operating cash flow at selected latest complete period."
          },
          {
            "name": "Latest Forecast Accuracy %",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [Forecast Accuracy %], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "0.0%",
            "description": "Forecast accuracy at selected latest complete period."
          },
          {
            "name": "Latest Intercompany Revenue",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [Intercompany Revenue], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Intercompany revenue at selected latest complete period."
          },
          {
            "name": "Latest Intercompany Elimination",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [Intercompany Elimination], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Intercompany elimination impact at selected latest complete period."
          },
          {
            "name": "Latest Open Exception Count",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [Open Exception Count], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "#,0",
            "description": "Open close-exception count at selected latest complete period."
          },
          {
            "name": "Latest Open Exception Value",
            "expression": "VAR d = [Selected Latest Complete Date]\nRETURN\n    CALCULATE ( [Open Exception Value], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Open close-exception exposure at selected latest complete period."
          },
          {
            "name": "Display Actual Revenue",
            "expression": "FORMAT ( DIVIDE ( [Latest Actual Revenue], 1000000 ), \"$0.0M;($0.0M);$0.0M\" )",
            "formatString": "",
            "description": "Text display for latest revenue KPI card."
          },
          {
            "name": "Display Actual EBITDA",
            "expression": "FORMAT ( DIVIDE ( [Latest Actual EBITDA], 1000000 ), \"$0.0M;($0.0M);$0.0M\" )",
            "formatString": "",
            "description": "Text display for latest EBITDA KPI card."
          },
          {
            "name": "Display EBITDA Margin %",
            "expression": "FORMAT ( [Latest EBITDA Margin %], \"0.0%\" )",
            "formatString": "",
            "description": "Text display for latest EBITDA margin KPI card."
          },
          {
            "name": "Display Gross Revenue",
            "expression": "FORMAT ( DIVIDE ( [Latest Gross Revenue], 1000000 ), \"$0.0M;($0.0M);$0.0M\" )",
            "formatString": "",
            "description": "Text display for latest gross revenue KPI card."
          },
          {
            "name": "Display Gross Profit",
            "expression": "FORMAT ( DIVIDE ( [Latest Gross Profit], 1000000 ), \"$0.0M;($0.0M);$0.0M\" )",
            "formatString": "",
            "description": "Text display for latest gross profit KPI card."
          },
          {
            "name": "Display OPEX",
            "expression": "FORMAT ( DIVIDE ( [Latest OPEX], 1000000 ), \"$0.0M;($0.0M);$0.0M\" )",
            "formatString": "",
            "description": "Text display for latest OPEX KPI card."
          },
          {
            "name": "Display Net Income",
            "expression": "FORMAT ( DIVIDE ( [Latest Net Income], 1000000 ), \"$0.0M;($0.0M);$0.0M\" )",
            "formatString": "",
            "description": "Text display for latest net income KPI card."
          },
          {
            "name": "Display Intercompany Revenue",
            "expression": "FORMAT ( DIVIDE ( [Latest Intercompany Revenue], 1000000 ), \"$0.0M;($0.0M);$0.0M\" )",
            "formatString": "",
            "description": "Text display for latest intercompany revenue KPI card."
          },
          {
            "name": "Display Intercompany Elimination",
            "expression": "FORMAT ( DIVIDE ( [Latest Intercompany Elimination], 1000000 ), \"$0.0M;($0.0M);$0.0M\" )",
            "formatString": "",
            "description": "Text display for latest intercompany elimination KPI card."
          },
          {
            "name": "Display Forecast Accuracy %",
            "expression": "FORMAT ( [Latest Forecast Accuracy %], \"0.0%\" )",
            "formatString": "",
            "description": "Text display for latest forecast accuracy KPI card."
          },
          {
            "name": "Display Open Exception Value",
            "expression": "FORMAT ( DIVIDE ( [Latest Open Exception Value], 1000000 ), \"$0.0M;($0.0M);$0.0M\" )",
            "formatString": "",
            "description": "Text display for latest close-risk KPI card."
          },
          {
            "name": "Display Open Exception Count",
            "expression": "FORMAT ( [Latest Open Exception Count], \"#,0\" )",
            "formatString": "",
            "description": "Text display for latest close-exception count chip."
          },
          {
            "name": "Display Revenue PY",
            "expression": "FORMAT ( DIVIDE ( [Revenue PY], 1000000 ), \"$0.0M;($0.0M);$0.0M\" )",
            "formatString": "",
            "description": "Text display for prior-year revenue."
          },
          {
            "name": "Display EBITDA PY",
            "expression": "FORMAT ( DIVIDE ( [EBITDA PY], 1000000 ), \"$0.0M;($0.0M);$0.0M\" )",
            "formatString": "",
            "description": "Text display for prior-year EBITDA."
          },
          {
            "name": "Display Open Exception Value PY",
            "expression": "FORMAT ( DIVIDE ( [Open Exception Value PY], 1000000 ), \"$0.0M;($0.0M);$0.0M\" )",
            "formatString": "",
            "description": "Text display for prior-year open exception value."
          },
          {
            "name": "Display Revenue Var %",
            "expression": "FORMAT ( [Latest Revenue Var %], \"+0.0%;-0.0%;0.0%\" )",
            "formatString": "",
            "description": "Text display for latest revenue variance percent."
          },
          {
            "name": "Display EBITDA Var %",
            "expression": "FORMAT ( [Latest EBITDA Var %], \"+0.0%;-0.0%;0.0%\" )",
            "formatString": "",
            "description": "Text display for latest EBITDA variance percent."
          },
          {
            "name": "Display Forecast Accuracy Delta",
            "expression": "FORMAT ( [Latest Forecast Accuracy %], \"0.0%\" )",
            "formatString": "",
            "description": "Text display for latest forecast accuracy footer."
          },
          {
            "name": "Current Lens Line 1",
            "expression": "VAR ScenarioRaw =\n    IF ( ISFILTERED ( DimScenario[scenario] ), CONCATENATEX ( VALUES ( DimScenario[scenario] ), DimScenario[scenario], \", \" ), \"Actual lens\" )\nRETURN\n    [Selected Latest Complete Period Label] & \" | \" & LEFT ( ScenarioRaw, 24 )",
            "formatString": "",
            "description": "First dynamic line for the Current Lens native panel."
          },
          {
            "name": "Current Lens Line 2",
            "expression": "VAR RegionRaw =\n    IF ( ISFILTERED ( DimEntity[region] ), CONCATENATEX ( VALUES ( DimEntity[region] ), DimEntity[region], \", \" ), \"All regions\" )\nVAR BURaw =\n    IF ( ISFILTERED ( DimBusinessUnit[business_unit] ), CONCATENATEX ( VALUES ( DimBusinessUnit[business_unit] ), DimBusinessUnit[business_unit], \", \" ), \"All BUs\" )\nRETURN\n    LEFT ( BURaw, 28 ) & \" | \" & LEFT ( RegionRaw, 28 )",
            "formatString": "",
            "description": "Second dynamic line for the Current Lens native panel."
          },
          {
            "name": "Revenue PY",
            "expression": "VAR d = EDATE ( [Selected Latest Complete Date], -12 )\nRETURN\n    CALCULATE ( [Actual Revenue], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Actual revenue for the same month in the prior year."
          },
          {
            "name": "EBITDA PY",
            "expression": "VAR d = EDATE ( [Selected Latest Complete Date], -12 )\nRETURN\n    CALCULATE ( [Actual EBITDA], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Actual EBITDA for the same month in the prior year."
          },
          {
            "name": "Gross Margin PY %",
            "expression": "VAR d = EDATE ( [Selected Latest Complete Date], -12 )\nRETURN\n    CALCULATE ( [Gross Margin %], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "0.0%",
            "description": "Gross margin for the same month in the prior year."
          },
          {
            "name": "Cash Position PY",
            "expression": "VAR d = EDATE ( [Selected Latest Complete Date], -12 )\nRETURN\n    CALCULATE ( [Cash Position], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Cash position for the same month in the prior year."
          },
          {
            "name": "Open Exception Value PY",
            "expression": "VAR d = EDATE ( [Selected Latest Complete Date], -12 )\nRETURN\n    CALCULATE ( [Open Exception Value], REMOVEFILTERS ( DimDate ), DimDate[date] = d )",
            "formatString": "$#,0;($#,0);$0",
            "description": "Open exception value for the same month in the prior year."
          },
          {
            "name": "Revenue KPI Card SVG",
            "expression": "VAR d = [Selected Latest Complete Date]\nVAR LatestIdx =\n    CALCULATE ( MAX ( DimDate[month_index] ), REMOVEFILTERS ( DimDate ), DimDate[date] = d )\nVAR CurrentValue =\n    COALESCE ( CALCULATE ( [Actual Revenue], REMOVEFILTERS ( DimDate ), DimDate[date] = d ), 0 )\nVAR PriorDate = EDATE ( d, -12 )\nVAR PriorValue =\n    COALESCE ( CALCULATE ( [Actual Revenue], REMOVEFILTERS ( DimDate ), DimDate[date] = PriorDate ), 0 )\nVAR BudgetValue = CALCULATE ( [Budget Revenue], REMOVEFILTERS ( DimDate ), DimDate[date] = d )\nVAR ChangePct = DIVIDE ( CurrentValue - PriorValue, ABS ( PriorValue ) )\nVAR DeltaPoints = ( CurrentValue - PriorValue ) * 100\nVAR StatusBasis =\n    IF (\n        NOT ISBLANK ( BudgetValue ),\n        DIVIDE ( CurrentValue - BudgetValue, ABS ( BudgetValue ) ),\n        ChangePct\n    )\nVAR StatusColor =\n    IF ( StatusBasis >= 0.02, \"%236F8552\", IF ( StatusBasis >= -0.02, \"%23A8894B\", \"%23B85A72\" ) )\nVAR StatusText =\n    IF ( StatusBasis >= 0.02, \"ON TRACK\", IF ( StatusBasis >= -0.02, \"WATCH\", \"ACTION\" ) )\nVAR TrendColor =\n    IF ( CurrentValue >= PriorValue, \"%236F8552\", \"%23B85A72\" )\nVAR MonthTable =\n    ADDCOLUMNS (\n        FILTER (\n            ALL ( DimDate ),\n            DimDate[date] <= d\n                && DimDate[month_index] >= LatestIdx - 11\n        ),\n        \"__Value\", CALCULATE ( [Actual Revenue] )\n    )\nVAR CleanTable = FILTER ( MonthTable, NOT ISBLANK ( [__Value] ) )\nVAR RowCount = COUNTROWS ( CleanTable )\nVAR MinValue = MINX ( CleanTable, [__Value] )\nVAR MaxValue = MAXX ( CleanTable, [__Value] )\nVAR FirstValue = MINX ( TOPN ( 1, CleanTable, DimDate[date], ASC ), [__Value] )\nVAR LastValue = MAXX ( TOPN ( 1, CleanTable, DimDate[date], DESC ), [__Value] )\nVAR FirstY =\n    IF (\n        MaxValue = MinValue,\n        70,\n        96 - DIVIDE ( FirstValue - MinValue, MaxValue - MinValue, 0.5 ) * 52\n    )\nVAR LastY =\n    IF (\n        MaxValue = MinValue,\n        70,\n        96 - DIVIDE ( LastValue - MinValue, MaxValue - MinValue, 0.5 ) * 52\n    )\nVAR LinePoints =\n    CONCATENATEX (\n        CleanTable,\n        VAR RankValue = RANKX ( CleanTable, DimDate[date], , ASC, DENSE ) - 1\n        VAR XValue = 172 + DIVIDE ( RankValue, MAX ( 1, RowCount - 1 ), 0 ) * 102\n        VAR YRatio =\n            IF (\n                MaxValue = MinValue,\n                0.5,\n                DIVIDE ( [__Value] - MinValue, MaxValue - MinValue, 0.5 )\n            )\n        VAR YValue = 96 - YRatio * 52\n        RETURN FORMAT ( XValue, \"0.0\", \"en-US\" ) & \",\" & FORMAT ( YValue, \"0.0\", \"en-US\" ),\n        \" \",\n        DimDate[date],\n        ASC\n    )\nVAR AreaPoints = \"172,106 \" & LinePoints & \" 274,106\"\nVAR ValueText = SUBSTITUTE ( SUBSTITUTE ( FORMAT ( DIVIDE ( CurrentValue, 1000000 ), \"$0.0M;($0.0M);$0.0M\" ), \"%\", \"%25\" ), \"&\", \"and\" )\nVAR PyText = SUBSTITUTE ( SUBSTITUTE ( FORMAT ( DIVIDE ( PriorValue, 1000000 ), \"$0.0M;($0.0M);$0.0M\" ), \"%\", \"%25\" ), \"&\", \"and\" )\nVAR DeltaText = SUBSTITUTE ( SUBSTITUTE ( FORMAT ( ChangePct, \"+0.0%;-0.0%;0.0%\" ), \"%\", \"%25\" ), \"&\", \"and\" )\nVAR Sparkline =\n    IF (\n        RowCount >= 2,\n        \"<g clip-path='url(%23sparkClip)'><polygon points='\" & AreaPoints & \"' fill='\" & TrendColor & \"' fill-opacity='0.26'/>\"\n            & \"<polyline points='\" & LinePoints & \"' fill='none' stroke='\" & TrendColor & \"' stroke-width='4.0' stroke-linecap='round' stroke-linejoin='round'/></g>\"\n            & \"<circle cx='172' cy='\" & FORMAT ( FirstY, \"0.0\", \"en-US\" ) & \"' r='4.4' fill='%231F2630' stroke='%23B9C3CF' stroke-width='1.45'/>\"\n            & \"<circle cx='274' cy='\" & FORMAT ( LastY, \"0.0\", \"en-US\" ) & \"' r='5.6' fill='\" & TrendColor & \"'/>\",\n        \"<line x1='172' y1='70' x2='274' y2='70' stroke='%23313B48' stroke-width='4.0' stroke-linecap='round'/>\"\n    )\nVAR SVG =\n    \"<svg xmlns='http://www.w3.org/2000/svg' width='296' height='135' viewBox='0 0 296 135'>\"\n    & \"<defs><clipPath id='sparkClip'><rect x='170' y='43' width='106' height='64' rx='5'/></clipPath></defs>\"\n    & \"<rect x='1.2' y='1.2' width='293.6' height='132.6' rx='12' fill='%23242B35' stroke='%233A4655' stroke-width='1.05'/>\"\n    & \"<rect x='13' y='13' width='150' height='4.5' rx='2.25' fill='%232F5F9E'/>\"\n    & \"<rect x='13' y='31' width='16' height='16' rx='4.2' fill='%232F5F9E' fill-opacity='0.22' stroke='%232F5F9E' stroke-width='1.15'/>\"\n    & \"<text x='38' y='45' font-family='Segoe UI Semibold' font-size='14.2' fill='%23F7FAFC' letter-spacing='0'>Revenue</text>\"\n    & \"<text x='13' y='98' font-family='Segoe UI Semibold' font-size='38' fill='%232F5F9E' letter-spacing='0'>\" & ValueText & \"</text>\"\n    & \"<rect x='162' y='32' width='120' height='82' rx='9' fill='%231F2630' stroke='%233A4655' stroke-width='1.0'/>\"\n    & \"<rect x='170' y='43' width='106' height='64' rx='5.5' fill='%232F5F9E' fill-opacity='0.13'/>\"\n    & \"<line x1='170' y1='73' x2='276' y2='73' stroke='%23313B48' stroke-width='1.4' stroke-dasharray='4 5'/>\"\n    & Sparkline\n    & \"<rect x='13' y='110' width='94' height='20' rx='9' fill='%232C3440' stroke='%233A4655' stroke-width='0.75'/>\"\n    & \"<text x='23' y='124' font-family='Segoe UI Semibold' font-size='10.5' fill='%23B9C3CF'>PY \" & PyText & \"</text>\"\n    & \"<rect x='113' y='110' width='76' height='20' rx='9' fill='\" & StatusColor & \"' fill-opacity='0.16' stroke='\" & StatusColor & \"' stroke-opacity='0.18'/>\"\n    & \"<text x='151' y='124' text-anchor='middle' font-family='Segoe UI Semibold' font-size='10.5' fill='\" & StatusColor & \"'>\" & DeltaText & \"</text>\"\n    & \"<rect x='195' y='110' width='87' height='20' rx='9' fill='\" & StatusColor & \"' fill-opacity='0.11'/>\"\n    & \"<text x='238.5' y='124' text-anchor='middle' font-family='Segoe UI Semibold' font-size='10.2' fill='\" & StatusColor & \"'>\" & StatusText & \"</text>\"\n    & \"</svg>\"\nRETURN\n    \"data:image/svg+xml;utf8,\" & SVG",
            "formatString": "",
            "description": "SVG KPI card for revenue with latest value, PY delta, status chip, and sparkline.",
            "dataCategory": "ImageUrl"
          },
          {
            "name": "EBITDA KPI Card SVG",
            "expression": "VAR d = [Selected Latest Complete Date]\nVAR LatestIdx =\n    CALCULATE ( MAX ( DimDate[month_index] ), REMOVEFILTERS ( DimDate ), DimDate[date] = d )\nVAR CurrentValue =\n    COALESCE ( CALCULATE ( [Actual EBITDA], REMOVEFILTERS ( DimDate ), DimDate[date] = d ), 0 )\nVAR PriorDate = EDATE ( d, -12 )\nVAR PriorValue =\n    COALESCE ( CALCULATE ( [Actual EBITDA], REMOVEFILTERS ( DimDate ), DimDate[date] = PriorDate ), 0 )\nVAR BudgetValue = CALCULATE ( [Budget EBITDA], REMOVEFILTERS ( DimDate ), DimDate[date] = d )\nVAR ChangePct = DIVIDE ( CurrentValue - PriorValue, ABS ( PriorValue ) )\nVAR DeltaPoints = ( CurrentValue - PriorValue ) * 100\nVAR StatusBasis =\n    IF (\n        NOT ISBLANK ( BudgetValue ),\n        DIVIDE ( CurrentValue - BudgetValue, ABS ( BudgetValue ) ),\n        ChangePct\n    )\nVAR StatusColor =\n    IF ( StatusBasis >= 0.02, \"%236F8552\", IF ( StatusBasis >= -0.02, \"%23A8894B\", \"%23B85A72\" ) )\nVAR StatusText =\n    IF ( StatusBasis >= 0.02, \"ON TRACK\", IF ( StatusBasis >= -0.02, \"WATCH\", \"ACTION\" ) )\nVAR TrendColor =\n    IF ( CurrentValue >= PriorValue, \"%236F8552\", \"%23B85A72\" )\nVAR MonthTable =\n    ADDCOLUMNS (\n        FILTER (\n            ALL ( DimDate ),\n            DimDate[date] <= d\n                && DimDate[month_index] >= LatestIdx - 11\n        ),\n        \"__Value\", CALCULATE ( [Actual EBITDA] )\n    )\nVAR CleanTable = FILTER ( MonthTable, NOT ISBLANK ( [__Value] ) )\nVAR RowCount = COUNTROWS ( CleanTable )\nVAR MinValue = MINX ( CleanTable, [__Value] )\nVAR MaxValue = MAXX ( CleanTable, [__Value] )\nVAR FirstValue = MINX ( TOPN ( 1, CleanTable, DimDate[date], ASC ), [__Value] )\nVAR LastValue = MAXX ( TOPN ( 1, CleanTable, DimDate[date], DESC ), [__Value] )\nVAR FirstY =\n    IF (\n        MaxValue = MinValue,\n        70,\n        96 - DIVIDE ( FirstValue - MinValue, MaxValue - MinValue, 0.5 ) * 52\n    )\nVAR LastY =\n    IF (\n        MaxValue = MinValue,\n        70,\n        96 - DIVIDE ( LastValue - MinValue, MaxValue - MinValue, 0.5 ) * 52\n    )\nVAR LinePoints =\n    CONCATENATEX (\n        CleanTable,\n        VAR RankValue = RANKX ( CleanTable, DimDate[date], , ASC, DENSE ) - 1\n        VAR XValue = 172 + DIVIDE ( RankValue, MAX ( 1, RowCount - 1 ), 0 ) * 102\n        VAR YRatio =\n            IF (\n                MaxValue = MinValue,\n                0.5,\n                DIVIDE ( [__Value] - MinValue, MaxValue - MinValue, 0.5 )\n            )\n        VAR YValue = 96 - YRatio * 52\n        RETURN FORMAT ( XValue, \"0.0\", \"en-US\" ) & \",\" & FORMAT ( YValue, \"0.0\", \"en-US\" ),\n        \" \",\n        DimDate[date],\n        ASC\n    )\nVAR AreaPoints = \"172,106 \" & LinePoints & \" 274,106\"\nVAR ValueText = SUBSTITUTE ( SUBSTITUTE ( FORMAT ( DIVIDE ( CurrentValue, 1000000 ), \"$0.0M;($0.0M);$0.0M\" ), \"%\", \"%25\" ), \"&\", \"and\" )\nVAR PyText = SUBSTITUTE ( SUBSTITUTE ( FORMAT ( DIVIDE ( PriorValue, 1000000 ), \"$0.0M;($0.0M);$0.0M\" ), \"%\", \"%25\" ), \"&\", \"and\" )\nVAR DeltaText = SUBSTITUTE ( SUBSTITUTE ( FORMAT ( ChangePct, \"+0.0%;-0.0%;0.0%\" ), \"%\", \"%25\" ), \"&\", \"and\" )\nVAR Sparkline =\n    IF (\n        RowCount >= 2,\n        \"<g clip-path='url(%23sparkClip)'><polygon points='\" & AreaPoints & \"' fill='\" & TrendColor & \"' fill-opacity='0.26'/>\"\n            & \"<polyline points='\" & LinePoints & \"' fill='none' stroke='\" & TrendColor & \"' stroke-width='4.0' stroke-linecap='round' stroke-linejoin='round'/></g>\"\n            & \"<circle cx='172' cy='\" & FORMAT ( FirstY, \"0.0\", \"en-US\" ) & \"' r='4.4' fill='%231F2630' stroke='%23B9C3CF' stroke-width='1.45'/>\"\n            & \"<circle cx='274' cy='\" & FORMAT ( LastY, \"0.0\", \"en-US\" ) & \"' r='5.6' fill='\" & TrendColor & \"'/>\",\n        \"<line x1='172' y1='70' x2='274' y2='70' stroke='%23313B48' stroke-width='4.0' stroke-linecap='round'/>\"\n    )\nVAR SVG =\n    \"<svg xmlns='http://www.w3.org/2000/svg' width='296' height='135' viewBox='0 0 296 135'>\"\n    & \"<defs><clipPath id='sparkClip'><rect x='170' y='43' width='106' height='64' rx='5'/></clipPath></defs>\"\n    & \"<rect x='1.2' y='1.2' width='293.6' height='132.6' rx='12' fill='%23242B35' stroke='%233A4655' stroke-width='1.05'/>\"\n    & \"<rect x='13' y='13' width='150' height='4.5' rx='2.25' fill='%232B6F75'/>\"\n    & \"<rect x='13' y='31' width='16' height='16' rx='4.2' fill='%232B6F75' fill-opacity='0.22' stroke='%232B6F75' stroke-width='1.15'/>\"\n    & \"<text x='38' y='45' font-family='Segoe UI Semibold' font-size='14.2' fill='%23F7FAFC' letter-spacing='0'>EBITDA</text>\"\n    & \"<text x='13' y='98' font-family='Segoe UI Semibold' font-size='38' fill='%232B6F75' letter-spacing='0'>\" & ValueText & \"</text>\"\n    & \"<rect x='162' y='32' width='120' height='82' rx='9' fill='%231F2630' stroke='%233A4655' stroke-width='1.0'/>\"\n    & \"<rect x='170' y='43' width='106' height='64' rx='5.5' fill='%232B6F75' fill-opacity='0.13'/>\"\n    & \"<line x1='170' y1='73' x2='276' y2='73' stroke='%23313B48' stroke-width='1.4' stroke-dasharray='4 5'/>\"\n    & Sparkline\n    & \"<rect x='13' y='110' width='94' height='20' rx='9' fill='%232C3440' stroke='%233A4655' stroke-width='0.75'/>\"\n    & \"<text x='23' y='124' font-family='Segoe UI Semibold' font-size='10.5' fill='%23B9C3CF'>PY \" & PyText & \"</text>\"\n    & \"<rect x='113' y='110' width='76' height='20' rx='9' fill='\" & StatusColor & \"' fill-opacity='0.16' stroke='\" & StatusColor & \"' stroke-opacity='0.18'/>\"\n    & \"<text x='151' y='124' text-anchor='middle' font-family='Segoe UI Semibold' font-size='10.5' fill='\" & StatusColor & \"'>\" & DeltaText & \"</text>\"\n    & \"<rect x='195' y='110' width='87' height='20' rx='9' fill='\" & StatusColor & \"' fill-opacity='0.11'/>\"\n    & \"<text x='238.5' y='124' text-anchor='middle' font-family='Segoe UI Semibold' font-size='10.2' fill='\" & StatusColor & \"'>\" & StatusText & \"</text>\"\n    & \"</svg>\"\nRETURN\n    \"data:image/svg+xml;utf8,\" & SVG",
