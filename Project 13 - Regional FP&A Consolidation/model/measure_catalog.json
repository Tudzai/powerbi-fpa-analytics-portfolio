[
  {
    "measure_name": "Total Revenue",
    "dax": "SUM ( FactFinancialSummary[external_revenue_usd] )",
    "format_string": "$#,0;($#,0);$0",
    "definition": "Consolidated external revenue after excluding intercompany revenue."
  },
  {
    "measure_name": "Gross Revenue",
    "dax": "SUM ( FactFinancialSummary[gross_revenue_usd] )",
    "format_string": "$#,0;($#,0);$0",
    "definition": "External plus intercompany revenue before elimination."
  },
  {
    "measure_name": "Intercompany Revenue",
    "dax": "SUM ( FactFinancialSummary[intercompany_revenue_usd] )",
    "format_string": "$#,0;($#,0);$0",
    "definition": "Intercompany revenue requiring elimination."
  },
  {
    "measure_name": "Intercompany Elimination",
    "dax": "SUM ( FactFinancialSummary[intercompany_elimination_usd] )",
    "format_string": "$#,0;($#,0);$0",
    "definition": "Net intercompany elimination impact."
  },
  {
    "measure_name": "Gross Profit",
    "dax": "SUM ( FactFinancialSummary[gross_profit_usd] )",
    "format_string": "$#,0;($#,0);$0",
    "definition": "Revenue minus cost of services."
  },
  {
    "measure_name": "Gross Margin %",
    "dax": "DIVIDE ( [Gross Profit], [Total Revenue] )",
    "format_string": "0.0%",
    "definition": "Gross profit divided by consolidated external revenue."
  },
  {
    "measure_name": "OPEX",
    "dax": "SUM ( FactFinancialSummary[opex_usd] )",
    "format_string": "$#,0;($#,0);$0",
    "definition": "Personnel, facilities, sales and marketing, and G&A."
  },
  {
    "measure_name": "EBITDA",
    "dax": "SUM ( FactFinancialSummary[ebitda_usd] )",
    "format_string": "$#,0;($#,0);$0",
    "definition": "Gross profit plus OPEX after intercompany elimination."
  },
  {
    "measure_name": "EBITDA Margin %",
    "dax": "DIVIDE ( [EBITDA], [Total Revenue] )",
    "format_string": "0.0%",
    "definition": "EBITDA divided by consolidated external revenue."
  },
  {
    "measure_name": "Operating Income",
    "dax": "SUM ( FactFinancialSummary[operating_income_usd] )",
    "format_string": "$#,0;($#,0);$0",
    "definition": "EBITDA less depreciation."
  },
  {
    "measure_name": "Net Income",
    "dax": "SUM ( FactFinancialSummary[net_income_usd] )",
    "format_string": "$#,0;($#,0);$0",
    "definition": "Operating income less interest and tax."
  },
  {
    "measure_name": "Cash Position",
    "dax": "SUM ( FactFinancialSummary[cash_position_usd] )",
    "format_string": "$#,0;($#,0);$0",
    "definition": "Period-end cash position by entity and BU allocation."
  },
  {
    "measure_name": "Operating Cash Flow",
    "dax": "SUM ( FactFinancialSummary[operating_cash_flow_usd] )",
    "format_string": "$#,0;($#,0);$0",
    "definition": "Operating cash flow proxy tied to EBITDA conversion."
  },
  {
    "measure_name": "Working Capital",
    "dax": "SUM ( FactFinancialSummary[working_capital_usd] )",
    "format_string": "$#,0;($#,0);$0",
    "definition": "Working capital proxy for close review."
  },
  {
    "measure_name": "Actual Revenue",
    "dax": "CALCULATE ( [Total Revenue], DimScenario[scenario] = \"Actual\" )",
    "format_string": "$#,0;($#,0);$0",
    "definition": "Actual consolidated revenue."
  },
  {
    "measure_name": "Budget Revenue",
    "dax": "CALCULATE ( [Total Revenue], DimScenario[scenario] = \"Budget\" )",
    "format_string": "$#,0;($#,0);$0",
    "definition": "Budget consolidated revenue."
  },
  {
    "measure_name": "Revenue Var vs Budget",
    "dax": "[Actual Revenue] - [Budget Revenue]",
    "format_string": "$#,0;($#,0);$0",
    "definition": "Actual revenue less budget revenue."
  },
  {
    "measure_name": "Revenue Var %",
    "dax": "DIVIDE ( [Revenue Var vs Budget], [Budget Revenue] )",
    "format_string": "0.0%",
    "definition": "Revenue variance divided by budget revenue."
  },
  {
    "measure_name": "Actual EBITDA",
    "dax": "CALCULATE ( [EBITDA], DimScenario[scenario] = \"Actual\" )",
    "format_string": "$#,0;($#,0);$0",
    "definition": "Actual EBITDA."
  },
  {
    "measure_name": "Budget EBITDA",
    "dax": "CALCULATE ( [EBITDA], DimScenario[scenario] = \"Budget\" )",
    "format_string": "$#,0;($#,0);$0",
    "definition": "Budget EBITDA."
  },
  {
    "measure_name": "EBITDA Var vs Budget",
    "dax": "[Actual EBITDA] - [Budget EBITDA]",
    "format_string": "$#,0;($#,0);$0",
    "definition": "Actual EBITDA less budget EBITDA."
  },
  {
    "measure_name": "EBITDA Var %",
    "dax": "DIVIDE ( [EBITDA Var vs Budget], [Budget EBITDA] )",
    "format_string": "0.0%",
    "definition": "EBITDA variance divided by budget EBITDA."
  },
  {
    "measure_name": "Forecast EBITDA",
    "dax": "CALCULATE ( [EBITDA], DimScenario[scenario] = \"Forecast\" )",
    "format_string": "$#,0;($#,0);$0",
    "definition": "Forecast EBITDA."
  },
  {
    "measure_name": "Forecast Accuracy %",
    "dax": "1 - ABS ( DIVIDE ( [Actual EBITDA] - [Forecast EBITDA], [Actual EBITDA] ) )",
    "format_string": "0.0%",
    "definition": "Directional forecast accuracy for EBITDA."
  },
  {
    "measure_name": "Open Exception Count",
    "dax": "CALCULATE ( COUNTROWS ( FactCloseExceptions ), FactCloseExceptions[status] <> \"Closed\" )",
    "format_string": "#,0",
    "definition": "Open or in-progress close exceptions."
  },
  {
    "measure_name": "Open Exception Value",
    "dax": "CALCULATE ( SUM ( FactCloseExceptions[amount_usd] ), FactCloseExceptions[status] <> \"Closed\" )",
    "format_string": "$#,0;($#,0);$0",
    "definition": "Value attached to unresolved close exceptions."
  }
]