	/// SVG KPI card for open exception exposure with lower-is-better status and sparkline.
	measure 'Close Exceptions KPI Card SVG' =
			VAR d = [Selected Latest Complete Date]
			VAR LatestIdx =
			    CALCULATE ( MAX ( DimDate[month_index] ), REMOVEFILTERS ( DimDate ), DimDate[date] = d )
			VAR CurrentValue =
			    COALESCE ( CALCULATE ( [Open Exception Value], REMOVEFILTERS ( DimDate ), DimDate[date] = d ), 0 )
