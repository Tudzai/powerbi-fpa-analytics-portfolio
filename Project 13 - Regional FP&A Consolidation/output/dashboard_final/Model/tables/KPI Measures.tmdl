			RETURN
			    "data:image/svg+xml;utf8," & SVG
		dataCategory: ImageUrl

	/// SVG KPI card for forecast accuracy with prior-year point delta and sparkline.
	measure 'Forecast Accuracy KPI Card SVG' =
			VAR d = [Selected Latest Complete Date]
			VAR LatestIdx =
			    CALCULATE ( MAX ( DimDate[month_index] ), REMOVEFILTERS ( DimDate ), DimDate[date] = d )
			VAR CurrentValue =
			    COALESCE ( CALCULATE ( [Forecast Accuracy %], REMOVEFILTERS ( DimDate ), DimDate[date] = d ), 0 )
			VAR PriorDate = EDATE ( d, -12 )
			VAR PriorValue =
			    COALESCE ( CALCULATE ( [Forecast Accuracy %], REMOVEFILTERS ( DimDate ), DimDate[date] = PriorDate ), 0 )
			VAR BudgetValue = BLANK ()
			VAR ChangePct = DIVIDE ( CurrentValue - PriorValue, ABS ( PriorValue ) )
			VAR DeltaPoints = ( CurrentValue - PriorValue ) * 100
			VAR StatusBasis =
			    IF (
			        NOT ISBLANK ( BudgetValue ),
			        DIVIDE ( CurrentValue - BudgetValue, ABS ( BudgetValue ) ),
			        ChangePct
			    )
			VAR StatusColor =
			    IF ( StatusBasis >= 0.02, "%236F8552", IF ( StatusBasis >= -0.02, "%23A8894B", "%23B85A72" ) )
			VAR StatusText =
			    IF ( StatusBasis >= 0.02, "ON TRACK", IF ( StatusBasis >= -0.02, "WATCH", "ACTION" ) )
			VAR TrendColor =
			    IF ( CurrentValue >= PriorValue, "%236F8552", "%23B85A72" )
			VAR MonthTable =
			    ADDCOLUMNS (
			        FILTER (
			            ALL ( DimDate ),
			            DimDate[date] <= d
			                && DimDate[month_index] >= LatestIdx - 11
			        ),
			        "__Value", CALCULATE ( [Forecast Accuracy %] )
			    )
			VAR CleanTable = FILTER ( MonthTable, NOT ISBLANK ( [__Value] ) )
			VAR RowCount = COUNTROWS ( CleanTable )
			VAR MinValue = MINX ( CleanTable, [__Value] )
			VAR MaxValue = MAXX ( CleanTable, [__Value] )
			VAR FirstValue = MINX ( TOPN ( 1, CleanTable, DimDate[date], ASC ), [__Value] )
			VAR LastValue = MAXX ( TOPN ( 1, CleanTable, DimDate[date], DESC ), [__Value] )
			VAR FirstY =
			    IF (
			        MaxValue = MinValue,
			        64,
			        90 - DIVIDE ( FirstValue - MinValue, MaxValue - MinValue, 0.5 ) * 52
			    )
			VAR LastY =
			    IF (
			        MaxValue = MinValue,
			        64,
			        90 - DIVIDE ( LastValue - MinValue, MaxValue - MinValue, 0.5 ) * 52
			    )
			VAR LinePoints =
			    CONCATENATEX (
			        CleanTable,
			        VAR RankValue = RANKX ( CleanTable, DimDate[date], , ASC, DENSE ) - 1
			        VAR XValue = 178 + DIVIDE ( RankValue, MAX ( 1, RowCount - 1 ), 0 ) * 96
			        VAR YRatio =
			            IF (
			                MaxValue = MinValue,
			                0.5,
			                DIVIDE ( [__Value] - MinValue, MaxValue - MinValue, 0.5 )
			            )
			        VAR YValue = 90 - YRatio * 52
			        RETURN FORMAT ( XValue, "0.0", "en-US" ) & "," & FORMAT ( YValue, "0.0", "en-US" ),
			        " ",
			        DimDate[date],
			        ASC
			    )
			VAR AreaPoints = "178,90 " & LinePoints & " 274,90"
			VAR ValueText = SUBSTITUTE ( SUBSTITUTE ( FORMAT ( CurrentValue, "0.0%" ), "%", "%25" ), "&", "and" )
			VAR PyText = SUBSTITUTE ( SUBSTITUTE ( FORMAT ( PriorValue, "0.0%" ), "%", "%25" ), "&", "and" )
			VAR DeltaText = SUBSTITUTE ( SUBSTITUTE ( FORMAT ( DeltaPoints, "+0.0pt;-0.0pt;0.0pt" ), "%", "%25" ), "&", "and" )
			VAR Sparkline =
			    IF (
			        RowCount >= 2,
			        "<g clip-path='url(%23sparkClip)'><polygon points='" & AreaPoints & "' fill='" & TrendColor & "' fill-opacity='0.17'/>"
			            & "<polyline points='" & LinePoints & "' fill='none' stroke='" & TrendColor & "' stroke-width='3.6' stroke-linecap='round' stroke-linejoin='round'/>"
			            & "<circle cx='178' cy='" & FORMAT ( FirstY, "0.0", "en-US" ) & "' r='4.0' fill='%231F2630' stroke='%23B9C3CF' stroke-width='1.35'/>"
			            & "<circle cx='274' cy='" & FORMAT ( LastY, "0.0", "en-US" ) & "' r='5.0' fill='" & TrendColor & "'/></g>",
			        "<line x1='178' y1='64' x2='274' y2='64' stroke='%23313B48' stroke-width='3.6' stroke-linecap='round'/>"
			    )
			VAR SVG =
			    "<svg xmlns='http://www.w3.org/2000/svg' width='296' height='135' viewBox='0 0 296 135'>"
			    & "<defs><clipPath id='sparkClip'><rect x='178' y='38' width='106' height='52' rx='5'/></clipPath></defs>"
			    & "<rect x='1.2' y='1.2' width='293.6' height='132.6' rx='12' fill='%23242B35' stroke='%233A4655' stroke-width='1.05'/>"
			    & "<rect x='13' y='13' width='150' height='4.5' rx='2.25' fill='%23A8894B'/>"
			    & "<rect x='13' y='31' width='16' height='16' rx='4.2' fill='%23A8894B' fill-opacity='0.22' stroke='%23A8894B' stroke-width='1.15'/>"
			    & "<text x='38' y='45' font-family='Segoe UI Semibold' font-size='13.0' fill='%23F7FAFC' letter-spacing='0'>Forecast Accuracy</text>"
			    & "<text x='13' y='98' font-family='Segoe UI Semibold' font-size='38' fill='%23A8894B' letter-spacing='0'>" & ValueText & "</text>"
			    & "<rect x='170' y='32' width='114' height='64' rx='9' fill='%231F2630' stroke='%233A4655' stroke-width='1.0'/>"
			    & "<rect x='178' y='38' width='106' height='52' rx='5.5' fill='%23A8894B' fill-opacity='0.13'/>"
			    & "<line x1='178' y1='64' x2='284' y2='64' stroke='%23313B48' stroke-width='1.4' stroke-dasharray='4 5'/>"
			    & Sparkline
			    & "<rect x='14' y='104' width='92' height='24' rx='11' fill='%232C3440' stroke='%233A4655' stroke-width='0.75'/>"
			    & "<text x='60' y='120' text-anchor='middle' font-family='Segoe UI Semibold' font-size='10.8' fill='%23B9C3CF'>PY " & PyText & "</text>"
			    & "<rect x='112' y='104' width='76' height='24' rx='11' fill='" & StatusColor & "' fill-opacity='0.16' stroke='" & StatusColor & "' stroke-opacity='0.18'/>"
			    & "<text x='150' y='120' text-anchor='middle' font-family='Segoe UI Semibold' font-size='10.8' fill='" & StatusColor & "'>" & DeltaText & "</text>"
			    & "<rect x='196' y='104' width='86' height='24' rx='11' fill='" & StatusColor & "' fill-opacity='0.11'/>"
			    & "<text x='239' y='120' text-anchor='middle' font-family='Segoe UI Semibold' font-size='10.7' fill='" & StatusColor & "'>" & StatusText & "</text>"
			    & "</svg>"
			RETURN
			    "data:image/svg+xml;utf8," & SVG
		dataCategory: ImageUrl

	/// Top-bar Current Lens SVG for selected period, region, BU, revenue variance, and close-risk exposure.
	measure 'Lens Summary SVG' =
			VAR PeriodText = [Selected Latest Complete Period Label]
			VAR RegionRaw =
			    IF ( ISFILTERED ( DimEntity[region] ), CONCATENATEX ( VALUES ( DimEntity[region] ), DimEntity[region], ", " ), "All regions" )
			VAR BURaw =
			    IF ( ISFILTERED ( DimBusinessUnit[business_unit] ), CONCATENATEX ( VALUES ( DimBusinessUnit[business_unit] ), DimBusinessUnit[business_unit], ", " ), "All BUs" )
			VAR ScenarioRaw =
			    IF ( ISFILTERED ( DimScenario[scenario] ), CONCATENATEX ( VALUES ( DimScenario[scenario] ), DimScenario[scenario], ", " ), "Actual lens" )
			VAR ScenarioText = SUBSTITUTE ( LEFT ( ScenarioRaw, 20 ), "&", "and" )
			VAR RegionText = SUBSTITUTE ( LEFT ( RegionRaw, 24 ), "&", "and" )
			VAR BUText = SUBSTITUTE ( LEFT ( BURaw, 28 ), "&", "and" )
			VAR RevVar = [Latest Revenue Var %]
			VAR EbitdaVar = [Latest EBITDA Var %]
			VAR RiskValue = COALESCE ( [Latest Open Exception Value], 0 )
			VAR RevText = SUBSTITUTE ( FORMAT ( RevVar, "+0.0%;-0.0%;0.0%" ), "%", "%25" )
			VAR StatusColor = IF ( EbitdaVar >= 0.02, "%232B6F75", IF ( EbitdaVar >= -0.02, "%23A8894B", "%23B85A72" ) )
			VAR Line1 = SUBSTITUTE ( LEFT ( PeriodText & " | " & ScenarioText, 38 ), "&", "and" )
			VAR Line2 = SUBSTITUTE ( LEFT ( BUText & " | " & RegionText, 48 ), "&", "and" )
			VAR RiskText = "$" & FORMAT ( DIVIDE ( RiskValue, 1000000 ), "0.0M" )
			VAR SVG =
			    "<svg xmlns='http://www.w3.org/2000/svg' width='568' height='78' viewBox='0 0 568 78'>"
			    & "<rect x='18' y='14' width='5' height='50' rx='2.5' fill='%232B6F75'/>"
			    & "<circle cx='46' cy='27' r='7.4' fill='" & StatusColor & "'/>"
			    & "<text x='64' y='28' font-family='Segoe UI Semibold' font-size='14.0' fill='%23F7FAFC'>CURRENT LENS</text>"
			    & "<text x='64' y='50' font-family='Segoe UI Semibold' font-size='13.1' fill='%23F7FAFC'>" & Line1 & "</text>"
			    & "<text x='64' y='66' font-family='Segoe UI' font-size='12.2' fill='%23C7D0DB'>" & Line2 & "</text>"
			    & "<rect x='244' y='10' width='154' height='58' rx='11' fill='%231F2630' stroke='%233A4655' stroke-width='1.05'/>"
			    & "<text x='321' y='30' text-anchor='middle' font-family='Segoe UI' font-size='11.2' fill='%23C7D0DB'>Revenue var</text>"
			    & "<text x='321' y='57' text-anchor='middle' font-family='Segoe UI Semibold' font-size='22.0' fill='%232F5F9E'>" & RevText & "</text>"
			    & "<rect x='410' y='10' width='144' height='58' rx='11' fill='%231F2630' stroke='%233A4655' stroke-width='1.05'/>"
			    & "<text x='482' y='30' text-anchor='middle' font-family='Segoe UI' font-size='11.2' fill='%23C7D0DB'>Close risk</text>"
			    & "<text x='482' y='57' text-anchor='middle' font-family='Segoe UI Semibold' font-size='22.0' fill='%23A8894B'>" & RiskText & "</text>"
			    & "</svg>"
			RETURN
			    "data:image/svg+xml;utf8," & SVG
		dataCategory: ImageUrl

	column 'Measure Group'
		dataType: string
		isHidden
		summarizeBy: none
		sourceColumn: Measure Group

	partition 'KPI Measures-Import' = m
		mode: import
		source =
				let
				    Source = #table(type table [Measure Group = text], {{"Regional FP&A Consolidation"}})
				in
				    Source
