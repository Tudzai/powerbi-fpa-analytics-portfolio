            "lineageTag": "7bbd8914-6df6-4017-8a39-2fbca3235b14",
            "formatString": "$#,0;($#,0);$0"
          },
          {
            "name": "EBITDA Margin %",
            "expression": "DIVIDE([EBITDA], [Revenue])",
            "lineageTag": "0dc8e078-c380-4ff9-99f0-ae3fa00945f1",
            "formatString": "0.0%"
          },
          {
