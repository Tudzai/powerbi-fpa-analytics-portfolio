    "<rect x='14' y='12' width='146' height='5' rx='2.5' fill='%2315803D' opacity='0.92'/>" &
    "<rect x='14' y='30' width='16' height='16' rx='4.5' fill='%2315803D' opacity='0.95'/>" &
