Net Revenue =
SUM(FactShipmentProfitability[net_revenue_usd])

Freight Cost =
SUM(FactShipmentProfitability[freight_cost_usd])

Fuel Cost =
SUM(FactShipmentProfitability[fuel_cost_usd])

Demurrage Cost =
SUM(FactShipmentProfitability[demurrage_cost_usd])

Claims Cost =
SUM(FactShipmentProfitability[claims_cost_usd])

Total Cost =
SUM(FactShipmentProfitability[total_cost_usd])

Gross Profit =
SUM(FactShipmentProfitability[gross_profit_usd])

GP Margin % =
DIVIDE([Gross Profit], [Net Revenue])

Shipment Count =
SUM(FactShipmentProfitability[shipment_count])

TEU =
SUM(FactShipmentProfitability[teu])

CBM =
SUM(FactShipmentProfitability[cbm])

Revenue per Shipment =
DIVIDE([Net Revenue], [Shipment Count])

Cost per Shipment =
DIVIDE([Total Cost], [Shipment Count])

Target Gross Profit =
SUMX(FactShipmentProfitability, FactShipmentProfitability[net_revenue_usd] * FactShipmentProfitability[target_margin_pct])

Margin Gap vs Target =
[Gross Profit] - [Target Gross Profit]

Target Margin % =
DIVIDE([Target Gross Profit], [Net Revenue])

Margin Gap % =
[GP Margin %] - [Target Margin %]

On-Time % =
DIVIDE(SUM(FactShipmentProfitability[on_time_count]), [Shipment Count])

Utilization % =
AVERAGE(FactShipmentProfitability[utilization_pct])

Negative Margin Shipments =
CALCULATE([Shipment Count], FILTER(FactShipmentProfitability, FactShipmentProfitability[gross_profit_usd] < 0))

Reprice Opportunity =
SUMX(FILTER(FactShipmentProfitability, FactShipmentProfitability[gross_profit_usd] < 0), -FactShipmentProfitability[gross_profit_usd])

Bridge Amount =
SUM(FactCostDriverBridge[amount_usd])

Open Actions =
CALCULATE(COUNTROWS(FactActionQueue), FILTER(FactActionQueue, FactActionQueue[status] <> "Closed"))

Action Risk Value =
SUM(FactActionQueue[risk_value_usd])

Recovery Value =
SUM(FactActionQueue[target_margin_recovery_usd])

Latest Net Revenue =
VAR LatestDate = MAXX(ALLSELECTED(DimDate), DimDate[date])
VAR LatestValue = CALCULATE([Net Revenue], FILTER(ALL(DimDate), DimDate[date] = LatestDate))
RETURN DIVIDE(LatestValue, 1000000)

Latest Gross Profit =
VAR LatestDate = MAXX(ALLSELECTED(DimDate), DimDate[date])
VAR LatestValue = CALCULATE([Gross Profit], FILTER(ALL(DimDate), DimDate[date] = LatestDate))
RETURN DIVIDE(LatestValue, 1000000)

Latest GP Margin % =
VAR LatestDate = MAXX(ALLSELECTED(DimDate), DimDate[date])
VAR LatestValue = CALCULATE([GP Margin %], FILTER(ALL(DimDate), DimDate[date] = LatestDate))
RETURN DIVIDE(LatestValue, 1)

Latest Reprice Opportunity =
VAR LatestDate = MAXX(ALLSELECTED(DimDate), DimDate[date])
VAR LatestValue = CALCULATE([Reprice Opportunity], FILTER(ALL(DimDate), DimDate[date] = LatestDate))
RETURN DIVIDE(LatestValue, 1000000)

Latest Revenue per Shipment =
VAR LatestDate = MAXX(ALLSELECTED(DimDate), DimDate[date])
VAR LatestValue = CALCULATE([Revenue per Shipment], FILTER(ALL(DimDate), DimDate[date] = LatestDate))
RETURN DIVIDE(LatestValue, 1)

Latest Margin Gap vs Target =
VAR LatestDate = MAXX(ALLSELECTED(DimDate), DimDate[date])
VAR LatestValue = CALCULATE([Margin Gap vs Target], FILTER(ALL(DimDate), DimDate[date] = LatestDate))
RETURN DIVIDE(LatestValue, 1000000)

Latest Negative Margin Shipments =
VAR LatestDate = MAXX(ALLSELECTED(DimDate), DimDate[date])
VAR LatestValue = CALCULATE([Negative Margin Shipments], FILTER(ALL(DimDate), DimDate[date] = LatestDate))
RETURN DIVIDE(LatestValue, 1)

Latest On-Time % =
VAR LatestDate = MAXX(ALLSELECTED(DimDate), DimDate[date])
VAR LatestValue = CALCULATE([On-Time %], FILTER(ALL(DimDate), DimDate[date] = LatestDate))
RETURN DIVIDE(LatestValue, 1)

Latest Open Actions =
VAR LatestDate = MAXX(ALLSELECTED(DimDate), DimDate[date])
VAR LatestValue = CALCULATE([Open Actions], FILTER(ALL(DimDate), DimDate[date] = LatestDate))
RETURN DIVIDE(LatestValue, 1)

Latest Action Risk Value =
VAR LatestDate = MAXX(ALLSELECTED(DimDate), DimDate[date])
VAR LatestValue = CALCULATE([Action Risk Value], FILTER(ALL(DimDate), DimDate[date] = LatestDate))
RETURN DIVIDE(LatestValue, 1000000)

Latest Recovery Value =
VAR LatestDate = MAXX(ALLSELECTED(DimDate), DimDate[date])
VAR LatestValue = CALCULATE([Recovery Value], FILTER(ALL(DimDate), DimDate[date] = LatestDate))
RETURN DIVIDE(LatestValue, 1000000)

Latest Demurrage Cost =
VAR LatestDate = MAXX(ALLSELECTED(DimDate), DimDate[date])
VAR LatestValue = CALCULATE([Demurrage Cost], FILTER(ALL(DimDate), DimDate[date] = LatestDate))
RETURN DIVIDE(LatestValue, 1000000)

Current Lens Primary =
VAR LatestDate = MAXX(ALLSELECTED(DimDate), DimDate[date])
VAR PeriodText = FORMAT(LatestDate, "MMM yyyy")
VAR ModeCount = COUNTROWS(VALUES(DimTradeLane[mode]))
VAR ModeTotal = CALCULATE(COUNTROWS(VALUES(DimTradeLane[mode])), ALL(DimTradeLane[mode]))
VAR ModeText = IF(NOT ISFILTERED(DimTradeLane[mode]) || ModeCount = ModeTotal, "All modes", IF(ModeCount = 1, SELECTEDVALUE(DimTradeLane[mode]), FORMAT(ModeCount, "0") & " modes"))
VAR SegmentCount = COUNTROWS(VALUES(DimCustomer[segment]))
VAR SegmentTotal = CALCULATE(COUNTROWS(VALUES(DimCustomer[segment])), ALL(DimCustomer[segment]))
VAR SegmentText = IF(NOT ISFILTERED(DimCustomer[segment]) || SegmentCount = SegmentTotal, "All seg", IF(SegmentCount = 1, SELECTEDVALUE(DimCustomer[segment]), FORMAT(SegmentCount, "0") & " seg"))
RETURN LEFT(PeriodText & " | " & ModeText & " | " & SegmentText, 34)

Current Lens Secondary =
VAR OriginText = IF(HASONEVALUE(DimTradeLane[origin_country]), SELECTEDVALUE(DimTradeLane[origin_country]), "All org")
VAR DestText = IF(HASONEVALUE(DimTradeLane[destination_country]), SELECTEDVALUE(DimTradeLane[destination_country]), "All dest")
VAR OfficeText = IF(HASONEVALUE(DimOffice[office]), SELECTEDVALUE(DimOffice[office]), "All offices")
RETURN LEFT(OriginText & " -> " & DestText & " | " & OfficeText, 42)

Executive Decision Text =
VAR GapText = FORMAT(DIVIDE([Margin Gap vs Target], 1000000), "$0.0M;($0.0M);$0.0M")
VAR RepriceText = FORMAT(DIVIDE([Reprice Opportunity], 1000000), "$0.0M")
RETURN IF([Margin Gap vs Target] < 0, "Reprice | Gap " & GapText, "Protect mix | GP " & FORMAT([GP Margin %], "0.0%"))

Lane Decision Text =
VAR GapPts = FORMAT([Margin Gap %] * 100, "+0.0;-0.0;0.0") & " pt"
RETURN IF([Margin Gap vs Target] < 0, "Fix lanes | Gap " & GapPts, "Scale lanes | Target " & FORMAT([Target Margin %], "0.0%"))

Cost Decision Text =
"Risk " & FORMAT(DIVIDE([Action Risk Value], 1000000), "$0.0M") & " | Rec " & FORMAT(DIVIDE([Recovery Value], 1000000), "$0.0M")

Current Lens Panel SVG =
VAR LineRaw = [Current Lens Primary]
VAR LineText = SUBSTITUTE(SUBSTITUTE(LEFT(LineRaw, 38), "&", "and"), "%", "%25")
VAR SVG =
    "<svg xmlns='http://www.w3.org/2000/svg' width='256' height='28' viewBox='0 0 256 28'>" &
    "<rect x='0' y='0' width='256' height='28' fill='%23FFFFFF'/>" &
    "<text x='0' y='9' font-family='Segoe UI' font-size='8.4' font-weight='750' fill='%232563EB'>CURRENT LENS</text>" &
    "<text x='0' y='24' font-family='Segoe UI' font-size='11.4' font-weight='700' fill='%230F172A'>" & LineText & "</text>" &
    "</svg>"
RETURN "data:image/svg+xml;utf8," & SVG

Executive Decision Panel SVG =
VAR LineRaw = [Executive Decision Text]
VAR LineText = SUBSTITUTE(SUBSTITUTE(LEFT(LineRaw, 38), "&", "and"), "%", "%25")
VAR SVG =
    "<svg xmlns='http://www.w3.org/2000/svg' width='244' height='28' viewBox='0 0 244 28'>" &
    "<rect x='0' y='0' width='244' height='28' fill='%23FFFFFF'/>" &
    "<text x='0' y='9' font-family='Segoe UI' font-size='8.4' font-weight='750' fill='%23B45309'>NEXT ACTION</text>" &
    "<text x='0' y='24' font-family='Segoe UI' font-size='11.4' font-weight='700' fill='%230F172A'>" & LineText & "</text>" &
    "</svg>"
RETURN "data:image/svg+xml;utf8," & SVG

Lane Decision Panel SVG =
VAR LineRaw = [Lane Decision Text]
