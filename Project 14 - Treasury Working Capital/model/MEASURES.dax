        [Open Risk Count],
        FILTER(ALL(DimDate), DimDate[month_index] = PriorPeriod)
    )
VAR PeriodTable =
    ADDCOLUMNS(
        FILTER(ALLSELECTED(DimDate), DimDate[month_index] <= CurrentPeriod),
        "__Sort", DimDate[month_index],
        "__Value", [Open Risk Count]
    )

VAR CurrentTextRaw = FORMAT(CurrentValue, "#,0")
VAR PriorTextRaw = IF(ISBLANK(PriorValue), "n/a", FORMAT(PriorValue, "#,0"))
VAR DeltaTextRaw = IF(ISBLANK(PriorValue), "n/a", FORMAT(CurrentValue - PriorValue, "+0.0;-0.0;0.0"))
