Cash Balance =
SUM(FactCashPosition[balance_usd])

Available Cash =
SUM(FactCashPosition[available_cash_usd])

Restricted Cash =
SUM(FactCashPosition[restricted_cash_usd])

Credit Available =
SUM(FactLiquidityFacility[available_usd])

Available Liquidity =
[Available Cash] + [Credit Available]

Minimum Cash Buffer =
SUM(FactLiquidityFacility[min_cash_buffer_usd])

Liquidity Headroom =
[Available Liquidity] - [Minimum Cash Buffer]

AR Outstanding =
SUM(FactARInvoice[outstanding_usd])

Overdue AR =
CALCULATE([AR Outstanding], FactARInvoice[is_overdue] = TRUE())

Overdue AR % =
DIVIDE([Overdue AR], [AR Outstanding])

AP Outstanding =
SUM(FactAPInvoice[outstanding_usd])

AP Due 14 Days =
CALCULATE([AP Outstanding], FactAPInvoice[due_window] = "0-14 days")

Revenue =
SUM(FactWorkingCapital[revenue_usd])

COGS =
SUM(FactWorkingCapital[cogs_usd])

Working Capital =
SUM(FactWorkingCapital[working_capital_usd])

DSO =
DIVIDE(SUM(FactWorkingCapital[ar_balance_usd]), [Revenue]) * 30

DPO =
DIVIDE(SUM(FactWorkingCapital[ap_balance_usd]), [COGS]) * 30

DIO =
DIVIDE(SUM(FactWorkingCapital[inventory_balance_usd]), [COGS]) * 30

Cash Conversion Cycle =
[DSO] + [DIO] - [DPO]

Forecast Closing Cash =
SUM(FactCashForecast[closing_cash_usd])

Forecast Net Cash Flow =
SUM(FactCashForecast[net_cash_flow_usd])

Forecast Receipts =
SUM(FactCashForecast[customer_receipts_usd]) + SUM(FactCashForecast[other_receipts_usd])

Forecast Payments =
SUM(FactCashForecast[supplier_payments_usd]) + SUM(FactCashForecast[payroll_tax_usd]) + SUM(FactCashForecast[capex_usd]) + SUM(FactCashForecast[debt_service_usd])

Cash Runway Weeks =
DIVIDE([Available Liquidity], ABS(AVERAGE(FactCashForecast[net_cash_flow_usd])))

Forecast Error % =
DIVIDE(SUM(FactForecastAccuracy[abs_error_usd]), SUMX(FactForecastAccuracy, ABS(FactForecastAccuracy[actual_net_cash_flow_usd])))

FX Net Exposure =
SUM(FactFXExposure[net_exposure_usd])

Unhedged FX Exposure =
SUM(FactFXExposure[unhedged_exposure_usd])

Unhedged FX % =
DIVIDE([Unhedged FX Exposure], [FX Net Exposure])

Open Risk Value =
CALCULATE(SUM(FactTreasuryRiskAction[amount_usd]), FactTreasuryRiskAction[status] <> "Closed")

Open Risk Count =
CALCULATE(COUNTROWS(FactTreasuryRiskAction), FactTreasuryRiskAction[status] <> "Closed")

Latest Complete Month =
MAXX(FILTER(ALL(DimDate), DimDate[is_latest_complete] = TRUE()), DimDate[date])

Available Liquidity KPI Card SVG =
VAR CurrentPeriod =
    MAXX(
        FILTER(ALL(DimDate), DimDate[is_latest_complete] = TRUE()),
        DimDate[month_index]
    )
VAR PriorPeriod = CurrentPeriod - 12
VAR CurrentValue =
    CALCULATE(
        [Available Liquidity],
        FILTER(ALL(DimDate), DimDate[month_index] = CurrentPeriod)
    )
VAR PriorValue =
    CALCULATE(
        [Available Liquidity],
        FILTER(ALL(DimDate), DimDate[month_index] = PriorPeriod)
    )
VAR PeriodTable =
    ADDCOLUMNS(
        FILTER(ALLSELECTED(DimDate), DimDate[month_index] <= CurrentPeriod),
        "__Sort", DimDate[month_index],
        "__Value", [Available Liquidity]
    )

VAR CurrentTextRaw = FORMAT(DIVIDE(CurrentValue, 1000000), "$0.0M;($0.0M);$0.0M")
VAR PriorTextRaw = IF(ISBLANK(PriorValue), "n/a", FORMAT(DIVIDE(PriorValue, 1000000), "$0.0M;($0.0M);$0.0M"))
VAR DeltaTextRaw = IF(ISBLANK(PriorValue), "n/a", FORMAT(DIVIDE(CurrentValue - PriorValue, ABS(PriorValue)), "+0.0%;-0.0%;0.0%"))
VAR CurrentText = SUBSTITUTE(CurrentTextRaw, "%", "%25")
VAR PriorText = SUBSTITUTE(PriorTextRaw, "%", "%25")
VAR DeltaText = SUBSTITUTE(DeltaTextRaw, "%", "%25")
VAR DeltaColor =
    IF(ISBLANK(PriorValue), "%23607081", IF(CurrentValue >= PriorValue, "%230F766E", "%23B85062"))
VAR CleanTable =
    FILTER(PeriodTable, NOT ISBLANK([__Value]))
VAR RowCount = COUNTROWS(CleanTable)
VAR MinValue = MINX(CleanTable, [__Value])
VAR MaxValue = MAXX(CleanTable, [__Value])
VAR FirstValue = MINX(TOPN(1, CleanTable, [__Sort], ASC), [__Value])
VAR LastValue = MINX(TOPN(1, CleanTable, [__Sort], DESC), [__Value])
VAR StartYValue = 80 - DIVIDE(FirstValue - MinValue, MaxValue - MinValue, 0.5) * 38
VAR EndYValue = 80 - DIVIDE(LastValue - MinValue, MaxValue - MinValue, 0.5) * 38
VAR TrendColor = IF(LastValue >= FirstValue, "%230F766E", "%23B85062")
VAR BandColor = IF(LastValue >= FirstValue, "%23DDEEDC", "%23F7DADD")
VAR LinePoints =
    CONCATENATEX(
        CleanTable,
        VAR RankValue = RANKX(CleanTable, [__Sort], , ASC, DENSE) - 1
        VAR XValue = 136 + DIVIDE(RankValue, MAX(1, RowCount - 1), 0) * 92
        VAR YValue = 80 - DIVIDE([__Value] - MinValue, MaxValue - MinValue, 0.5) * 38
        RETURN FORMAT(XValue, "0.0") & "," & FORMAT(YValue, "0.0"),
        " ",
        [__Sort],
        ASC
    )
VAR SVG =
    "<svg xmlns='http://www.w3.org/2000/svg' width='252' height='158' viewBox='0 0 252 158'>"
        & "<rect x='1' y='1' width='250' height='156' rx='10' fill='%23FFFFFF' stroke='%23D8E0E7' stroke-width='1.2'/>"
        & "<rect x='12' y='11' width='228' height='4' rx='2' fill='%230F766E'/>"
        & "<rect x='14' y='27' width='12' height='12' rx='3' fill='%230F766E'/>"
        & "<text x='34' y='38' font-family='Segoe UI Semibold' font-size='12.5' fill='%2315202B'>Available Liquidity</text>"
        & "<text x='14' y='77' font-family='Segoe UI Semibold' font-size='25' fill='%230F766E'>" & CurrentText & "</text>"
        & "<rect x='130' y='30' width='108' height='58' rx='8' fill='%23F3F6F8'/>"
        & "<rect x='136' y='58' width='92' height='12' rx='6' fill='" & BandColor & "'/>"
        & "<line x1='136' y1='64' x2='228' y2='64' stroke='%23AAB7C4' stroke-width='1' stroke-dasharray='4 5'/>"
        & "<polyline points='" & LinePoints & "' fill='none' stroke='" & TrendColor & "' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'/>"
        & "<circle cx='136' cy='" & FORMAT(StartYValue, "0.0") & "' r='3.6' fill='%23FFFFFF' stroke='%23607081' stroke-width='1.4'/>"
        & "<circle cx='228' cy='" & FORMAT(EndYValue, "0.0") & "' r='4.8' fill='" & TrendColor & "' stroke='%23FFFFFF' stroke-width='1.8'/>"
        & "<rect x='14' y='126' width='98' height='20' rx='6' fill='%23F8FAFB'/>"
        & "<rect x='120' y='126' width='118' height='20' rx='6' fill='%23F8FAFB'/>"
        & "<text x='22' y='140' font-family='Segoe UI' font-size='9.4' fill='%23607081'>PY " & PriorText & "</text>"
        & "<text x='130' y='140' font-family='Segoe UI Semibold' font-size='9.4' fill='" & DeltaColor & "'>Delta " & DeltaText & "</text>"
        & "</svg>"
RETURN IF(RowCount = 0, BLANK(), "data:image/svg+xml;utf8," & SVG)

